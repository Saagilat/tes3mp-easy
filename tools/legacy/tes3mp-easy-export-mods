#!/bin/bash
#
# tes3mp-easy-export-mods — Package and export mods+scripts to a TES3MP server
#
# Replaces tes3mp-easy-server-update-mods.
#
# Algorithm:
#   1. Reads [mods] section from tes3mp-easy-export.conf
#   2. Validates requiredDataFiles.json exists in PLUGINS_DIR
#   3. Validates CRC32 for each plugin against requiredDataFiles.json
#   4. Packages mods+scripts via package.sh (source)
#   5. SCPs mods.tar.gz to server:/tes3mp-easy/import-mods/
#   6. Runs import_mods.sh on server via SSH
#   7. Runs deploy_mods.sh --latest on server via SSH (only if import succeeds)
#   8. Cleans up local archive
#
# Configuration:
#   $(dirname "$0")/tes3mp-easy-export.conf
#
# Usage:
#   tes3mp-easy-export-mods
#
# Dependencies: bash, rhash, tar, ssh, scp

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/tes3mp-easy-export.conf"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

err()  { echo -e "${RED}[ERROR]${NC} $*" >&2; }
ok()   { echo -e "${GREEN}[OK]${NC}   $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
info() { echo -e "${BLUE}[INFO]${NC} $*"; }

# --- INI parser for sections ---
parse_ini_section() {
    local file="$1"
    local section="$2"
    local prefix="$3"
    local in_section=0

    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" =~ ^# ]] && continue

        if [[ "$line" =~ ^\[(.*)\]$ ]]; then
            if [ "${BASH_REMATCH[1]}" = "$section" ]; then
                in_section=1
            else
                in_section=0
            fi
            continue
        fi

        if [ "$in_section" -eq 1 ]; then
            local key="${line%%=*}"
            local value="${line#*=}"
            key="${key#"${key%%[![:space:]]*}"}"
            key="${key%"${key##*[![:space:]]}"}"
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            case "$value" in
                \"*\") value="${value#\"}"; value="${value%\"}" ;;
                \'*\') value="${value#\'}"; value="${value%\'}" ;;
            esac
            printf -v "${prefix}${key}" "%s" "$value"
        fi
    done < "$file"
}

# --- Check config ---
if [ ! -f "$CONFIG_FILE" ]; then
    err "Config file not found: $CONFIG_FILE"
    exit 1
fi

# --- Parse config sections ---
parse_ini_section "$CONFIG_FILE" "export" "CFG_"
parse_ini_section "$CONFIG_FILE" "mods" "CFG_"

# --- Validate config ---
if [ -z "${CFG_SSH_HOST:-}" ]; then
    err "SSH_HOST is not set in [export] section of $CONFIG_FILE"
    exit 1
fi

if [ -z "${CFG_PLUGINS_DIR:-}" ]; then
    err "PLUGINS_DIR is not set in [mods] section of $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$CFG_PLUGINS_DIR" ]; then
    err "Plugins directory does not exist: $CFG_PLUGINS_DIR"
    exit 1
fi

if [ -z "${CFG_SERVER_SCRIPTS_DIR:-}" ]; then
    err "SERVER_SCRIPTS_DIR is not set in [mods] section of $CONFIG_FILE"
    exit 1
fi

if [ ! -d "$CFG_SERVER_SCRIPTS_DIR" ]; then
    err "Server scripts directory does not exist: $CFG_SERVER_SCRIPTS_DIR"
    exit 1
fi

# --- Check dependencies ---
for cmd in rhash tar ssh scp; do
    if ! command -v "$cmd" &>/dev/null; then
        err "'$cmd' not found. Install it and try again."
        exit 1
    fi
done

echo "=== TES3MP Export Mods ==="
echo "  SSH host:            $CFG_SSH_HOST"
echo "  Plugins dir:         $CFG_PLUGINS_DIR"
echo "  Server scripts:      $CFG_SERVER_SCRIPTS_DIR"
echo ""

# --- Step 1: Check requiredDataFiles.json ---
echo "[1/5] Checking requiredDataFiles.json..."

REQ_JSON="$CFG_PLUGINS_DIR/requiredDataFiles.json"
if [ ! -f "$REQ_JSON" ]; then
    err "requiredDataFiles.json not found in $CFG_PLUGINS_DIR"
    err "Run tes3mp-easy-generate-required-data first."
    exit 1
fi
ok "Found requiredDataFiles.json"

# --- Step 2: Validate CRC32 ---
echo ""
echo "[2/5] Validating plugin CRC32 against requiredDataFiles.json..."

ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

VALIDATION_FAILED=0

while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*\"([^\"]+)\":[[:space:]]*\[(.*)\] ]]; then
        filename="${BASH_REMATCH[1]}"
        crc_content="${BASH_REMATCH[2]}"

        skip=0
        for orig in "${ORIGINAL_FILES[@]}"; do
            if [[ "${filename,,}" == "${orig,,}" ]]; then
                skip=1
                break
            fi
        done
        [[ "$skip" -eq 1 ]] && continue

        filepath="$CFG_PLUGINS_DIR/$filename"

        if [ ! -f "$filepath" ]; then
            err "Plugin \"$filename\" not found at $filepath"
            VALIDATION_FAILED=1
            continue
        fi

        expected_crc=""
        if [[ "$crc_content" =~ '"0x([0-9A-Fa-f]+)"' ]]; then
            expected_crc="${BASH_REMATCH[1]}"
        fi

        if [[ -n "$expected_crc" ]]; then
            actual_crc=$(rhash --crc32 --simple "$filepath" 2>/dev/null | cut -d' ' -f1 | tr '[:lower:]' '[:upper:]')
            expected_crc_upper="${expected_crc^^}"
            if [[ "$actual_crc" != "$expected_crc_upper" ]]; then
                err "CRC32 mismatch for \"$filename\": expected 0x$expected_crc_upper, got 0x$actual_crc"
                VALIDATION_FAILED=1
            fi
        fi
    fi
done < "$REQ_JSON"

if [ "$VALIDATION_FAILED" -ne 0 ]; then
    err "Validation failed — aborting"
    exit 1
fi
ok "All plugins pass CRC32 check"

# --- Step 3: Package mods+scripts ---
echo ""
echo "[3/5] Packaging mods and scripts..."

TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

OUTPUT_ARCHIVE="$TMP_DIR/mods.tar.gz"

export PLUGINS_DIR="$CFG_PLUGINS_DIR"
export SERVER_SCRIPTS_DIR="$CFG_SERVER_SCRIPTS_DIR"
export ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

source "$SCRIPT_DIR/../../server_setup/scripts/package.sh"

package_mods "$OUTPUT_ARCHIVE"

if [ ! -f "$OUTPUT_ARCHIVE" ]; then
    err "Failed to create archive"
    exit 1
fi
ok "Archive created: $OUTPUT_ARCHIVE"

# --- Step 4: Transfer to server ---
echo ""
echo "[4/5] Transferring to server..."

ssh "$CFG_SSH_HOST" "mkdir -p /tes3mp-easy/import-mods" || {
    err "Failed to create remote directory"
    exit 1
}

scp "$OUTPUT_ARCHIVE" "$CFG_SSH_HOST":/tes3mp-easy/import-mods/mods.tar.gz || {
    err "Failed to transfer archive to server"
    exit 1
}
ok "Archive transferred to $CFG_SSH_HOST:/tes3mp-easy/import-mods/"

# --- Step 5: Import and deploy on server ---
echo ""
echo "[5/5] Running import_mods.sh and deploy_mods.sh on server..."
echo "  (import saves archive without stopping server)"
echo "  (deploy stops server, deploys mods, and restarts)"

# Import first (validate + save). If this fails, deploy is not called
ssh "$CFG_SSH_HOST" "cd /tes3mp-easy && bash scripts/import_mods.sh" || {
    err "import_mods.sh failed on server — check server logs"
    err "deploy_mods.sh will NOT be called."
    exit 1
}
ok "Server import completed"

# Deploy (only if import succeeded)
ssh "$CFG_SSH_HOST" "cd /tes3mp-easy && bash scripts/deploy_mods.sh --latest" || {
    err "deploy_mods.sh failed on server — check server logs"
    exit 1
}
ok "Server deploy completed"

# --- Clean up local archive ---
rm -f "$OUTPUT_ARCHIVE"
ok "Local archive cleaned up"

echo ""
echo "=== Done! ==="
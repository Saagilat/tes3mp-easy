#!/bin/bash
#
# menu-nav.sh — TUI menu navigation engine (pure bash, no whiptail)
#

[ -z "${LIB_DIR:-}" ] && LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)" 2>/dev/null || true

# Load theme
if [[ -f "$LIB_DIR/theme.ini" ]]; then
    while IFS='=' read -r key val; do
        key="${key// /}"
        val="${val# }"
        [[ -z "$key" || "$key" == \;* || "$key" == \#* ]] && continue
        case "$key" in THEME_*) eval "$key=\"\$val\"" ;; esac
    done < "$LIB_DIR/theme.ini"
fi

THEME_MENU_WIDTH="${THEME_MENU_WIDTH:-64}"
THEME_BORDER_TL="${THEME_BORDER_TL:-╭}"
THEME_BORDER_TR="${THEME_BORDER_TR:-╮}"
THEME_BORDER_BL="${THEME_BORDER_BL:-╰}"
THEME_BORDER_BR="${THEME_BORDER_BR:-╯}"
THEME_BORDER_H="${THEME_BORDER_H:-─}"
THEME_BORDER_V="${THEME_BORDER_V:-│}"

T_RESET=$'\033[0m'
T_BLD=$'\033[1m'
T_CYN=$'\033['"${THEME_CYAN:-36}"'m'
T_YLW=$'\033['"${THEME_YELLOW:-33}"'m'

W="$THEME_MENU_WIDTH"
H="$THEME_BORDER_H"
V="$THEME_BORDER_V"
TL="$THEME_BORDER_TL"
TR="$THEME_BORDER_TR"
BL="$THEME_BORDER_BL"
BR="$THEME_BORDER_BR"

print_boxed_header() {
    local title="$1"
    local title_len=${#title}
    local pad=$(( (W - title_len - 2) / 2 ))
    [[ $pad -lt 0 ]] && pad=0
    local line
    printf -v line "%${W}s" ""
    line="${line// /$H}"
    printf "\n${T_CYN}${TL}${line}${TR}${T_RESET}\n"
    printf "${T_CYN}${V}${T_RESET}%*s${T_BLD}${T_YLW} %s ${T_RESET}%*s${T_CYN}${V}${T_RESET}\n" \
        $pad "" "$title" $((W - pad - title_len - 2)) ""
    printf "${T_CYN}${BL}${line}${BR}${T_RESET}\n"
}

__saved_stty=""

__restore_tty() {
    if [[ -n "$__saved_stty" ]]; then
        stty "$__saved_stty" 2>/dev/null || true
        __saved_stty=""
    fi
}

__read_key() {
    __saved_stty=$(stty -g 2>/dev/null || echo "")
    trap __restore_tty EXIT INT TERM
    stty raw -echo -icanon min 1 time 0 2>/dev/null

    # Read 1 byte (blocks)
    local b1
    b1=$(dd bs=1 count=1 2>/dev/null; printf x)
    b1="${b1%x}"

    local result="$b1"

    # If ESC, read up to 2 more bytes (non-blocking with 100ms timeout)
    if [[ "$b1" == $'\e' ]]; then
        stty raw -echo -icanon min 1 time 1 2>/dev/null
        local b2 b3
        b2=$(dd bs=1 count=1 2>/dev/null; printf x)
        b2="${b2%x}"
        result="$result$b2"
        if [[ -n "$b2" ]]; then
            b3=$(dd bs=1 count=1 2>/dev/null; printf x)
            b3="${b3%x}"
            result="$result$b3"
        fi
    fi

    __restore_tty
    printf "%s" "$result"
}

run_menu() {
    local menu_title="$1"
    shift
    local ssh_host="${1:-}"
    shift
    local modpack="${1:-}"
    shift
    local config_file="${1:-}"
    shift
    local needs_restart="${1:-}"
    shift
    local items=("$@")

    stty sane 2>/dev/null || true

    local -a v_labels=()
    local -a v_types=()
    local -a v_actions=()

    local i
    for ((i=0; i<${#items[@]}; i++)); do
        local item="${items[$i]}"
        local label="${item%%|*}"
        local rest="${item#*|}"
        local type="${rest%%|*}"
        local action="${rest#*|}"
        v_labels+=("$label")
        v_types+=("$type")
        v_actions+=("$action")
    done

    local count=${#v_labels[@]}
    local cursor=0

    local -a fn_map=()
    for ((i=0; i<count; i++)); do
        [[ "${v_types[$i]}" == "fn" ]] && fn_map+=($i)
    done
    local fn_total=${#fn_map[@]}

    while true; do
        printf "\033[H\033[J"

        print_boxed_header "$menu_title"

        echo ""
        if [[ -n "$ssh_host" ]]; then
            printf "  ${T_CYN}Host:${T_RESET} ${T_BLD}${ssh_host}${T_RESET}\n"
        fi
        if [[ -n "$modpack" ]]; then
            printf "  ${T_CYN}Mods:${T_RESET} ${T_BLD}${modpack}${T_RESET}\n"
        fi
        if [[ "$needs_restart" == "1" ]]; then
            printf "  ${T_YLW}[!] Restart required${T_RESET}\n"
        fi
        if [[ -z "$ssh_host" && -z "$modpack" && "$needs_restart" != "1" ]]; then
            printf "  <not configured>\n"
        fi
        echo ""

        local fn_counter=0
        for ((i=0; i<count; i++)); do
            local typ="${v_types[$i]}"
            local lbl="${v_labels[$i]}"

            if [[ "$typ" == "sep" ]]; then
                local sep_line
                printf -v sep_line "%*s" $((W - 6)) ""
                sep_line="${sep_line// /$H}"
                printf "  ${T_CYN}${T_BLD}${H}${H}${H} ${lbl} ${sep_line}${T_RESET}\n"
            elif [[ "$typ" == "fn" ]]; then
                fn_counter=$((fn_counter + 1))
                if [[ $i -eq $cursor ]]; then
                    printf "  ${T_YLW}%2d) %s${T_RESET}\n" "$fn_counter" "$lbl"
                else
                    printf "  %2d) %s\n" "$fn_counter" "$lbl"
                fi
            fi
        done

        printf "\n  ↑↓ navigate · Enter select · Ctrl+C exit\n"

        # ─── Read a single keypress ───
        local key
        key=$(__read_key)

        case "$key" in
            $'\e[A')
                if [[ $fn_total -gt 0 ]]; then
                    local cur_fn_idx=0
                    for ((i=0; i<fn_total; i++)); do
                        [[ ${fn_map[$i]} -eq $cursor ]] && { cur_fn_idx=$i; break; }
                    done
                    cur_fn_idx=$((cur_fn_idx - 1))
                    [[ $cur_fn_idx -lt 0 ]] && cur_fn_idx=$((fn_total - 1))
                    cursor=${fn_map[$cur_fn_idx]}
                fi
                ;;
            $'\e[B')
                if [[ $fn_total -gt 0 ]]; then
                    local cur_fn_idx=0
                    for ((i=0; i<fn_total; i++)); do
                        [[ ${fn_map[$i]} -eq $cursor ]] && { cur_fn_idx=$i; break; }
                    done
                    cur_fn_idx=$((cur_fn_idx + 1))
                    [[ $cur_fn_idx -ge $fn_total ]] && cur_fn_idx=0
                    cursor=${fn_map[$cur_fn_idx]}
                fi
                ;;
            $'\e'*)
                # Any other ESC sequence — ignore
                ;;
            *)
                # Enter (\r) or any key — select
                local typ="${v_types[$cursor]}"
                local action="${v_actions[$cursor]}"

                if [[ "$typ" == "fn" ]]; then
                    echo ""
                    "$action"
                    echo ""
                    press_enter

                    if [[ -n "$config_file" && -f "$config_file" ]]; then
                        source "$config_file" 2>/dev/null || true
                        ssh_host="${SSH_HOST:-}"
                        modpack="${MODPACK_DIR:-}"
                    fi
                    if [[ -n "$ssh_host" ]]; then
                        if ssh "$ssh_host" "test -f /tes3mp-easy/needs_restart.flag" 2>/dev/null; then
                            needs_restart="1"
                        else
                            needs_restart=""
                        fi
                    fi
                fi
                ;;
        esac
    done
}
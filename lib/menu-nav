#!/bin/bash
#
# menu-nav.sh — TUI menu navigation engine (pure bash, no whiptail)
#

[ -z "${LIB_DIR:-}" ] && LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)" 2>/dev/null || true

# ─── Load theme from INI ───
if [[ -f "$LIB_DIR/theme.ini" ]]; then
    while IFS='=' read -r key val; do
        key="${key// /}"
        val="${val# }"
        [[ -z "$key" || "$key" == \;* || "$key" == \#* ]] && continue
        case "$key" in THEME_*) eval "$key=\"\$val\"" ;; esac
    done < "$LIB_DIR/theme.ini"
fi

# Fallback defaults
THEME_MENU_WIDTH="${THEME_MENU_WIDTH:-64}"
THEME_BORDER_TL="${THEME_BORDER_TL:-╭}"
THEME_BORDER_TR="${THEME_BORDER_TR:-╮}"
THEME_BORDER_BL="${THEME_BORDER_BL:-╰}"
THEME_BORDER_BR="${THEME_BORDER_BR:-╯}"
THEME_BORDER_H="${THEME_BORDER_H:-─}"
THEME_BORDER_V="${THEME_BORDER_V:-│}"

# Build ANSI escapes from numeric color values
T_RESET=$'\033[0m'
T_BLD=$'\033[1m'
T_CYN=$'\033['"${THEME_CYAN:-36}"'m'
T_YLW=$'\033['"${THEME_YELLOW:-33}"'m'

# Shortcuts
W="$THEME_MENU_WIDTH"
H="$THEME_BORDER_H"
V="$THEME_BORDER_V"
TL="$THEME_BORDER_TL"
TR="$THEME_BORDER_TR"
BL="$THEME_BORDER_BL"
BR="$THEME_BORDER_BR"


# ────────────────────────────────────────────────────────────
# print_boxed_header
# ────────────────────────────────────────────────────────────
print_boxed_header() {
    local title="$1"
    local title_len=${#title}
    local pad=$(( (W - title_len - 2) / 2 ))
    [[ $pad -lt 0 ]] && pad=0

    local line
    printf -v line "%${W}s" ""
    line="${line// /$H}"

    printf "\n${T_CYN}${TL}${line}${TR}${T_RESET}\n"
    printf "${T_CYN}${V}${T_RESET}%*s${T_BLD}${T_YLW} %s ${T_RESET}%*s${T_CYN}${V}${T_RESET}\n" \
        $pad "" "$title" $((W - pad - title_len - 2)) ""
    printf "${T_CYN}${BL}${line}${BR}${T_RESET}\n"
}

# ────────────────────────────────────────────────────────────
# run_menu
# ────────────────────────────────────────────────────────────
run_menu() {
    local menu_title="$1"
    shift
    local ssh_host="${1:-}"
    shift
    local modpack="${1:-}"
    shift
    local config_file="${1:-}"
    shift
    local needs_restart="${1:-}"
    shift
    local items=("$@")

    # Build visible arrays
    local -a v_labels=()
    local -a v_types=()
    local -a v_actions=()

    local i
    for ((i=0; i<${#items[@]}; i++)); do
        local item="${items[$i]}"
        local label="${item%%|*}"
        local rest="${item#*|}"
        local type="${rest%%|*}"
        local action="${rest#*|}"

        v_labels+=("$label")
        v_types+=("$type")
        v_actions+=("$action")
    done

    local count=${#v_labels[@]}
    local cursor=0

    # Build fn-only index mapping
    local -a fn_map=()
    for ((i=0; i<count; i++)); do
        [[ "${v_types[$i]}" == "fn" ]] && fn_map+=($i)
    done
    local fn_total=${#fn_map[@]}

    while true; do
        printf "\033[H\033[J"

        # ─── Header ───
        print_boxed_header "$menu_title"

        # ─── Info ───
        echo ""
        if [[ -n "$ssh_host" ]]; then
            printf "  ${T_CYN}Host:${T_RESET} ${T_BLD}${ssh_host}${T_RESET}\n"
        fi
        if [[ -n "$modpack" ]]; then
            printf "  ${T_CYN}Mods:${T_RESET} ${T_BLD}${modpack}${T_RESET}\n"
        fi
        if [[ "$needs_restart" == "1" ]]; then
            printf "  ${T_YLW}[!] Restart required${T_RESET}\n"
        fi
        if [[ -z "$ssh_host" && -z "$modpack" && "$needs_restart" != "1" ]]; then
            printf "  <not configured>\n"
        fi
        echo ""

        # ─── Items ───
        local fn_counter=0
        for ((i=0; i<count; i++)); do
            local typ="${v_types[$i]}"
            local lbl="${v_labels[$i]}"

            if [[ "$typ" == "sep" ]]; then
                local sep_line
                printf -v sep_line "%*s" $((W - 6)) ""
                sep_line="${sep_line// /$H}"
                printf "  ${T_CYN}${T_BLD}${H}${H}${H} ${lbl} ${sep_line}${T_RESET}\n"
            elif [[ "$typ" == "fn" ]]; then
                fn_counter=$((fn_counter + 1))
                if [[ $i -eq $cursor ]]; then
                    printf "  ${T_YLW}%2d) %s${T_RESET}\n" "$fn_counter" "$lbl"
                else
                    printf "  %2d) %s\n" "$fn_counter" "$lbl"
                fi
            fi
        done

        printf "\n  Enter number or press Enter for current item · Ctrl+C exit\n"

        # ─── Key input via read -p ───
        echo ""
        local choice
        read -r -p "  Select number or press Enter for current: " choice

        if [[ -n "$choice" && "$choice" =~ ^[0-9]+$ ]]; then
            # Try to map number to fn item
            local target_idx=0
            local fn_c=0
            for ((i=0; i<count; i++)); do
                [[ "${v_types[$i]}" == "fn" ]] && ((fn_c++))
                if [[ $fn_c -eq $choice ]]; then
                    target_idx=$i
                    break
                fi
            done
            if [[ $target_idx -ge 0 && $target_idx -lt count ]]; then
                cursor=$target_idx
            fi
        fi

        # Execute selected item
        local typ="${v_types[$cursor]}"
        local action="${v_actions[$cursor]}"

        if [[ "$typ" == "fn" ]]; then
            echo ""
            "$action"
            echo ""
            press_enter

            if [[ -n "$config_file" && -f "$config_file" ]]; then
                source "$config_file" 2>/dev/null || true
                ssh_host="${SSH_HOST:-}"
                modpack="${MODPACK_DIR:-}"
            fi
            if [[ -n "$ssh_host" ]]; then
                if ssh "$ssh_host" "test -f /tes3mp-easy/needs_restart.flag" 2>/dev/null; then
                    needs_restart="1"
                else
                    needs_restart=""
                fi
            fi
        fi
    done
}
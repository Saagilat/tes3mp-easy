#!/bin/bash
#
# install-mods — Download and install mods from TES3MP server
#
# What it does:
#   1. Fetches list of mod backups from server
#   2. Downloads selected/latest archive
#   3. Extracts plugins into TES3MP_DIR/servers/<address>/data/Data Files/
#   4. Generates per-server openmw.cfg with:
#      - data= to original Morrowind Data Files
#      - data= to server's data/Data Files/
#      - content= for all plugins
#   5. Replaces user openmw.cfg in Proton prefix
#   6. Removes downloaded archive
#
# The server address is determined from destinationAddress in tes3mp-client-default.cfg.
# Each server gets its own isolated folder — switch servers just by changing
# destinationAddress and running this script again.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found. Run setup-wizard first."
    exit 1
}

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

if [[ -z "${MORROWIND_PATH:-}" ]]; then
    err "MORROWIND_PATH is not set in config."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
MORROWIND_PATH="${MORROWIND_PATH/#\~/$HOME}"

# ────────────────────────────────────────────────────
# 1. Get server address and derive server_id
# ────────────────────────────────────────────────────
SERVER_URL="${SERVER_URL:-$(_get_server_url)}" || {
    err "Could not determine server URL."
    err "Set TES3MP_DIR in config or check tes3mp-client-default.cfg."
    exit 1
}

info "Server: $SERVER_URL"

# Strip protocol and port to get a clean server id (hostname)
SERVER_ID=$(echo "$SERVER_URL" | sed -E 's|^https?://||; s|:?[0-9]*/?$||; s|[/:]+|_|g')
[[ -z "$SERVER_ID" ]] && SERVER_ID="default"

info "Server ID: $SERVER_ID"

# ────────────────────────────────────────────────────
# 2. Paths
# ────────────────────────────────────────────────────
PREFIX_DIR="$TES3MP_DIR/prefix"
OPENMW_CFG="$PREFIX_DIR/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/openmw.cfg"

SERVER_DIR="$TES3MP_DIR/servers/$SERVER_ID"
SERVER_DATA_DIR="$SERVER_DIR/data/Data Files"
SERVER_CFG="$SERVER_DIR/openmw.cfg"

mkdir -p "$SERVER_DATA_DIR"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Downloading and Installing Mods"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Server:       $SERVER_ID"
echo "  Server data:  $SERVER_DATA_DIR"
echo "  Server cfg:   $SERVER_CFG"
echo ""

# ────────────────────────────────────────────────────
# 3. Fetch mod backup list
# ────────────────────────────────────────────────────
check_deps jq

info "Fetching list of mod backups..."

JSON=$(curl -sf "$SERVER_URL/list-backups/mods" 2>/dev/null || echo "")
if [[ -z "$JSON" || "$JSON" == "[]" ]]; then
    err "No mod backups available on server."
    exit 1
fi

# Find current backup: file whose sha256 matches current field
SELECTED=$(echo "$JSON" | jq -r '
    . as $root |
    $root.files[] |
    select(.sha256 == $root.current) |
    .name
' 2>/dev/null)

if [[ -z "$SELECTED" ]]; then
    err "No current mod backup available on server."
    err "Ask admin to deploy mods first."
    exit 1
fi
info "Current mods: $SELECTED"

# ────────────────────────────────────────────────────
# 4. Download archive
# ────────────────────────────────────────────────────
DOWNLOAD_DIR=$(mktemp -d)
ARCHIVE_PATH="$DOWNLOAD_DIR/$SELECTED"

info "Downloading $SELECTED..."
curl -sfL "$SERVER_URL/download/mods/$SELECTED" -o "$ARCHIVE_PATH" || {
    err "Download failed."
    rm -rf "$DOWNLOAD_DIR"
    exit 1
}
ok "Downloaded: $SELECTED"

# ────────────────────────────────────────────────────
# 5. Extract archive
# ────────────────────────────────────────────────────
EXTRACT_DIR=$(mktemp -d)
info "Extracting..."
tar xzf "$ARCHIVE_PATH" -C "$EXTRACT_DIR" || {
    err "Failed to extract archive."
    rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
    exit 1
}
ok "Extracted."

PLUGINS_SRC="$EXTRACT_DIR/plugins"
if [[ ! -d "$PLUGINS_SRC" ]]; then
    err "No 'plugins/' directory found in archive."
    rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
    exit 1
fi

# ────────────────────────────────────────────────────
# 6. Clean server data and copy new plugins
# ────────────────────────────────────────────────────
echo ""
info "Cleaning server data directory..."

# Remove all plugins from server data dir
for plugin in "$SERVER_DATA_DIR"/*.esp "$SERVER_DATA_DIR"/*.ESP \
              "$SERVER_DATA_DIR"/*.esm "$SERVER_DATA_DIR"/*.ESM \
              "$SERVER_DATA_DIR"/*.omwaddon "$SERVER_DATA_DIR"/*.OMWADDON; do
    [[ -f "$plugin" ]] && rm -f "$plugin"
done

echo ""
info "Copying server plugins to $SERVER_DATA_DIR ..."

PLUGIN_COUNT=0
for plugin in "$PLUGINS_SRC"/*.esp "$PLUGINS_SRC"/*.ESP \
              "$PLUGINS_SRC"/*.esm "$PLUGINS_SRC"/*.ESM \
              "$PLUGINS_SRC"/*.omwaddon "$PLUGINS_SRC"/*.OMWADDON; do
    [[ -f "$plugin" ]] || continue
    cp "$plugin" "$SERVER_DATA_DIR/"
    ((PLUGIN_COUNT++)) || true
done

ok "$PLUGIN_COUNT plugin(s) copied to $SERVER_DATA_DIR"

# ────────────────────────────────────────────────────
# 7. Generate server openmw.cfg
# ────────────────────────────────────────────────────
echo ""
info "Generating server config..."

DATA_BASENAME="$(basename "$MORROWIND_PATH")"

# Start from current user config (if exists) to preserve encoding=, fallback=, etc.
# Remove only data= and content= lines — we'll replace those.
SERVER_CFG_TMP=$(mktemp)
if [[ -f "$OPENMW_CFG" ]]; then
    grep -vE '^data=|^content=' "$OPENMW_CFG" > "$SERVER_CFG_TMP" || true
else
    # No existing config — start with basic fallbacks
    cat > "$SERVER_CFG_TMP" << 'CFGEMPTY'
fallback-archive=Morrowind.bsa
fallback-archive=Tribunal.bsa
fallback-archive=Bloodmoon.bsa
CFGEMPTY
fi

# Add our data= paths
cat >> "$SERVER_CFG_TMP" << CFGDATA
# openmw.cfg for server: $SERVER_ID
# Generated by install-mods on $(date)

# Original Morrowind data files
data="C:\\${DATA_BASENAME}\\Data Files"

# Server-specific mods
data="C:\\TES3MP\\servers\\${SERVER_ID}\\data\\Data Files"
CFGDATA

# Add base game content
echo "" >> "$SERVER_CFG_TMP"
echo "# Base game content" >> "$SERVER_CFG_TMP"
echo "content=Morrowind.esm" >> "$SERVER_CFG_TMP"
echo "content=Tribunal.esm" >> "$SERVER_CFG_TMP"
echo "content=Bloodmoon.esm" >> "$SERVER_CFG_TMP"

# Add content= lines from requiredDataFiles.json or plugins order
ADDED_COUNT=0
echo "" >> "$SERVER_CFG_TMP"
echo "# Server mods (order from server)" >> "$SERVER_CFG_TMP"

REQ_JSON="$PLUGINS_SRC/requiredDataFiles.json"
if [[ -f "$REQ_JSON" ]]; then
    while IFS= read -r filename; do
        [[ -z "$filename" ]] && continue
        if [[ -f "$SERVER_DATA_DIR/$filename" ]]; then
            echo "content=$filename" >> "$SERVER_CFG_TMP"
            ((ADDED_COUNT++)) || true
        else
            warn "Skipping missing plugin: $filename"
        fi
    done < <(jq -r '.[] | keys[]' "$REQ_JSON")
else
    for plugin in "$PLUGINS_SRC"/*.esp "$PLUGINS_SRC"/*.ESP \
                  "$PLUGINS_SRC"/*.esm "$PLUGINS_SRC"/*.ESM \
                  "$PLUGINS_SRC"/*.omwaddon "$PLUGINS_SRC"/*.OMWADDON; do
        [[ -f "$plugin" ]] || continue
        BASENAME=$(basename "$plugin")
        echo "content=$BASENAME" >> "$SERVER_CFG_TMP"
        ((ADDED_COUNT++)) || true
    done
fi

# Move to final location
mv "$SERVER_CFG_TMP" "$SERVER_CFG"
ok "$ADDED_COUNT content entries added to server config"
ok "Server config written to $SERVER_CFG"

# ────────────────────────────────────────────────────
# 8. Copy server config to user openmw.cfg in prefix
# ────────────────────────────────────────────────────
echo ""
info "Updating user openmw.cfg in Proton prefix..."

if [[ ! -f "$OPENMW_CFG" ]]; then
    err "openmw.cfg not found at: $OPENMW_CFG"
    err "Run 'install-client' first (or launch the client once)."
    rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
    exit 1
fi

BACKUP_CFG="$OPENMW_CFG.bak.$(date +%Y%m%d_%H%M%S)"
cp "$OPENMW_CFG" "$BACKUP_CFG"
ok "Backup saved: $BACKUP_CFG"

cp "$SERVER_CFG" "$OPENMW_CFG"
ok "User openmw.cfg updated for server: $SERVER_ID"

# ────────────────────────────────────────────────────
# 9. Clean up
# ────────────────────────────────────────────────────
rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
ok "Downloaded archive removed."

echo ""
echo "═══════════════════════════════════════════════"
echo "  Mods installation complete!"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Server:     $SERVER_ID"
echo "  Plugins:    $PLUGIN_COUNT"
echo "  Content:    $ADDED_COUNT"
echo ""
echo "  Morrowind Data Files were NOT modified."
echo "  Mods are stored in: $SERVER_DIR"
echo ""
echo "  Now launch the client: run-client"
echo ""
#!/bin/bash
#
# install-mods — Download and install mods from TES3MP server
#
# What it does:
#   1. Fetches list of mod backups from server
#   2. Downloads selected/latest archive
#   3. Removes all old content= from openmw.cfg
#   4. Extracts plugins into MORROWIND_PATH/Data Files
#   5. Adds content= for all plugins from requiredDataFiles.json
#   6. Removes downloaded archive
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found. Run setup-wizard first."
    exit 1
}

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

if [[ -z "${MORROWIND_PATH:-}" ]]; then
    err "MORROWIND_PATH is not set in config."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
MORROWIND_PATH="${MORROWIND_PATH/#\~/$HOME}"

# Path to OpenMW config inside Proton prefix
PREFIX_DIR="$TES3MP_DIR/prefix"
OPENMW_CFG="$PREFIX_DIR/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/openmw.cfg"

if [[ ! -f "$OPENMW_CFG" ]]; then
    err "openmw.cfg not found at: $OPENMW_CFG"
    err "Run 'install-client' first (or launch the client once)."
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Downloading and Installing Mods"
echo "═══════════════════════════════════════════════"
echo ""

# ────────────────────────────────────────────────────
# 1. Get server URL
# ────────────────────────────────────────────────────
SERVER_URL="${SERVER_URL:-$(_get_server_url)}" || {
    err "Could not determine server URL."
    err "Set TES3MP_DIR in config or check tes3mp-client-default.cfg."
    exit 1
}

info "Server: $SERVER_URL"

# ────────────────────────────────────────────────────
# 2. Fetch mod backup list
# ────────────────────────────────────────────────────
check_deps jq

info "Fetching list of mod backups..."

JSON=$(curl -sf "$SERVER_URL/list-backups/mods" 2>/dev/null || echo "")
if [[ -z "$JSON" || "$JSON" == "[]" ]]; then
    err "No mod backups available on server."
    exit 1
fi

# Find current backup: file whose sha256 matches current field
SELECTED=$(echo "$JSON" | jq -r '
    . as $root |
    $root.files[] |
    select(.sha256 == $root.current) |
    .name
' 2>/dev/null)

if [[ -z "$SELECTED" ]]; then
    err "No current mod backup available on server."
    err "Ask admin to deploy mods first."
    exit 1
fi
info "Current mods: $SELECTED"

# ────────────────────────────────────────────────────
# 3. Download archive
# ────────────────────────────────────────────────────
DOWNLOAD_DIR=$(mktemp -d)
ARCHIVE_PATH="$DOWNLOAD_DIR/$SELECTED"

info "Downloading $SELECTED..."
curl -sfL "$SERVER_URL/download/mods/$SELECTED" -o "$ARCHIVE_PATH" || {
    err "Download failed."
    rm -rf "$DOWNLOAD_DIR"
    exit 1
}
ok "Downloaded: $SELECTED"

# ────────────────────────────────────────────────────
# 4. Extract archive
# ────────────────────────────────────────────────────
EXTRACT_DIR=$(mktemp -d)
info "Extracting..."
tar xzf "$ARCHIVE_PATH" -C "$EXTRACT_DIR" || {
    err "Failed to extract archive."
    rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
    exit 1
}
ok "Extracted."

PLUGINS_SRC="$EXTRACT_DIR/plugins"
if [[ ! -d "$PLUGINS_SRC" ]]; then
    err "No 'plugins/' directory found in archive."
    rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
    exit 1
fi

# ────────────────────────────────────────────────────
# 5. Clean openmw.cfg (remove all content= lines)
# ────────────────────────────────────────────────────
echo ""
info "Cleaning old content entries from openmw.cfg..."

BACKUP_CFG="$OPENMW_CFG.bak.$(date +%Y%m%d_%H%M%S)"
cp "$OPENMW_CFG" "$BACKUP_CFG"
ok "Backup saved: $BACKUP_CFG"

grep -vE '^content=' "$OPENMW_CFG" > "${OPENMW_CFG}.tmp"
mv "${OPENMW_CFG}.tmp" "$OPENMW_CFG"
ok "All content entries removed (will be re-added from server order)."

# ────────────────────────────────────────────────────
# 6. Clean and copy plugins to Data Files
# ────────────────────────────────────────────────────
echo ""
info "Cleaning Data Files from all plugins..."

DATA_FILES_DIR="$MORROWIND_PATH/Data Files"
mkdir -p "$DATA_FILES_DIR"

# Keep only base game ESM files, remove everything else
REMOVED_COUNT=0
for plugin in "$DATA_FILES_DIR"/*.esp "$DATA_FILES_DIR"/*.ESP \
              "$DATA_FILES_DIR"/*.esm "$DATA_FILES_DIR"/*.ESM \
              "$DATA_FILES_DIR"/*.omwaddon "$DATA_FILES_DIR"/*.OMWADDON; do
    [[ -f "$plugin" ]] || continue
    basename="$(basename "$plugin")"
    # Keep base game files
    if [[ "${basename,,}" = "morrowind.esm" || \
          "${basename,,}" = "tribunal.esm" || \
          "${basename,,}" = "bloodmoon.esm" ]]; then
        continue
    fi
    rm -f "$plugin"
    warn "Removed plugin: $basename"
    ((REMOVED_COUNT++)) || true
done

if [[ "$REMOVED_COUNT" -gt 0 ]]; then
    info "Removed $REMOVED_COUNT plugin(s) from Data Files"
fi

echo ""
info "Copying server plugins to Data Files..."

PLUGIN_COUNT=0
for plugin in "$PLUGINS_SRC"/*.esp "$PLUGINS_SRC"/*.ESP \
              "$PLUGINS_SRC"/*.esm "$PLUGINS_SRC"/*.ESM \
              "$PLUGINS_SRC"/*.omwaddon "$PLUGINS_SRC"/*.OMWADDON; do
    [[ -f "$plugin" ]] || continue
    cp "$plugin" "$DATA_FILES_DIR/"
    ((PLUGIN_COUNT++)) || true
done

ok "$PLUGIN_COUNT plugin(s) copied to $DATA_FILES_DIR"

# ────────────────────────────────────────────────────
# 7. Add content= lines to openmw.cfg
# ────────────────────────────────────────────────────
echo ""
info "Updating openmw.cfg..."

ADDED_COUNT=0

REQ_JSON="$EXTRACT_DIR/requiredDataFiles.json"
if [[ -f "$REQ_JSON" ]]; then
    # Extract filenames from requiredDataFiles.json
    # JSON format (array): [ { "file.esp": [...], ... }, ... ]
    while IFS= read -r filename; do
        [[ -z "$filename" ]] && continue
        if [[ -f "$DATA_FILES_DIR/$filename" ]]; then
            echo "content=$filename" >> "$OPENMW_CFG"
            ((ADDED_COUNT++)) || true
        else
            warn "Skipping missing plugin: $filename"
        fi
    done < <(jq -r '.[] | keys[]' "$REQ_JSON")
else
    for plugin in "$PLUGINS_SRC"/*.esp "$PLUGINS_SRC"/*.ESP \
                  "$PLUGINS_SRC"/*.esm "$PLUGINS_SRC"/*.ESM \
                  "$PLUGINS_SRC"/*.omwaddon "$PLUGINS_SRC"/*.OMWADDON; do
        [[ -f "$plugin" ]] || continue
        BASENAME=$(basename "$plugin")
        echo "content=$BASENAME" >> "$OPENMW_CFG"
        ((ADDED_COUNT++)) || true
    done
fi

ok "$ADDED_COUNT content entries added to openmw.cfg (server order)"

# ────────────────────────────────────────────────────
# 8. Clean up
# ────────────────────────────────────────────────────
rm -rf "$DOWNLOAD_DIR" "$EXTRACT_DIR"
ok "Downloaded archive removed."

echo ""
echo "═══════════════════════════════════════════════"
echo "  Mods installation complete!"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Plugins copied: $PLUGIN_COUNT"
echo "  Content entries: $ADDED_COUNT"
echo ""
echo "  Now launch the client: run-client"
echo ""
#!/bin/bash
#
# set-proton-path — Validate and save PROTON_PATH to config
# Layer 1: non-interactive.
# Usage: set-proton-path <path>
# Returns 0 if valid (proton executable found), 1 if invalid.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.ini"

path="${1:-}"
[[ -z "$path" ]] && { err "Usage: set-proton-path <path>"; exit 1; }

resolved="${path/#\~/$HOME}"

if [[ -f "$resolved/proton" ]]; then
    if grep -q "^PROTON_PATH[[:space:]]*=" "$CONFIG" 2>/dev/null; then
        sed -i "s|^PROTON_PATH[[:space:]]*=.*|PROTON_PATH = ${path}|" "$CONFIG"
    else
        echo "PROTON_PATH = ${path}" >> "$CONFIG"
    fi
    ok "PROTON_PATH set to: ${path}"
    return 0
else
    err "proton executable not found at: ${resolved}"
    return 1
fi
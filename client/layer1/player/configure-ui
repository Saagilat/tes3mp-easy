#!/bin/bash
#
# configure-ui ‚Äî Configure GUI and Video settings (ttf resolution, font size, scaling, fps)
# Layer 1: non-interactive. Takes values as arguments.
# Usage: configure-ui <ttf_resolution> <font_size> <scaling> [framerate_limit] [display_fps_counter]
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found."; exit 1; }

[[ -z "${TES3MP_DIR:-}" ]] && { err "TES3MP_DIR is not set in config."; exit 1; }
TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"

TTF_RES="${1:-}"
FONT_SIZE="${2:-}"
SCALING="${3:-}"
FPS_LIMIT="${4:-}"
FPS_COUNTER="${5:-}"

[[ -z "$TTF_RES" || -z "$FONT_SIZE" || -z "$SCALING" ]] && {
    err "Usage: configure-ui <ttf_resolution> <font_size> <scaling> [framerate_limit] [display_fps_counter]"
    exit 1
}

SETTINGS_CFG="$TES3MP_DIR/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/settings.cfg"

if [[ ! -f "$SETTINGS_CFG" ]]; then
    err "settings.cfg not found at: $SETTINGS_CFG"
    err "Run the client at least once first."
    exit 1
fi

echo ""
echo "‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê"
echo "  Configure UI & Video"
echo "‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê"
echo ""

# ‚îÄ‚îÄ UI settings (section [GUI]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
if ! grep -q "^\[GUI\]" "$SETTINGS_CFG" 2>/dev/null; then
    echo "" >> "$SETTINGS_CFG"
    echo "[GUI]" >> "$SETTINGS_CFG"
fi

for key_val in "ttf resolution=$TTF_RES" "font size=$FONT_SIZE" "scaling factor=$SCALING"; do
    key="${key_val%=*}"
    val="${key_val#*=}"
    if grep -q "^${key}[[:space:]]*=" <(awk '/^\[GUI\]/,0' "$SETTINGS_CFG" 2>/dev/null); then
        line_num=$(awk '/^\[GUI\]/,0' "$SETTINGS_CFG" | grep -n "^${key}[[:space:]]*=" | head -1 | cut -d: -f1)
        abs_line=$(( $(grep -n "^\[GUI\]" "$SETTINGS_CFG" | head -1 | cut -d: -f1) + line_num - 1 ))
        sed -i "${abs_line}s|^${key}[[:space:]]*=.*|${key} = ${val}|" "$SETTINGS_CFG"
    else
        sed -i "/^\[GUI\]/a ${key} = ${val}" "$SETTINGS_CFG"
    fi
done

# ‚îÄ‚îÄ Video settings (section [Video]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
if ! grep -q "^\[Video\]" "$SETTINGS_CFG" 2>/dev/null; then
    echo "" >> "$SETTINGS_CFG"
    echo "[Video]" >> "$SETTINGS_CFG"
fi

if [[ -n "$FPS_LIMIT" ]]; then
    key="framerate limit"
    if grep -q "^${key}[[:space:]]*=" <(awk '/^\[Video\]/,0' "$SETTINGS_CFG" 2>/dev/null); then
        line_num=$(awk '/^\[Video\]/,0' "$SETTINGS_CFG" | grep -n "^${key}[[:space:]]*=" | head -1 | cut -d: -f1)
        abs_line=$(( $(grep -n "^\[Video\]" "$SETTINGS_CFG" | head -1 | cut -d: -f1) + line_num - 1 ))
        sed -i "${abs_line}s|^${key}[[:space:]]*=.*|${key} = ${FPS_LIMIT}|" "$SETTINGS_CFG"
    else
        sed -i "/^\[Video\]/a ${key} = ${FPS_LIMIT}" "$SETTINGS_CFG"
    fi
fi

if [[ -n "$FPS_COUNTER" ]]; then
    key="display framerate counter"
    if grep -q "^${key}[[:space:]]*=" <(awk '/^\[Video\]/,0' "$SETTINGS_CFG" 2>/dev/null); then
        line_num=$(awk '/^\[Video\]/,0' "$SETTINGS_CFG" | grep -n "^${key}[[:space:]]*=" | head -1 | cut -d: -f1)
        abs_line=$(( $(grep -n "^\[Video\]" "$SETTINGS_CFG" | head -1 | cut -d: -f1) + line_num - 1 ))
        sed -i "${abs_line}s|^${key}[[:space:]]*=.*|${key} = ${FPS_COUNTER}|" "$SETTINGS_CFG"
    else
        sed -i "/^\[Video\]/a ${key} = ${FPS_COUNTER}" "$SETTINGS_CFG"
    fi
fi

ok "UI settings saved: ttf resolution=$TTF_RES, font size=$FONT_SIZE, scaling=$SCALING"
if [[ -n "$FPS_LIMIT" ]]; then
    ok "Framerate limit set to: $FPS_LIMIT"
fi
if [[ -n "$FPS_COUNTER" ]]; then
    ok "Display framerate counter set to: $FPS_COUNTER"
fi

echo ""
echo "‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê"
echo "  Done! Restart the client to apply changes."
echo ""
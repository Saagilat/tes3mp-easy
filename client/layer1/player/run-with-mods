#!/bin/bash
#
# run-with-mods — Install mods and launch TES3MP client
#
# Combines install-mods + run-client into one call.
# If mod installation fails (server unavailable, no mods),
# warns and still launches the client.
#
# Usage:
#   run-with-mods
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found. Run setup-wizard first."
    exit 1
}

echo ""
echo "═══════════════════════════════════════════════"
echo "  Installing Mods & Launching Client"
echo "═══════════════════════════════════════════════"
echo ""

# Step 1: install mods (best-effort)
if bash "$SCRIPT_DIR/layer1/player/install-mods" 2>/dev/null; then
    ok "Mods installed."
else
    warn "Mod installation skipped or failed — launching client without mod update."
    warn "This is normal if the server is offline or has no mods deployed."
fi

# Step 2: launch client
echo ""
bash "$SCRIPT_DIR/layer1/player/run-client"
#!/bin/bash
#
# edit-client-cfg-record — Set key=value in tes3mp-client-default.cfg
# Layer 1: non-interactive, player.
# Usage: edit-client-cfg-record <key> <value>
#
# Preserves INI section structure — replaces key in-place if found.
# If key is not found, appends to [General] section (or to end of file).
#
# Examples:
#   edit-client-cfg-record destinationAddress 10.0.0.50
#   edit-client-cfg-record port 25565
#   edit-client-cfg-record password mypass
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found. Run setup-wizard first."
    exit 1
}

key="${1:-}"
value="${2:-}"

[[ -z "$key" ]] && { err "Usage: edit-client-cfg-record <key> <value>"; exit 1; }

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
cfg="$TES3MP_DIR/tes3mp-client-default.cfg"
if [[ ! -f "$cfg" ]]; then
    err "Client config not found: $cfg"
    err "Run install-client first."
    exit 1
fi

# Escape value for sed: use '|' as delimiter (rare in IPs/paths/passwords)
escaped_value="${value//|/\\|}"

if grep -qi "^${key}[[:space:]]*=" "$cfg" 2>/dev/null; then
    # Key exists — replace in-place, preserving its position in the file
    sed -i "s|^${key}[[:space:]]*=.*|${key} = ${escaped_value}|I" "$cfg"
else
    # Key not found — insert at end of [General] section (case-insensitive)
    tmp=$(mktemp) || { err "Failed to create temp file."; exit 1; }

    awk -v k="$key" -v v="$value" '
        BEGIN { found=0 }
        tolower($0) ~ /^\[general\]/ { print; found=1; next }
        found && /^\[/ { print k " = " v; found=0 }
        { print }
        END { if (found) print k " = " v }
    ' "$cfg" > "$tmp" && mv "$tmp" "$cfg" || {
        err "Failed to edit ${key}"
        rm -f "$tmp"
        exit 1
    }
fi

ok "${key} set to: ${value}"
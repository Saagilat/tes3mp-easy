#!/bin/bash
#
# edit-client-cfg-record — Set key=value in tes3mp-client-default.cfg
# Layer 1: non-interactive, player.
# Usage: edit-client-cfg-record <key> <value>
#
# Removes the key from any INI section, then inserts it into [General].
# This ensures the settings are always in the section TES3MP expects.
# Output: nothing on success, error message on stderr on failure.
#
# Examples:
#   edit-client-cfg-record destinationAddress 10.0.0.50
#   edit-client-cfg-record port 25565
#   edit-client-cfg-record password mypass
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
SHARED_CONFIG="$CONFIG_DIR/tes3mp-easy.json"

key="${1:-}"
value="${2:-}"

[[ -z "$key" ]] && { echo "Usage: edit-client-cfg-record <key> <value>" >&2; exit 1; }

# Read TES3MP_DIR from JSON config via jq
if ! command -v jq &>/dev/null; then
    echo "jq is required but not found." >&2
    exit 1
fi

if [[ ! -f "$SHARED_CONFIG" ]]; then
    echo "Config not found: $SHARED_CONFIG" >&2
    exit 1
fi

TES3MP_DIR=$(jq -r '.TES3MP_DIR // empty' "$SHARED_CONFIG" 2>/dev/null)

if [[ -z "$TES3MP_DIR" ]]; then
    echo "TES3MP_DIR is not set in config." >&2
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
cfg="$TES3MP_DIR/tes3mp-client-default.cfg"

if [[ ! -f "$cfg" ]]; then
    echo "Client config not found: $cfg" >&2
    echo "Run install-client first." >&2
    exit 1
fi

# Step 1: remove existing key=value from anywhere in the file (case-insensitive)
tmp=$(mktemp) || { echo "Failed to create temp file." >&2; exit 1; }

grep -vi "^${key}[[:space:]]*=" "$cfg" > "$tmp" 2>/dev/null || true

# Step 2: insert key=value after [General] section (or at end of file)
tmp2=$(mktemp) || { echo "Failed to create temp file." >&2; rm -f "$tmp"; exit 1; }

awk -v k="$key" -v v="$value" '
    BEGIN { found=0 }
    tolower($0) ~ /^\[general\]/ { print; found=1; next }
    found && /^\[/ { print k " = " v; found=0 }
    { print }
    END { if (found) print k " = " v }
' "$tmp" > "$tmp2" 2>/dev/null && mv "$tmp2" "$cfg" || {
    echo "Failed to edit ${key}" >&2
    rm -f "$tmp" "$tmp2"
    exit 1
}

rm -f "$tmp"
exit 0
#!/bin/bash
#
# set-morrowind-path — Validate and save MORROWIND_PATH to config
# Layer 1: non-interactive.
# Usage: set-morrowind-path <path>
# Returns 0 if valid and saved, 1 if invalid.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.ini"

path="${1:-}"
[[ -z "$path" ]] && { err "Usage: set-morrowind-path <path>"; exit 1; }

resolved="${path/#\~/$HOME}"

if [[ -f "$resolved/Data Files/Morrowind.esm" ]]; then
    if grep -q "^MORROWIND_PATH[[:space:]]*=" "$CONFIG" 2>/dev/null; then
        sed -i "s|^MORROWIND_PATH[[:space:]]*=.*|MORROWIND_PATH = ${path}|" "$CONFIG"
    else
        echo "MORROWIND_PATH = ${path}" >> "$CONFIG"
    fi
    ok "MORROWIND_PATH set to: ${path}"
    return 0
else
    err "Morrowind.esm not found at: ${resolved}/Data Files"
    return 1
fi
#!/bin/bash
#
# show-backups-world — List world backup archives from TES3MP server
# Layer 1: outputs JSON, no formatting.
# Usage: show-backups-world
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1

SERVER_URL=$(_get_server_url) || exit 1

retry curl -sf --max-time 10 "$SERVER_URL/list-backups/world" 2>/dev/null || exit 1

#!/bin/bash
#
# download-backup-mods — Download a mod backup archive from TES3MP server
# Usage: download-backup-mods <filename> [destination]
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-player.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

SERVER_URL=$(_get_server_url) || {
    err "Could not determine server URL."
    err "Set TES3MP_DIR in config or check tes3mp-client-default.cfg."
    exit 1
}

filename="${1:-}"
[[ -z "$filename" ]] && { err "Usage: download-backup-mods <filename> [destination]"; exit 1; }
base_dir="${BACKUP_DIR:-$HOME/Downloads}"
dest="${2:-$base_dir/mods/$filename}"

mkdir -p "$(dirname "$dest")"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Downloading mod backup: $filename"
echo "═══════════════════════════════════════════════"
echo ""

curl -sfL "$SERVER_URL/download/mods/$filename" -o "$dest" || {
    err "Download failed."
    exit 1
}
ok "Saved to: $dest"
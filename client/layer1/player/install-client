#!/bin/bash
#
# install-client — Install TES3MP client via Proton (no Steam needed)
#
# What it does:
#   1. Checks PROTON_PATH in config
#   2. Downloads and extracts TES3MP to $TES3MP_DIR/
#   3. Creates prefix and generates openmw.cfg (replaces openmw-wizard)
#   4. Creates symlink $TES3MP_DIR/openmw-profile → config folder in prefix
#   5. Copies default settings.cfg if missing
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found."
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

if [[ -z "${MORROWIND_PATH:-}" ]]; then
    err "MORROWIND_PATH is not set in config."
    err "Set path to Morrowind installation directory (parent of Data Files)."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
MORROWIND_PATH="${MORROWIND_PATH/#\~/$HOME}"

check_deps curl unzip

echo ""
echo "═══════════════════════════════════════════════"
echo "  Installing TES3MP Client via Proton"
echo "═══════════════════════════════════════════════"
echo ""
echo "  TES3MP directory:  $TES3MP_DIR"
echo "  Morrowind Data:    $MORROWIND_PATH/Data Files"
echo ""

mkdir -p "$TES3MP_DIR"

# ────────────────────────────────────────────────────
# 1. Check Proton
# ────────────────────────────────────────────────────
PROTON_DIR=""
if [[ -n "${PROTON_PATH:-}" ]] && [[ -f "$PROTON_PATH/proton" ]]; then
    PROTON_DIR="$PROTON_PATH"
    info "Proton: $PROTON_DIR"
else
    err ""
    err "Proton is not configured."
    err ""
    err "  1. Find where Proton is installed on your system."
    err "     Common locations:"
    err "      ~/.steam/steam/steamapps/common/Proton 9.0"
    err "      ~/.steam/steam/steamapps/common/Proton Experimental"
    err "      ~/.local/share/Steam/compatibilitytools.d/GE-Proton*"
    err ""
    err "  2. Open config and set PROTON_PATH:"
    err "     → edit-config  →  edit PROTON_PATH = /path/to/proton"
    err ""
    exit 1
fi

# ────────────────────────────────────────────────────
# 2. Download TES3MP
# ────────────────────────────────────────────────────
TES3MP_ZIP="/tmp/tes3mp.zip"
TES3MP_URL="https://github.com/TES3MP/TES3MP/releases/download/tes3mp-0.8.1/tes3mp.Win64.release.0.8.1.zip"

if [[ -f "$TES3MP_DIR/tes3mp.exe" ]]; then
    info "TES3MP already installed, skipping."
else
    info "Downloading TES3MP (this may take a while)..."
    curl -# -L --fail -o "$TES3MP_ZIP" "$TES3MP_URL" 2>&1 || {
        err "Failed to download TES3MP."
        exit 1
    }
    ok "TES3MP downloaded."

    info "Extracting..."
    unzip -qo "$TES3MP_ZIP" -d "$TES3MP_DIR" || {
        err "Failed to extract TES3MP."
        exit 1
    }
    rm -f "$TES3MP_ZIP"
    ok "TES3MP extracted."
fi

# ────────────────────────────────────────────────────
# 3. Create prefix and server directories
# ────────────────────────────────────────────────────
PREFIX_DIR="$TES3MP_DIR/prefix"
mkdir -p "$PREFIX_DIR"

# Create servers directory for isolated server mod folders
SERVERS_DIR="$TES3MP_DIR/servers"
mkdir -p "$SERVERS_DIR"
info "Servers directory created: $SERVERS_DIR"

# ────────────────────────────────────────────────────
# 4. Create Data Files symlink for Proton/Wine
# ────────────────────────────────────────────────────
if [[ -d "$MORROWIND_PATH/Data Files" ]]; then
    # Symlink in prefix drive_c (so OpenMW sees C:\Morrowind\Data Files)
    MORROWIND_LINK="$PREFIX_DIR/pfx/drive_c/Morrowind"
    mkdir -p "$(dirname "$MORROWIND_LINK")"
    ln -sfn "$MORROWIND_PATH" "$MORROWIND_LINK"
    info "Symlink created: $MORROWIND_LINK → $MORROWIND_PATH"
fi

# ────────────────────────────────────────────────────
# 5. Generate openmw.cfg (instead of openmw-wizard)
# ────────────────────────────────────────────────────
CONFIG_DIR="$PREFIX_DIR/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW"
mkdir -p "$CONFIG_DIR"

OPENMW_CFG="$CONFIG_DIR/openmw.cfg"
DATA_BASENAME="$(basename "$MORROWIND_PATH")"  # "Morrowind"

info "Generating openmw.cfg..."

cat > "$OPENMW_CFG" << CFGEOF
fallback-archive=Morrowind.bsa
fallback-archive=Tribunal.bsa
fallback-archive=Bloodmoon.bsa
data="C:\\${DATA_BASENAME}\\Data Files"
content=Morrowind.esm
content=Tribunal.esm
content=Bloodmoon.esm
CFGEOF

ok "openmw.cfg generated."

# ────────────────────────────────────────────────────
# 6. Create symlink to config folder
# ────────────────────────────────────────────────────
SYMLINK_PATH="$TES3MP_DIR/openmw-profile"

if [[ -d "$CONFIG_DIR" ]]; then
    ln -sfn "$CONFIG_DIR" "$SYMLINK_PATH"
    ok "Symlink created: $SYMLINK_PATH → $CONFIG_DIR"

    # Create default settings.cfg if it doesn't exist
    SETTINGS_CFG="$CONFIG_DIR/settings.cfg"
    if [[ ! -f "$SETTINGS_CFG" ]]; then
        EXAMPLE="$SCRIPT_DIR/lib/settings.cfg.example"
        if [[ -f "$EXAMPLE" ]]; then
            cp "$EXAMPLE" "$SETTINGS_CFG"
            ok "Default settings.cfg created."
        else
            warn "Example not found: $EXAMPLE"
        fi
    fi
else
    warn "Config directory not found (wizard may not have created it yet):"
    warn "  $CONFIG_DIR"
    warn "Run the client once to generate config files."
fi

echo ""
echo "  Client installed successfully."
echo ""
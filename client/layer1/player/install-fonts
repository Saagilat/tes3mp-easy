#!/bin/bash
#
# install-fonts — Install fonts for OpenMW/TES3MP
# Layer 1: non-interactive. Takes option number as argument.
# Usage: install-fonts <option>
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found."; exit 1; }

[[ -z "${TES3MP_DIR:-}" ]] && { err "TES3MP_DIR is not set in config."; exit 1; }
TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"

FONT_OPT="${1:-}"
[[ -z "$FONT_OPT" ]] && { err "Usage: install-fonts <option (1-12)>"; exit 1; }

SETTINGS_CFG="$TES3MP_DIR/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/settings.cfg"
OPENMW_CFG="$TES3MP_DIR/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/openmw.cfg"
FONTS_DIR="$TES3MP_DIR/openmw-profile"
[[ ! -d "$FONTS_DIR" ]] && FONTS_DIR="$TES3MP_DIR/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW"

GF_RAW="https://raw.githubusercontent.com/google/fonts/main/ofl"

FONTS_SUBDIR="$FONTS_DIR/Fonts"
mkdir -p "$FONTS_SUBDIR"

install_3_fonts() {
    local main_url="$1"   main_file="$2"
    local serif_url="$3"  serif_file="$4"
    local mono_url="$5"   mono_file="$6"

    local OK=true

    echo ""
    info "Downloading $main_file ..."
    curl -fsSL -o "$FONTS_SUBDIR/$main_file" "$main_url" || { err "  Failed: $main_file"; OK=false; }

    info "Downloading $serif_file ..."
    curl -fsSL -o "$FONTS_SUBDIR/$serif_file" "$serif_url" || { err "  Failed: $serif_file"; OK=false; }

    info "Downloading $mono_file ..."
    curl -fsSL -o "$FONTS_SUBDIR/$mono_file" "$mono_url" || { err "  Failed: $mono_file"; OK=false; }

    if [[ "$OK" == true ]]; then
        ok "Fonts downloaded to $FONTS_SUBDIR"

        local main_name="${main_file%.ttf}"
        local serif_name="${serif_file%.ttf}"
        local mono_name="${mono_file%.ttf}"

        cat > "$FONTS_SUBDIR/openmw_font.xml" << XML
<?xml version="1.0" encoding="UTF-8"?>
<MyGUI type="Resource" version="1.1">
    <Resource type="ResourceTrueTypeFont" name="Magic Cards">
        <Property key="Source" value="$main_file"/>
        <Property key="Antialias" value="false"/>
        <Property key="TabWidth" value="8"/>
        <Property key="OffsetHeight" value="0"/>
        <Codes>
            <Code range="33 126"/>
            <Code range="161 255"/>
            <Code range="1025"/>
            <Code range="1040 1103"/>
            <Code range="1105"/>
        </Codes>
    </Resource>
    <Resource type="ResourceTrueTypeFont" name="Daedric">
        <Property key="Source" value="$serif_file"/>
        <Property key="Antialias" value="false"/>
        <Property key="TabWidth" value="8"/>
        <Property key="OffsetHeight" value="0"/>
        <Codes>
            <Code range="32 126"/>
        </Codes>
    </Resource>
    <Resource type="ResourceTrueTypeFont" name="MonoFont">
        <Property key="Source" value="$mono_file"/>
        <Property key="Antialias" value="false"/>
        <Property key="TabWidth" value="8"/>
        <Property key="OffsetHeight" value="0"/>
        <Codes>
            <Code range="33 126"/>
            <Code range="192 382"/>
            <Code range="1025 1105"/>
        </Codes>
    </Resource>
</MyGUI>
XML
        ok "openmw_font.xml created in Fonts/ subfolder"

        if [[ -f "$OPENMW_CFG" ]]; then
            echo ""
            info "Updating openmw.cfg..."
            for idx in 0 1 2; do
                case "$idx" in
                    0) name="$main_name" ;;
                    1) name="$serif_name" ;;
                    2) name="$mono_name" ;;
                esac
                key="Fonts_Font_$idx"
                if grep -q "^fallback=${key}," "$OPENMW_CFG" 2>/dev/null || grep -q "^fallback=${key}$" "$OPENMW_CFG" 2>/dev/null; then
                    sed -i "s|^fallback=${key},.*|fallback=${key},${name}|" "$OPENMW_CFG"
                    sed -i "s|^fallback=${key}$|fallback=${key},${name}|" "$OPENMW_CFG"
                else
                    echo "fallback=${key},${name}" >> "$OPENMW_CFG"
                fi
                ok "  ${key} → $name"
            done
        fi
    fi
}

echo ""
echo "═══════════════════════════════════════════════"
echo "  Install Fonts"
echo "═══════════════════════════════════════════════"
echo ""

case "${FONT_OPT}" in
    1) install_3_fonts \
            "$GF_RAW/ibmplexsans/IBMPlexSans%5Bwdth%2Cwght%5D.ttf" "IBMPlexSans.ttf" \
            "$GF_RAW/ibmplexserif/IBMPlexSerif-Regular.ttf" "IBMPlexSerif.ttf" \
            "$GF_RAW/ibmplexmono/IBMPlexMono-Regular.ttf" "IBMPlexMono.ttf" ;;
    2) install_3_fonts \
            "$GF_RAW/notosans/NotoSans%5Bwdth,wght%5D.ttf" "NotoSans.ttf" \
            "$GF_RAW/notoserif/NotoSerif%5Bwdth,wght%5D.ttf" "NotoSerif.ttf" \
            "$GF_RAW/robotomono/RobotoMono%5Bwght%5D.ttf" "RobotoMono.ttf" ;;
    3) install_3_fonts \
            "$GF_RAW/roboto/Roboto%5Bwdth,wght%5D.ttf" "Roboto.ttf" \
            "$GF_RAW/lora/Lora%5Bwght%5D.ttf" "Lora.ttf" \
            "$GF_RAW/cousine/Cousine-Regular.ttf" "Cousine.ttf" ;;
    4) install_3_fonts \
            "$GF_RAW/opensans/OpenSans%5Bwdth,wght%5D.ttf" "OpenSans.ttf" \
            "$GF_RAW/notoserif/NotoSerif%5Bwdth,wght%5D.ttf" "NotoSerif.ttf" \
            "$GF_RAW/sourcecodepro/SourceCodePro%5Bwght%5D.ttf" "SourceCodePro.ttf" ;;
    5) install_3_fonts \
            "$GF_RAW/montserrat/Montserrat%5Bwght%5D.ttf" "Montserrat.ttf" \
            "$GF_RAW/playfairdisplay/PlayfairDisplay%5Bwght%5D.ttf" "PlayfairDisplay.ttf" \
            "$GF_RAW/spacemono/SpaceMono-Regular.ttf" "SpaceMono.ttf" ;;
    6) install_3_fonts \
            "$GF_RAW/firasans/FiraSans-Regular.ttf" "FiraSans.ttf" \
            "$GF_RAW/lora/Lora%5Bwght%5D.ttf" "Lora.ttf" \
            "$GF_RAW/firamono/FiraMono-Regular.ttf" "FiraMono.ttf" ;;
    7) install_3_fonts \
            "$GF_RAW/arimo/Arimo%5Bwght%5D.ttf" "Arimo.ttf" \
            "$GF_RAW/notoserif/NotoSerif%5Bwdth,wght%5D.ttf" "NotoSerif.ttf" \
            "$GF_RAW/redhatmono/RedHatMono%5Bwght%5D.ttf" "RedHatMono.ttf" ;;
    8) install_3_fonts \
            "$GF_RAW/sourcesans3/SourceSans3%5Bwght%5D.ttf" "SourceSans3.ttf" \
            "$GF_RAW/playfairdisplay/PlayfairDisplay%5Bwght%5D.ttf" "PlayfairDisplay.ttf" \
            "$GF_RAW/robotomono/RobotoMono%5Bwght%5D.ttf" "RobotoMono.ttf" ;;
    9) install_3_fonts \
            "$GF_RAW/notosans/NotoSans%5Bwdth,wght%5D.ttf" "NotoSans.ttf" \
            "$GF_RAW/lora/Lora%5Bwght%5D.ttf" "Lora.ttf" \
            "$GF_RAW/cousine/Cousine-Regular.ttf" "Cousine.ttf" ;;
    10) install_3_fonts \
            "$GF_RAW/roboto/Roboto%5Bwdth,wght%5D.ttf" "Roboto.ttf" \
            "$GF_RAW/playfairdisplay/PlayfairDisplay%5Bwght%5D.ttf" "PlayfairDisplay.ttf" \
            "$GF_RAW/sourcecodepro/SourceCodePro%5Bwght%5D.ttf" "SourceCodePro.ttf" ;;
    11) install_3_fonts \
            "$GF_RAW/opensans/OpenSans%5Bwdth,wght%5D.ttf" "OpenSans.ttf" \
            "$GF_RAW/notoserif/NotoSerif%5Bwdth,wght%5D.ttf" "NotoSerif.ttf" \
            "$GF_RAW/spacemono/SpaceMono-Regular.ttf" "SpaceMono.ttf" ;;
    12)
        echo ""
        echo "  Download from Nexus Mods:"
        echo "    https://www.nexusmods.com/morrowind/mods/46854"
        echo ""
        echo "  Extract the archive and copy the 'Fonts/' folder into:"
        echo "    $FONTS_DIR/"
        echo ""
        ;;
esac
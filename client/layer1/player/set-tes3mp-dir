#!/bin/bash
#
# set-tes3mp-dir — Save TES3MP_DIR to config
# Layer 1: non-interactive.
# Usage: set-tes3mp-dir <path>
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.ini"

path="${1:-}"
[[ -z "$path" ]] && { err "Usage: set-tes3mp-dir <path>"; exit 1; }

if grep -q "^TES3MP_DIR[[:space:]]*=" "$CONFIG" 2>/dev/null; then
    sed -i "s|^TES3MP_DIR[[:space:]]*=.*|TES3MP_DIR = ${path}|" "$CONFIG"
else
    echo "TES3MP_DIR = ${path}" >> "$CONFIG"
fi
ok "TES3MP_DIR set to: ${path}"
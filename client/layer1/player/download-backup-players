#!/bin/bash
#
# download-backup-players — Download a player backup archive from TES3MP server
# Usage: download-backup-players <filename> [destination]
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found."
    err "Run 'edit-config' to set it up."
    exit 1
}

[[ -z "${BACKUP_DIR:-}" ]] && { err "BACKUP_DIR is not set in config"; exit 1; }

SERVER_URL=$(_get_server_url) || {
    err "Could not determine server URL."
    err "Set TES3MP_DIR in config or check tes3mp-client-default.cfg."
    exit 1
}

SERVER_ID=$(_get_server_id "$SERVER_URL")
[[ -z "$SERVER_ID" ]] && SERVER_ID="default"

filename="${1:-}"
[[ -z "$filename" ]] && { err "Usage: download-backup-players <filename> [destination]"; exit 1; }
dest="${2:-$BACKUP_DIR/$SERVER_ID/players/$filename}"

mkdir -p "$(dirname "$dest")"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Downloading player backup: $filename"
echo "═══════════════════════════════════════════════"
echo ""

curl -sfL "$SERVER_URL/download/players/$filename" -o "$dest" || {
    err "Download failed."
    exit 1
}
ok "Saved to: $dest"
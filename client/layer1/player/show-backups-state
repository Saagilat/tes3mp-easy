#!/bin/bash
#
# show-backups-state — List state backup archives from TES3MP server via HTTP
# Layer 1: outputs JSON, no formatting.
# Usage: show-backups-state
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found."; exit 1; }

SERVER_URL=$(_get_server_url) || { err "Could not determine server URL."; exit 1; }

curl -sf "$SERVER_URL/list-backups/state" || exit 1
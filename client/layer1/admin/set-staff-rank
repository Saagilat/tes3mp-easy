#!/bin/bash
#
# set-staff-rank — Set staff rank for a player on the server via SSH
# Layer 1: non-interactive. Takes player name and rank.
# Usage: set-staff-rank <player_name> <rank>
#   rank: 0=none, 1=moderator, 2=admin, 3=owner
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

player_name="${1:-}"
rank="${2:-}"

[[ -z "$player_name" ]] && { err "Usage: set-staff-rank <player_name> <rank>"; exit 1; }
[[ -z "$rank" ]] && { err "Usage: set-staff-rank <player_name> <rank>"; exit 1; }
[[ "$rank" != "0" && "$rank" != "1" && "$rank" != "2" && "$rank" != "3" ]] && {
    err "Rank must be 0 (none), 1 (moderator), 2 (admin), or 3 (owner)"
    exit 1
}

info "Setting staff rank for $player_name to $rank on $SSH_HOST..."
ssh "$SSH_HOST" "bash /tes3mp-easy/scripts/set-staff-rank.sh '$player_name' '$rank'" 2>/dev/null || {
    err "Failed to set staff rank on server"
    exit 1
}
ok "Staff rank for $player_name set to $rank on $SSH_HOST"
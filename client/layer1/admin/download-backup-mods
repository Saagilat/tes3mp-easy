#!/bin/bash
#
# admin-backup-mods — Download a mod backup archive from remote VPS
# Usage: admin-backup-mods <filename> [destination]
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }
[[ -z "${BACKUP_DIR:-}" ]] && { err "BACKUP_DIR is not set in config"; exit 1; }

SERVER_ID=$(_get_server_id "$SSH_HOST")
[[ -z "$SERVER_ID" ]] && SERVER_ID="default"

filename="${1:-}"
[[ -z "$filename" ]] && { err "Usage: admin-backup-mods <filename> [destination]"; exit 1; }
dest="${2:-$BACKUP_DIR/$SERVER_ID/mods/$filename}"

mkdir -p "$(dirname "$dest")"
scp "$SSH_HOST:/tes3mp-easy/backups/mods/$filename" "$dest" || {
    err "Failed to download $filename"
    exit 1
}
ok "Saved to: $dest"
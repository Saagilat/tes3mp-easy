#!/bin/bash
#
# set-backup-interval — Change backup interval on VPS
# Usage: set-backup-interval <seconds>
#
# Updates BACKUP_INTERVAL in docker-compose.yml and recreates export container.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

interval="${1:-}"
[[ -z "$interval" ]] && { err "Usage: set-backup-interval <seconds>"; exit 1; }
[[ "$interval" =~ ^[0-9]+$ ]] || { err "Interval must be a positive number"; exit 1; }

ssh "$SSH_HOST" "sed -i 's/BACKUP_INTERVAL:-\\([0-9]*\\)}/BACKUP_INTERVAL:-$interval}/' /tes3mp-easy/docker-compose.yml && cd /tes3mp-easy && docker compose up -d export" || { err "Failed to update interval"; exit 1; }
ok "Backup interval set to $interval seconds"

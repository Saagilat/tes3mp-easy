#!/bin/bash
#
# download-backup-state — Download a state backup archive from VPS via SCP
# Usage: download-backup-state                # create fresh backup and download
#        download-backup-state <filename>     # download existing backup
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found."; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }
[[ -z "${BACKUP_DIR:-}" ]] && { err "BACKUP_DIR is not set in config"; exit 1; }

SERVER_ID=$(_get_server_id "$SSH_HOST")
[[ -z "$SERVER_ID" ]] && { err "Could not determine server ID from SSH_HOST"; exit 1; }

filename="${1:-}"

if [[ -z "$filename" ]]; then
    # No filename → create fresh backup on server
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  Creating fresh state backup..."
    echo "═══════════════════════════════════════════════"
    echo ""

    timestamp=$(ssh "$SSH_HOST" "date +%F_%H-%M-%S" 2>/dev/null || date +%F_%H-%M-%S)
    archive_name="export-${timestamp}-state.tar.gz"

    # Run package_state on server via SSH
    ssh "$SSH_HOST" "cd /tes3mp-easy && source scripts/package.sh && \
        export PLAYER_DIR=/tes3mp-easy/players && \
        export WORLD_CELL_DIR=/tes3mp-easy/world/cell && \
        export WORLD_WORLD_DIR=/tes3mp-easy/world/world && \
        export WORLD_MAP_DIR=/tes3mp-easy/world/map && \
        export WORLD_RECORDSTORE_DIR=/tes3mp-easy/world/recordstore && \
        export WORLD_CUSTOM_DIR=/tes3mp-easy/world/custom && \
        export BACKUPS_DIR=/tes3mp-easy/backups && \
        package_state /tes3mp-easy/backups/state/$archive_name" || {
        err "Failed to create backup on server."
        exit 1
    }

    info "Fresh backup created: $archive_name"
    filename="$archive_name"
    dest="$BACKUP_DIR/$SERVER_ID/state/$filename"
else
    dest="${2:-$BACKUP_DIR/$SERVER_ID/state/$filename}"
fi

mkdir -p "$(dirname "$dest")"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Downloading state backup: $filename"
echo "═══════════════════════════════════════════════"
echo ""

scp "$SSH_HOST:/tes3mp-easy/backups/state/$filename" "$dest" || { err "Download failed."; exit 1; }
ok "Saved to: $dest"
#!/bin/bash
#
# check-server-status — Check if server container is running
# Layer 1: non-interactive. Outputs "Running", "Stopped", or empty.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && { echo ""; exit 0; }

state=$(ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose ps --format '{{.State}}' 2>/dev/null | head -1" 2>/dev/null || echo "")
if [[ "$state" == "running" ]]; then
    echo "Running"
else
    echo "Stopped"
fi
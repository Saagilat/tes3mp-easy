#!/bin/bash
#
# admin-export-mods — Package and upload mods+scripts to TES3MP server
#
# Layer 1: non-interactive. Creates mods.tar.gz from EXPORT_DIR/mods/
# and uploads via SSH to the server.
#
# Archive structure:
#   mods.tar.gz
#   ├── plugins/
#   │   └── mod1.esp
#   ├── requiredDataFiles.json
#   └── scripts/
#       └── test.lua
#
# Usage: bash export-mods
#
# Requires: SSH_HOST, EXPORT_DIR (set in config)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }
[[ -z "${EXPORT_DIR:-}" || ! -d "${EXPORT_DIR:-}" ]] && { err "EXPORT_DIR is not set or does not exist"; exit 1; }

# Derive server ID from SSH_HOST
SERVER_ID=$(_get_server_id "$SSH_HOST")
[[ -z "$SERVER_ID" ]] && { err "Could not determine server ID from SSH_HOST"; exit 1; }

plugins_dir="$EXPORT_DIR/$SERVER_ID/mods/plugins"
scripts_dir="$EXPORT_DIR/$SERVER_ID/mods/scripts"
[[ ! -d "$plugins_dir" ]] && { err "plugins/ not found in $EXPORT_DIR/$SERVER_ID/mods"; exit 1; }
[[ ! -d "$scripts_dir" ]] && { err "scripts/ not found in $EXPORT_DIR/$SERVER_ID/mods"; exit 1; }

check_deps rhash tar ssh scp jq

echo ""
echo "═══════════════════════════════════════════════"
echo "  TES3MP Export Mods"
echo "═══════════════════════════════════════════════"
echo ""

# Step 1: Check requiredDataFiles.json
echo "[1/5] Checking requiredDataFiles.json..."
req_json="$plugins_dir/requiredDataFiles.json"
[[ ! -f "$req_json" ]] && { err "requiredDataFiles.json not found — run admin-generate-data first"; exit 1; }
ok "Found requiredDataFiles.json"

# Step 2: CRC32 check (supports array format: [{file.esp: [...]}, ...])
echo "[2/5] Validating CRC32..."
ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")
validation_failed=0

while IFS= read -r filename; do
    [[ -z "$filename" ]] && continue
    skip=0
    for orig in "${ORIGINAL_FILES[@]}"; do
        [[ "${filename,,}" == "${orig,,}" ]] && { skip=1; break; }
    done
    [[ "$skip" -eq 1 ]] && continue

    filepath="$plugins_dir/$filename"
    [[ ! -f "$filepath" ]] && { err "Plugin \"$filename\" not found"; validation_failed=1; continue; }

    # Get expected CRC from JSON: [{file: ["0x..."]}, ...]
    expected_crc=$(jq -r --arg f "$filename" '.[] | to_entries[] | select(.key == $f) | .value[0] // empty' "$req_json")
    expected_crc="${expected_crc#0x}"
    expected_crc="${expected_crc^^}"

    if [[ -n "$expected_crc" ]]; then
        actual_crc=$(rhash --crc32 --simple "$filepath" 2>/dev/null | cut -d' ' -f1 | tr '[:lower:]' '[:upper:]')
        if [[ "$actual_crc" != "$expected_crc" ]]; then
            err "CRC32 mismatch for \"$filename\": expected 0x$expected_crc, got 0x$actual_crc"
            validation_failed=1
        fi
    fi
done < <(jq -r '.[] | keys[]' "$req_json")

[[ "$validation_failed" -ne 0 ]] && { err "Validation failed — aborting"; exit 1; }
ok "All plugins pass CRC32 check"

# Step 3: Package
echo "[3/5] Packaging..."
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
output_archive="$tmp_dir/mods.tar.gz"

# Stage: plugins + requiredDataFiles.json
mkdir -p "$tmp_dir/plugins"
for f in "$plugins_dir"/*; do
    [ -f "$f" ] || continue
    basename=$(basename "$f")
    # Skip requiredDataFiles.json — placed separately
    [ "$basename" = "requiredDataFiles.json" ] && continue
    # Skip original Morrowind files
    skip=0
    for orig in "${ORIGINAL_FILES[@]}"; do
        if [ "${basename,,}" = "${orig,,}" ]; then
            skip=1
            break
        fi
    done
    [ "$skip" -eq 1 ] && continue
    cp "$f" "$tmp_dir/plugins/"
done
    cp "$req_json" "$tmp_dir/plugins/requiredDataFiles.json"

# Stage: scripts
mkdir -p "$tmp_dir/scripts"
for f in "$scripts_dir"/*; do
    [ -f "$f" ] || continue
    cp "$f" "$tmp_dir/scripts/"
done

    (cd "$tmp_dir" && tar czf "$output_archive" -- * )
[[ ! -f "$output_archive" ]] && { err "Failed to create archive"; exit 1; }
ok "Archive created"

# Step 4: Transfer
echo "[4/5] Transferring to server..."
ssh "$SSH_HOST" "mkdir -p /tes3mp-easy/import-mods" || { err "Failed to create remote dir"; exit 1; }
scp "$output_archive" "$SSH_HOST":/tes3mp-easy/import-mods/mods.tar.gz || { err "Failed to transfer"; exit 1; }
ok "Archive transferred"

# Step 5: Import
echo "[5/5] Running import_mods.sh..."
ssh "$SSH_HOST" "cd /tes3mp-easy && bash scripts/import_mods.sh" || { err "import_mods.sh failed"; exit 1; }
ok "Server import completed"
rm -f "$output_archive"
echo ""
echo "Export complete!"
#!/bin/bash
#
# write-config-lua — Apply sed script to config.lua on server via SSH
# Layer 1: non-interactive. Takes path to a sed script file as argument.
# Usage: write-config-lua <sed_script_path>
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

sed_script="${1:-}"
[[ -z "$sed_script" || ! -f "$sed_script" ]] && { err "Usage: write-config-lua <sed_script_path>"; exit 1; }

remote_path="/tmp/tes3mp-write-config-$$.sed"
scp "$sed_script" "$SSH_HOST:$remote_path" >/dev/null 2>&1 || { err "Failed to upload sed script"; exit 1; }
ssh "$SSH_HOST" "sed -i -f $remote_path /tes3mp-easy/configs/config.lua && rm -f $remote_path" 2>/dev/null || {
    ssh "$SSH_HOST" "rm -f $remote_path" 2>/dev/null || true
    err "Failed to apply config changes"
    exit 1
}
ok "Server configuration updated."
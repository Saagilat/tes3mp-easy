#!/bin/bash
#
# set-export-dir — Save EXPORT_DIR to config and create if needed
# Layer 1: non-interactive.
# Usage: set-export-dir <path>
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.ini"

path="${1:-}"
[[ -z "$path" ]] && { err "Usage: set-export-dir <path>"; exit 1; }

resolved="${path/#\~/$HOME}"

if grep -q "^EXPORT_DIR[[:space:]]*=" "$CONFIG" 2>/dev/null; then
    sed -i "s|^EXPORT_DIR[[:space:]]*=.*|EXPORT_DIR = ${path}|" "$CONFIG"
else
    echo "EXPORT_DIR = ${path}" >> "$CONFIG"
fi

if [[ -d "$resolved" ]]; then
    ok "Directory exists: ${resolved}"
else
    if mkdir -p "$resolved" 2>/dev/null; then
        ok "Created: ${resolved}"
    else
        warn "Could not create: ${resolved}"
    fi
fi
ok "EXPORT_DIR set to: ${path}"
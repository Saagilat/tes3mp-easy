#!/bin/bash
#
# admin-generate-data — Generate requiredDataFiles.json for mods
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${EXPORT_DIR:-}" ]] && { err "EXPORT_DIR is not set"; exit 1; }

plugin_dir="${EXPORT_DIR}/mods/plugins"
[[ ! -d "$plugin_dir" ]] && { err "Directory not found: $plugin_dir"; exit 1; }

check_deps rhash
ORIGINAL_FILES=("Morrowind.esm" "Tribunal.esm" "Bloodmoon.esm")

echo ""
echo "═══════════════════════════════════════════════"
echo "  Generating requiredDataFiles.json"
echo "═══════════════════════════════════════════════"

output_file="$plugin_dir/requiredDataFiles.json"

# Generate array format as expected by TES3MP server
# e.g. [ { "Morrowind.esm": [] }, { "file.omwaddon": ["0xABCD1234"] } ]
{
    echo "["
    first=true

    for orig in "${ORIGINAL_FILES[@]}"; do
        skip=0
        for file in "$plugin_dir"/*; do
            [ -f "$file" ] || continue
            base=$(basename "$file")
            [ "${base,,}" != "${orig,,}" ] && continue
            skip=1
            break
        done
        if [[ "$first" == true ]]; then first=false; else echo ","; fi
        echo -n "  { \"$orig\": [] }"
        echo "  [OK] $orig (no CRC)"
    done

    while IFS= read -r -d '' file; do
        filename=$(basename "$file")
        crc32=$(rhash --crc32 --simple "$file" 2>/dev/null | cut -d' ' -f1 | tr '[:lower:]' '[:upper:]')
        if [[ "$first" == true ]]; then first=false; else echo ","; fi
        if [[ -n "$crc32" ]]; then
            echo -n "  { \"$filename\": [\"0x$crc32\"] }"
            echo "  [OK] $filename → CRC32: 0x$crc32"
        else
            echo -n "  { \"$filename\": [] }"
            echo "  [OK] $filename (no CRC)"
        fi
    done < <(find "$plugin_dir" -maxdepth 1 -type f \( -iname "*.esp" -o -iname "*.esm" -o -iname "*.omwaddon" \) -print0 | sort -z)

    echo ""
    echo "]"
} > "$output_file"

echo ""
ok "requiredDataFiles.json generated at: $output_file"
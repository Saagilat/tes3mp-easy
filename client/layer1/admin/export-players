#!/bin/bash
#
# admin-export-players — Package and upload player data to TES3MP server
#
# Layer 1: non-interactive. Creates players.tar.gz from EXPORT_DIR/players/
# and uploads via SSH to the server.
#
# Usage: bash export-players
#
# Requires: SSH_HOST, EXPORT_DIR (set in config)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }
[[ -z "${EXPORT_DIR:-}" || ! -d "${EXPORT_DIR:-}" ]] && { err "EXPORT_DIR is not set or does not exist"; exit 1; }

SERVER_ID=$(_get_server_id "$SSH_HOST")
[[ -z "$SERVER_ID" ]] && { err "Could not determine server ID from SSH_HOST"; exit 1; }

player_dir="$EXPORT_DIR/$SERVER_ID/players"
[[ ! -d "$player_dir" ]] && { err "players/ not found in $EXPORT_DIR/$SERVER_ID"; exit 1; }

check_deps tar ssh scp

echo ""
echo "═══════════════════════════════════════════════"
echo "  TES3MP Export Players"
echo "═══════════════════════════════════════════════"

echo "[1/4] Packaging..."
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT
output_archive="$tmp_dir/players.tar.gz"

# Stage: copy files into tmp_dir/players/ then pack
mkdir -p "$tmp_dir/players"
cp -r "$player_dir"/* "$tmp_dir/players/" 2>/dev/null || true

    (cd "$tmp_dir" && tar czf "$output_archive" -- * )
[[ ! -f "$output_archive" ]] && { err "Failed to create archive"; exit 1; }
ok "Archive created"

echo "[2/4] Transferring..."
ssh "$SSH_HOST" "mkdir -p /tes3mp-easy/import-players" || { err "Failed to create remote dir"; exit 1; }
scp "$output_archive" "$SSH_HOST":/tes3mp-easy/import-players/players.tar.gz || { err "Failed to transfer"; exit 1; }
ok "Archive transferred"

echo "[3/4] Running import_players.sh..."
ssh "$SSH_HOST" "cd /tes3mp-easy && bash scripts/import_players.sh" || { err "import_players.sh failed"; exit 1; }
ok "Server import completed"

echo "[4/4] Cleaning up..."
rm -f "$output_archive"
echo "Export complete!"
#!/bin/bash
#
# read-config-lua — Read config.lua settings from server via SSH
# Layer 1: non-interactive. Outputs key=value lines for all config.* settings.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

ssh "$SSH_HOST" "grep '^config\.' /tes3mp-easy/configs/config.lua" 2>/dev/null || exit 1
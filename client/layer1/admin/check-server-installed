#!/bin/bash
#
# check-server-installed — Check if server is installed on VPS
# Layer 1: non-interactive. Exits 0 if installed, 1 if not.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && exit 1

if ssh "$SSH_HOST" "test -f /tes3mp-easy/docker-compose.yml" 2>/dev/null; then
    exit 0
fi
exit 1
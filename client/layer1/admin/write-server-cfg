#!/bin/bash
#
# write-server-cfg — Set key=value in tes3mp-server-default.cfg on server via SSH
# Layer 1: non-interactive.
# Usage: write-server-cfg <key> <value>
#
# Output: nothing on success, error message on stderr on failure.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

key="${1:-}"
value="${2:-}"

[[ -z "$key" ]] && { err "Usage: write-server-cfg <key> <value>"; exit 1; }

remote_file="/tes3mp-easy/configs/tes3mp-server-default.cfg"

# Escape / and & for sed replacement
escaped_key=$(printf '%s\n' "$key" | sed 's/[\/&]/\\&/g')
escaped_val=$(printf '%s\n' "$value" | sed 's/[\/&]/\\&/g')

# Remove existing line (case-insensitive), then append at end
ssh "$SSH_HOST" "
  sed -i '/^${escaped_key}[[:space:]]*=/Id' '$remote_file'
  printf '%s = %s\n' '$key' '$value' >> '$remote_file'
  touch /tes3mp-easy/needs_restart.flag
" 2>/dev/null || { err "Failed to update $remote_file on $SSH_HOST"; exit 1; }

ok "Server config updated on $SSH_HOST"
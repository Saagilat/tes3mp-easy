#!/bin/bash
#
# show-backups-state — List state backup archives on remote VPS via SSH
# Layer 1: outputs JSON, no formatting.
# Usage: show-backups-state
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && exit 1

retry ssh "$SSH_HOST" "BACKUPS_DIR=/tes3mp-easy/backups bash /tes3mp-easy/scripts/list-backups.sh state" 2>/dev/null || exit 1
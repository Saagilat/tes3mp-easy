#!/bin/bash
#
# edit-config-record — Set a key=value in tes3mp-easy JSON config
# Layer 1: non-interactive, shared (admin + player).
# Usage: edit-config-record <key> <value>
#
# Examples:
#   edit-config-record SSH_HOST myserver
#   edit-config-record EDITOR nano
#   edit-config-record MORROWIND_PATH /home/user/Morrowind
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

key="${1:-}"
value="${2:-}"

[[ -z "$key" ]] && { err "Usage: edit-config-record <key> <value>"; exit 1; }

if write_config "$key" "$value"; then
    ok "${key} set to: ${value}"
else
    err "Failed to set ${key}"
    exit 1
fi
#!/bin/bash
#
# run-openmw-cs — Launch OpenMW-CS via Proton (no Steam needed)
#
# Usage:
#   run-openmw-cs
#
# Shared between admin and player menus.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-player.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

if [[ -z "${PROTON_PATH:-}" ]]; then
    err "PROTON_PATH is not set in config."
    err "Open edit-config and set PROTON_PATH to your Proton folder."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
PROTON_PATH="${PROTON_PATH/#\~/$HOME}"

PROTON_DIR="$PROTON_PATH"
PREFIX_DIR="$TES3MP_DIR/prefix"
OPENMW_CS_EXE="$TES3MP_DIR/openmw-cs.exe"

if [[ ! -f "$PROTON_DIR/proton" ]]; then
    err "Proton not found at: $PROTON_DIR"
    err "Update PROTON_PATH in edit-config."
    exit 1
fi

if [[ ! -f "$OPENMW_CS_EXE" ]]; then
    err "OpenMW-CS not found at: $OPENMW_CS_EXE"
    err "Make sure openmw-cs.exe is present in your TES3MP directory."
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Launching OpenMW-CS"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Proton:      $PROTON_DIR"
echo "  Prefix:      $PREFIX_DIR"
echo "  OpenMW-CS:   $OPENMW_CS_EXE"
echo ""

export SteamAppId=22320
export SteamGameId=22320
export STEAM_COMPAT_DATA_PATH="$PREFIX_DIR"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$HOME/.steam/steam"

"$PROTON_DIR/proton" run "$OPENMW_CS_EXE" || {
    err "OpenMW-CS exited with non-zero status."
    exit 1
}

ok "OpenMW-CS closed."
#!/bin/bash
#
# set-editor — Save EDITOR to config
# Layer 1: non-interactive, shared (admin + player).
# Usage: set-editor <editor>
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.ini"

editor="${1:-}"
[[ -z "$editor" ]] && { err "Usage: set-editor <editor>"; exit 1; }

if grep -q "^EDITOR[[:space:]]*=" "$CONFIG" 2>/dev/null; then
    sed -i "s|^EDITOR[[:space:]]*=.*|EDITOR = ${editor}|" "$CONFIG"
else
    echo "EDITOR = ${editor}" >> "$CONFIG"
fi
ok "EDITOR set to: ${editor}"
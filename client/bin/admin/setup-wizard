require_ssh() {
    if [[ -z "${SSH_HOST:-}" ]]; then
        err "SSH_HOST is not set."
        return 1
    fi
    if ! ssh -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" "echo ok" 2>/dev/null; then
        err "Cannot connect to ${SSH_HOST}. Check your SSH config."
        return 1
    fi
    return 0
}

# Read entire config.lua into memory (array), one SSH call
lua_load() {
    local line key val
    _LUA_CONF=()
    while IFS='=' read -r key val; do
        key="${key%% }"
        key="${key## }"
        [[ -z "$key" || "$key" == '--'* ]] && continue
        # Strip quotes from value
        val="${val# \"}"
        val="${val%\"}"
        val="${val# }"
        val="${val% }"
        _LUA_CONF["$key"]="$val"
    done < <(ssh "$SSH_HOST" "grep '^config\.' /tes3mp-easy/configs/config.lua" 2>/dev/null || true)
}

# Apply all changes to config.lua in one SSH call
lua_save() {
    if [[ ${#_LUA_CHANGED[@]} -eq 0 ]]; then
        _LUA_CHANGED=()
        _LUA_TYPE=()
        return
    fi

    local script_path="/tmp/tes3mp-wizard-$$.sed"
    local line key val

    # Generate sed commands — each line: s|old|new|
    > /tmp/tes3mp-wizard-local.sed
    for key in "${!_LUA_CHANGED[@]}"; do
        val="${_LUA_CONF[$key]}"
        local escaped_key
        escaped_key=$(printf '%s\n' "$key" | sed 's/[\/&]/\\&/g')
        case "${_LUA_TYPE[$key]}" in
            bool|number)
                echo "s/^${escaped_key}[[:space:]]*=.*/${key} = ${val}/" >> /tmp/tes3mp-wizard-local.sed
                ;;
            password)
                local escaped_val
                escaped_val=$(printf '%s\n' "$val" | sed 's/[\/&"]/\\&/g')
                echo "s/^${escaped_key}[[:space:]]*=.*/${key} = \"${escaped_val}\"/" >> /tmp/tes3mp-wizard-local.sed
                ;;
            string|*)
                local escaped_val
                escaped_val=$(printf '%s\n' "$val" | sed 's/[\/&"]/\\&/g')
                echo "s|^${escaped_key}[[:space:]]*=.*|${key} = \"${escaped_val}\"|" >> /tmp/tes3mp-wizard-local.sed
                ;;
        esac
    done

    # Upload sed script to server via scp
    scp /tmp/tes3mp-wizard-local.sed "$SSH_HOST:$script_path" >/dev/null 2>&1
    rm -f /tmp/tes3mp-wizard-local.sed

    # Apply and remove
    ssh "$SSH_HOST" "sed -i -f $script_path /tes3mp-easy/configs/config.lua && rm -f $script_path" 2>/dev/null

    _LUA_CHANGED=()
    _LUA_TYPE=()
}

# Mark a setting as changed (stores in _LUA_CHANGED)
lua_set() {
    local key="$1" value="$2" type="${3:-string}"
    _LUA_CONF["$key"]="$value"
    _LUA_CHANGED["$key"]="1"
    _LUA_TYPE["$key"]="$type"
}

# Get current value for a setting
lua_get() {
    local key="$1" default="$2"
    local val="${_LUA_CONF[$key]:-}"
    echo "${val:-$default}"
}

# Ask a boolean config setting (local, no SSH)
ask_bool() {
    local key="$1" prompt="$2" default="$3"
    local current
    current=$(lua_get "$key" "")
    local def="${current:-$default}"
    if confirm "$prompt" "$def"; then
        lua_set "$key" "true" "bool"
    else
        lua_set "$key" "false" "bool"
    fi
}

# Ask a string/number config setting (local, no SSH)
ask_value() {
    local key="$1" prompt="$2" default="$3" type="${4:-string}"
    local current
    current=$(lua_get "$key" "")
    local def="${current:-$default}"
    local val
    input "$prompt" "$def" val
    lua_set "$key" "$val" "$type"
}

# ────────────────────────────────────────────────────────────
# SSH_HOST prompt
# ────────────────────────────────────────────────────────────
configure_ssh() {
    local current="${SSH_HOST:-}"

    while true; do
        if [[ -n "$current" ]]; then
            input "Enter SSH host (from ~/.ssh/config)" "$current" SSH_HOST
        else
            echo ""
            echo "  You need an SSH host configured in ~/.ssh/config, e.g.:"
            echo "    Host my-server"
            echo "        HostName 203.0.113.10"
            echo "        User root"
            echo ""
            input "Enter SSH host" "" SSH_HOST
        fi

        if [[ -z "$SSH_HOST" ]]; then
            err "SSH_HOST cannot be empty."
            current=""
            continue
        fi

        set_ini "SSH_HOST" "$SSH_HOST" "$ADMIN_CONFIG"

        echo ""
        info "Testing SSH connection to ${SSH_HOST}..."
        if ssh -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST" "echo ok" 2>/dev/null; then
            ok "SSH connection successful."
            return 0
        else
            err "Connection to ${SSH_HOST} failed."
            if confirm "Try again?" "y"; then
                current="$SSH_HOST"
                continue
            else
                warn "Skipping SSH configuration for now."
                return 1
            fi
        fi
    done
}

# ────────────────────────────────────────────────────────────
# EXPORT_DIR prompt
# ────────────────────────────────────────────────────────────
configure_export_dir() {
    local current="${EXPORT_DIR:-}"

    while true; do
        if [[ -n "$current" ]]; then
            input "Enter path to mods directory" "$current" EXPORT_DIR
        else
            input "Enter path to mods directory" "./exports" EXPORT_DIR
        fi

        if [[ -z "$EXPORT_DIR" ]]; then
            warn "EXPORT_DIR not set — skipping."
            return 1
        fi

        set_ini "EXPORT_DIR" "$EXPORT_DIR" "$ADMIN_CONFIG"
        local resolved="${EXPORT_DIR/#\~/$HOME}"

        if [[ -d "$resolved" ]]; then
            ok "Directory exists: ${resolved}"
        else
            warn "Directory does not exist yet: ${resolved}"
            if confirm "Create it now?" "y"; then
                mkdir -p "$resolved"
                ok "Created: ${resolved}"
            fi
        fi
        return 0
    done
}

# ────────────────────────────────────────────────────────────
# Server configuration (all ✅ settings from config.lua)
# ────────────────────────────────────────────────────────────
configure_server() {
    if ! require_ssh; then
        warn "SSH not available — skipping server configuration."
        return
    fi

    echo ""
    info "Loading current config from server..."
    lua_load
    info "Press Enter to keep the default value shown in brackets."
    echo ""

    # ─── Game settings ───
    group_header "Game"
    ask_value "config.serverName" "  Server name" "TES3MP Server" "string"
    ask_value "config.serverPassword" "  Server password (empty = no password)" "" "password"
    ask_value "config.gameMode" "  Game mode" "Default" "string"
    ask_value "config.difficulty" "  Difficulty (-100..100)" "0" "number"
    ask_value "config.loginTime" "  Login time (seconds)" "60" "number"
    ask_value "config.maxClientsPerIP" "  Max clients per IP" "3" "number"

    # ─── Time ───
    group_header "Time"
    ask_bool "config.passTimeWhenEmpty" "  Pass time when empty?" "n"
    ask_value "config.nightStartHour" "  Night start hour" "20" "number"
    ask_value "config.nightEndHour" "  Night end hour" "6" "number"

    # ─── Permissions ───
    group_header "Permissions"
    ask_bool "config.allowConsole" "  Allow console?" "n"
    ask_bool "config.allowBedRest" "  Allow bed rest?" "y"
    ask_bool "config.allowWildernessRest" "  Allow wilderness rest?" "y"
    ask_bool "config.allowWait" "  Allow wait?" "y"
    ask_bool "config.allowSuicideCommand" "  Allow /suicide?" "y"
    ask_bool "config.allowFixmeCommand" "  Allow /fixme?" "y"

    # ─── Sharing ───
    group_header "Sharing"
    ask_bool "config.shareJournal" "  Share journal?" "y"
    ask_bool "config.shareFactionRanks" "  Share faction ranks?" "y"
    ask_bool "config.shareFactionExpulsion" "  Share faction expulsion?" "n"
    ask_bool "config.shareFactionReputation" "  Share faction reputation?" "y"
    ask_bool "config.shareTopics" "  Share dialogue topics?" "y"
    ask_bool "config.shareBounty" "  Share bounty?" "n"
    ask_bool "config.shareReputation" "  Share reputation?" "y"
    ask_bool "config.shareMapExploration" "  Share map exploration?" "n"
    ask_bool "config.shareVideos" "  Share videos?" "y"

    # ─── Respawn & Death ───
    group_header "Respawn & Death"
    ask_bool "config.playersRespawn" "  Players respawn?" "y"
    ask_value "config.deathTime" "  Death time (seconds)" "5" "number"
    ask_value "config.deathPenaltyJailDays" "  Jail days penalty" "5" "number"
    ask_bool "config.bountyResetOnDeath" "  Reset bounty on death?" "n"
    ask_bool "config.bountyDeathPenalty" "  Bounty death penalty?" "n"
    ask_bool "config.respawnAtImperialShrine" "  Respawn at Imperial shrine?" "y"
    ask_bool "config.respawnAtTribunalTemple" "  Respawn at Tribunal temple?" "y"

    # ─── Collisions ───
    group_header "Collisions"
    ask_bool "config.enablePlayerCollision" "  Player-player collision?" "y"
    ask_bool "config.enableActorCollision" "  Actor-actor collision?" "y"
    ask_bool "config.enablePlacedObjectCollision" "  Placed object collision?" "n"

    # ─── Stats limits ───
    group_header "Stats Limits"
    ask_value "config.maxAttributeValue" "  Max attribute value" "200" "number"
    ask_value "config.maxSpeedValue" "  Max Speed value" "365" "number"
    ask_value "config.maxSkillValue" "  Max skill value" "200" "number"
    ask_value "config.maxAcrobaticsValue" "  Max Acrobatics value" "1200" "number"

    # ─── Safety ───
    group_header "Safety"
    ask_bool "config.enforceDataFiles" "  Enforce data files?" "y"
    ask_bool "config.ignoreScriptErrors" "  Ignore script errors?" "n"

    ok "Saving server configuration..."
    lua_save
    ok "Server configuration updated."
}

# ────────────────────────────────────────────────────────────
# Main wizard
# ────────────────────────────────────────────────────────────
main() {
    local TOTAL=6

    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║       TES3MP Easy — Admin Setup Wizard          ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    info "This wizard will guide you through setting up the server."
    info "Press Ctrl+C at any time to exit."
    echo ""

    # Load current config
    load_config "$ADMIN_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 1: SSH_HOST
    # ────────────────────────────────────────────────────────
    step_header 1 $TOTAL "SSH Connection"
    configure_ssh
    load_config "$ADMIN_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 2: EXPORT_DIR
    # ────────────────────────────────────────────────────────
    step_header 2 $TOTAL "Export Directory"
    configure_export_dir
    load_config "$ADMIN_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 3: Install server
    # ────────────────────────────────────────────────────────
    step_header 3 $TOTAL "Server Installation"

    if ! require_ssh; then
        warn "Cannot proceed with server installation without SSH access."
        warn "Fix SSH_HOST and re-run the wizard."
    else
        local server_installed=false
        if ssh "$SSH_HOST" "test -f /tes3mp-easy/docker-compose.yml" 2>/dev/null; then
            server_installed=true
        fi

        if $server_installed; then
            ok "Server is already installed on ${SSH_HOST}."
            if confirm "Re-install / upgrade server?" "n"; then
                info "Re-installing server..."
                bash "$SCRIPT_DIR/bin/admin/install-server" || {
                    err "Server installation failed."
                }
            fi
        else
            if confirm "Install server on ${SSH_HOST}?" "y"; then
                info "Installing server..."
                bash "$SCRIPT_DIR/bin/admin/install-server" || {
                    err "Server installation failed."
                }
            fi
        fi
    fi

    # ────────────────────────────────────────────────────────
    # Step 4: Server configuration
    # ────────────────────────────────────────────────────────
    step_header 4 $TOTAL "Server Configuration"
    configure_server

    # ────────────────────────────────────────────────────────
    # Step 5: Mods setup
    # ────────────────────────────────────────────────────────
    step_header 5 $TOTAL "Mods Setup"

    if [[ -n "${EXPORT_DIR:-}" ]]; then
        local resolved="${EXPORT_DIR/#\~/$HOME}"
        local mod_plugins="$resolved/mods/plugins"
        local mod_scripts="$resolved/mods/scripts"

        if [[ -d "$mod_plugins" ]] && [[ -d "$mod_scripts" ]]; then
            ok "Mod directories already exist."
        else
            if confirm "Create mod directories (plugins + scripts)?" "y"; then
                mkdir -p "$mod_plugins" "$mod_scripts"
                ok "Created: $mod_plugins"
                ok "Created: $mod_scripts"
            fi
        fi

        if confirm "Export mods to server now?" "n"; then
            bash "$SCRIPT_DIR/bin/admin/export-mods" || {
                warn "Export failed — you can do it later from the menu."
            }
        fi
    else
        warn "EXPORT_DIR not set — skipping mods setup."
    fi

    # ────────────────────────────────────────────────────────
    # Step 6: Start server
    # ────────────────────────────────────────────────────────
    step_header 6 $TOTAL "Start Server"

    if require_ssh; then
        if confirm "Start server now?" "n"; then
            bash "$SCRIPT_DIR/bin/admin/start-server" || {
                err "Failed to start server."
            }
        fi
    fi

    # ────────────────────────────────────────────────────────
    # Summary
    # ────────────────────────────────────────────────────────
    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║            Setup Wizard Complete!                ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ${T_LABEL}Configuration:${NC}"
    echo "    SSH_HOST   = ${SSH_HOST:-${T_ERROR}(not set)${NC}}"
    echo "    EXPORT_DIR = ${EXPORT_DIR:-${T_ERROR}(not set)${NC}}"
    echo ""
    if [[ -n "${SSH_HOST:-}" ]]; then
        local running
        running=$(ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose ps --format '{{.State}}' 2>/dev/null | head -1" 2>/dev/null || echo "")
        if [[ "$running" == "running" ]]; then
            ok "Server is running on ${SSH_HOST}"
        else
            warn "Server is not running. Start it from the menu."
        fi
    fi
    echo ""
    info "You can always re-run this wizard or use individual menu items."
}

main "$@"
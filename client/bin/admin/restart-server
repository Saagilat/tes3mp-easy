#!/bin/bash
#
# restart-server — Restart TES3MP server on remote VPS
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-admin.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set in config"
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Restarting TES3MP Server"
echo "═══════════════════════════════════════════════"
echo ""

info "Running on $SSH_HOST: cd /tes3mp-easy && docker compose up -d --force-recreate"
ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose up -d --force-recreate" || {
    err "Failed to restart server on $SSH_HOST"
    exit 1
}
ssh "$SSH_HOST" "rm -f /tes3mp-easy/needs_restart.flag" 2>/dev/null || true
ok "Server restarted on $SSH_HOST"
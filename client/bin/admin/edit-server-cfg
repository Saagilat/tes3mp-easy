#!/bin/bash
#
# admin-edit-server-cfg — Edit tes3mp-server-default.cfg on remote VPS
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-admin.ini" 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

remote_path="/tes3mp-easy/configs/tes3mp-server-default.cfg"
tmpfile=$(mktemp /tmp/tes3mp-edit.XXXXXX)
basename="${remote_path##*/}"

info "Downloading $basename from $SSH_HOST..."
scp -q "$SSH_HOST:$remote_path" "$tmpfile" 2>/dev/null || { err "Failed to download $remote_path"; rm -f "$tmpfile"; exit 1; }

initial_sum=$(sha256sum "$tmpfile" | awk '{print $1}')

editor=$(find_editor)
info "Opening with: $editor"

case "$(basename "$editor")" in
    code|code-oss) "$editor" --wait "$tmpfile" 2>/dev/null ;;
    subl|sublime_text|sublime) "$editor" -w "$tmpfile" 2>/dev/null ;;
    gedit*|kate*) "$editor" "$tmpfile" & ;;
    *) "$editor" "$tmpfile" </dev/tty ;;
esac

new_sum=$(sha256sum "$tmpfile" | awk '{print $1}')
if [[ "$initial_sum" == "$new_sum" ]]; then
    info "File not modified — nothing to upload"
    rm -f "$tmpfile"
    exit 0
fi

info "Uploading $basename to $SSH_HOST..."
scp -q "$tmpfile" "$SSH_HOST:$remote_path" || { err "Failed to upload"; rm -f "$tmpfile"; exit 1; }
rm -f "$tmpfile"
ssh "$SSH_HOST" "touch /tes3mp-easy/needs_restart.flag" 2>/dev/null || true
ok "$basename saved on $SSH_HOST"
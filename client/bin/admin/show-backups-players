#!/bin/bash
#
# show-backups-players — List player backup archives on remote VPS via SSH
# Layer 1: outputs filenames one-per-line, no formatting.
# Usage: show-backups-players
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && exit 1

ssh "$SSH_HOST" "ls -t /tes3mp-easy/backups/players/*.tar.gz 2>/dev/null" 2>/dev/null | while IFS= read -r file; do
    basename "$file"
done
#!/bin/bash
#
# show-backups-world — List world backup archives on remote VPS via SSH
# Layer 1: outputs JSON, no formatting.
# Usage: show-backups-world
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1
[[ -z "${SSH_HOST:-}" ]] && exit 1

ssh "$SSH_HOST" "bash /tes3mp-easy/scripts/list-backups.sh world" 2>/dev/null || echo '{"files":[],"current":null}'
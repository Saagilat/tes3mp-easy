#!/bin/bash
#
# stop-server — Stop TES3MP server on remote VPS
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-admin.ini" 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-admin.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set in config"
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Stopping TES3MP Server"
echo "═══════════════════════════════════════════════"
echo ""

info "Running on $SSH_HOST: cd /tes3mp-easy && docker compose down"
ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose down" || {
    err "Failed to stop server on $SSH_HOST"
    exit 1
}
ok "Server stopped on $SSH_HOST"
#!/bin/bash
#
# show-backups-mods — List mod backup archives on remote VPS
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || {
    err "Config not found"
    exit 1
}

if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set"
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Mod backup archives on $SSH_HOST"
echo "═══════════════════════════════════════════════"
echo ""

ssh "$SSH_HOST" "ls -t /tes3mp-easy/backups/mods/*.tar.gz 2>/dev/null" || {
    err "No mod backups found"
    exit 1
}
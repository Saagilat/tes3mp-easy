#!/bin/bash
#
# admin-deploy-mods — Deploy mods archive on remote VPS
# Usage: admin-deploy-mods [--latest | <filename>]
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-admin.ini" 2>/dev/null || { err "Config not found"; exit 1; }
[[ -z "${SSH_HOST:-}" ]] && { err "SSH_HOST is not set"; exit 1; }

arg="${1:-}"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Deploy mods"
echo "═══════════════════════════════════════════════"
echo ""

ssh "$SSH_HOST" "cd /tes3mp-easy && bash scripts/deploy_mods.sh '$arg'" || {
    err "Deploy failed."
    exit 1
}
ssh "$SSH_HOST" "touch /tes3mp-easy/needs_restart.flag" 2>/dev/null || true
ok "Deploy queued. Use admin-restart to apply."
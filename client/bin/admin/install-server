#!/bin/bash
#
# install-server — Install TES3MP server on remote VPS
# Non-interactive (layer 1). Runs install.sh via SSH.
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-admin.ini" 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-admin.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set in config"
    exit 1
fi

install_url="https://raw.githubusercontent.com/Saagilat/tes3mp-easy/master/server/scripts/install.sh"
cmd="curl -fsSL '$install_url' | bash"

echo ""
echo "═══════════════════════════════════════════════"
echo "  TES3MP Server Installation"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Installing on: $SSH_HOST"
echo ""

info "Starting installation on $SSH_HOST..."
ssh "$SSH_HOST" "$cmd" || {
    err "Installation failed on $SSH_HOST"
    err "Check the output above for details."
    exit 1
}

ok "Infrastructure installation completed on $SSH_HOST"
echo ""
info "Next steps:"
info "  1. Start the server:   start-server"
info "  2. Add your mods with: export-mods"
echo ""
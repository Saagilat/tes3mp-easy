#!/bin/bash
#
# server-status — Show TES3MP container status on remote VPS
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-admin.ini" 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-admin.ini"
    err "Run 'edit-config' to set it up."
    exit 1
}

if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set in config"
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  TES3MP Server Status"
echo "═══════════════════════════════════════════════"
echo ""

ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose ps" || {
    err "Failed to get server status on $SSH_HOST"
    exit 1
}
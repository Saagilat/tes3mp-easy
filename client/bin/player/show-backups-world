#!/bin/bash
#
# show-backups-world — List world backup archives from TES3MP server
# Layer 1: outputs filenames one-per-line, no formatting.
# Usage: show-backups-world
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config 2>/dev/null || exit 1

SERVER_URL=$(_get_server_url) || exit 1

json=$(curl -sf "$SERVER_URL/list-backups/world" 2>/dev/null || echo "")
[[ -z "$json" || "$json" == "[]" ]] && exit 0

# Parse JSON array — split into individual objects, extract "name" field
json="${json#\[}"
json="${json%\]}"
[[ -z "$json" ]] && exit 0

IFS="}" read -ra objects <<< "$json"
for obj in "${objects[@]}"; do
    obj="${obj#\{}"
    obj="${obj#,}"
    if [[ "$obj" =~ \"name\":[[:space:]]*\"([^\"]+)\" ]]; then
        echo "${BASH_REMATCH[1]}"
    fi
done
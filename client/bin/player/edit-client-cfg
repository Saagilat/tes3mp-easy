#!/bin/bash
#
# player-edit-client-cfg — Edit tes3mp-client-default.cfg
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-player.ini" 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-player.ini"
    err "Run 'player-settings' to set it up."
    exit 1
}

if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    exit 1
fi

cfg="$TES3MP_DIR/tes3mp-client-default.cfg"
if [[ ! -f "$cfg" ]]; then
    err "File not found: $cfg"
    exit 1
fi

editor=$(find_editor)
info "Opening with: $editor"
"$editor" "$cfg"
ok "Config file saved."
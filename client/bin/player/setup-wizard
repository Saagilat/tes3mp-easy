#!/bin/bash
#
# setup-wizard — Player quick setup wizard (fully interactive, no editors)
#
# Guides the player through:
#   1. DATA_FILES  — configure if missing
#   2. TES3MP_DIR  — configure if missing
#   3. Install client
#   4. Install fonts
#   5. Configure UI (ttf resolution, font size, scaling)
#   6. Localization + launch
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

PLAYER_CONFIG="${HOME}/.tes3mp-easy-player.ini"
CONFIG_FILE="$PLAYER_CONFIG"

# ────────────────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────────────────
step_header() {
    local num="$1" total="$2" title="$3"
    echo ""
    echo "  ${T_LABEL}━━━ [${num}/${total}] ${title} ━━━${NC}"
    echo ""
}

confirm() {
    local prompt="${1:-Continue?}"
    local default="${2:-y}"
    local ans
    read -r -p "  ${prompt} [${default}/n]: " ans
    ans="${ans:-$default}"
    [[ "${ans,,}" == "y" ]]
}

input() {
    local prompt="$1" default="$2" result_var="$3"
    local ans
    if [[ -n "$default" ]]; then
        read -r -p "  ${prompt} [${default}]: " ans
        ans="${ans:-$default}"
    else
        read -r -p "  ${prompt}: " ans
    fi
    printf -v "$result_var" "%s" "$ans"
}

set_ini() {
    local key="$1" value="$2" file="$3"
    if grep -q "^${key}[[:space:]]*=" "$file" 2>/dev/null; then
        sed -i "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$file"
    else
        echo "${key} = ${value}" >> "$file"
    fi
    ok "${key} set to: ${value}"
}

# ────────────────────────────────────────────────────────────
# Main wizard
# ────────────────────────────────────────────────────────────
main() {
    local TOTAL=6

    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║      TES3MP Easy — Player Setup Wizard          ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    info "This wizard will guide you through setting up the client."
    info "Press Ctrl+C at any time to exit."
    echo ""

    # Load current config
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 1: DATA_FILES
    # ────────────────────────────────────────────────────────
    step_header 1 $TOTAL "Morrowind Data Files"

    local data_found=false
    if [[ -n "${DATA_FILES:-}" ]]; then
        local check_path="${DATA_FILES/#\~/$HOME}"
        if [[ -f "$check_path/Morrowind.esm" ]]; then
            data_found=true
        fi
    fi

    if $data_found; then
        ok "DATA_FILES found: ${DATA_FILES}"
        if ! confirm "Change DATA_FILES?" "n"; then
            info "Keeping DATA_FILES = ${DATA_FILES}"
        else
            input "Enter path to Morrowind/Data Files" "" DATA_FILES
            set_ini "DATA_FILES" "$DATA_FILES" "$PLAYER_CONFIG"
        fi
    else
        if [[ -n "${DATA_FILES:-}" ]]; then
            warn "DATA_FILES is set but Morrowind.esm not found at: ${DATA_FILES}"
        else
            warn "DATA_FILES is not set."
        fi
        echo ""
        echo "  Enter the path to your Morrowind Data Files directory."
        echo "  This is where Morrowind.esm is located."
        echo "  Example: /home/user/.steam/steam/steamapps/common/Morrowind/Data Files"
        echo ""
        input "Enter path to Morrowind/Data Files" "" DATA_FILES
        set_ini "DATA_FILES" "$DATA_FILES" "$PLAYER_CONFIG"
    fi

    # Reload config
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 2: TES3MP_DIR
    # ────────────────────────────────────────────────────────
    step_header 2 $TOTAL "TES3MP Directory"

    if [[ -n "${TES3MP_DIR:-}" ]]; then
        local tes3mp_path="${TES3MP_DIR/#\~/$HOME}"
        if [[ -f "$tes3mp_path/tes3mp.exe" ]]; then
            ok "TES3MP_DIR: ${TES3MP_DIR} (client already installed)"
        else
            info "Current TES3MP_DIR: ${TES3MP_DIR}"
        fi
        if ! confirm "Change TES3MP_DIR?" "n"; then
            info "Keeping TES3MP_DIR = ${TES3MP_DIR}"
        else
            input "Enter TES3MP directory" "games/tes3mp" TES3MP_DIR
            set_ini "TES3MP_DIR" "$TES3MP_DIR" "$PLAYER_CONFIG"
        fi
    else
        input "Enter TES3MP directory" "games/tes3mp" TES3MP_DIR
        set_ini "TES3MP_DIR" "$TES3MP_DIR" "$PLAYER_CONFIG"
    fi

    # Reload config
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 3: Install client
    # ────────────────────────────────────────────────────────
    step_header 3 $TOTAL "Client Installation"

    local tes3mp_exe=""
    if [[ -n "${TES3MP_DIR:-}" ]]; then
        tes3mp_exe="${TES3MP_DIR/#\~/$HOME}/tes3mp.exe"
    fi

    if [[ -n "$tes3mp_exe" && -f "$tes3mp_exe" ]]; then
        ok "Client is already installed."
        if confirm "Open OpenMW wizard again?" "n"; then
            # Check required settings first
            if [[ -z "${DATA_FILES:-}" ]]; then
                err "DATA_FILES is not set. Configure it first."
            elif [[ -z "${TES3MP_DIR:-}" ]]; then
                err "TES3MP_DIR is not set. Configure it first."
            else
                bash "$SCRIPT_DIR/bin/player/install-client" || {
                    err "Client installation wizard failed."
                }
            fi
        fi
    else
        info "Client is not installed."
        if confirm "Install client now?" "y"; then
            if [[ -z "${DATA_FILES:-}" ]]; then
                err "DATA_FILES is not set. Please configure it first."
            elif [[ -z "${TES3MP_DIR:-}" ]]; then
                err "TES3MP_DIR is not set. Please configure it first."
            else
                bash "$SCRIPT_DIR/bin/player/install-client" || {
                    err "Client installation failed."
                }
            fi
        fi
    fi

    # ────────────────────────────────────────────────────────
    # Step 4: Install fonts
    # ────────────────────────────────────────────────────────
    step_header 4 $TOTAL "Fonts"

    if confirm "Install fonts?" "y"; then
        bash "$SCRIPT_DIR/bin/player/install-fonts" || {
            warn "Font installation cancelled or failed."
        }
    fi

    # ────────────────────────────────────────────────────────
    # Step 5: Configure UI
    # ────────────────────────────────────────────────────────
    step_header 5 $TOTAL "UI Configuration"

    if confirm "Configure UI (ttf resolution, font size, scaling)?" "y"; then
        local settings_cfg=""
        if [[ -n "${TES3MP_DIR:-}" ]]; then
            settings_cfg="${TES3MP_DIR/#\~/$HOME}/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/settings.cfg"
        fi

        if [[ -n "$settings_cfg" && -f "$settings_cfg" ]]; then
            bash "$SCRIPT_DIR/bin/player/configure-ui" || {
                warn "UI configuration cancelled or failed."
            }
        else
            warn "settings.cfg not found. Run the client at least once first."
            warn "Skipping UI configuration."
        fi
    fi

    # ────────────────────────────────────────────────────────
    # Step 6: Localization + Launch
    # ────────────────────────────────────────────────────────
    step_header 6 $TOTAL "Finish"

    if confirm "Install localization?" "y"; then
        bash "$SCRIPT_DIR/bin/player/install-localization" || {
            warn "Localization installation cancelled or failed."
        }
    fi

    if confirm "Launch client now?" "n"; then
        bash "$SCRIPT_DIR/bin/player/run-client" || {
            err "Failed to launch client."
        }
    fi

    # ────────────────────────────────────────────────────────
    # Summary
    # ────────────────────────────────────────────────────────
    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║            Setup Wizard Complete!                ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ${T_LABEL}Configuration:${NC}"
    echo "    DATA_FILES = ${DATA_FILES:-${T_ERROR}(not set)${NC}}"
    echo "    TES3MP_DIR = ${TES3MP_DIR:-${T_ERROR}(not set)${NC}}"
    echo ""
    info "You can always re-run this wizard or use individual menu items."
}

main "$@"
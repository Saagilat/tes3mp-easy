#!/bin/bash
#
# setup-wizard — Player quick setup wizard (fully interactive, no editors)
#
# Guides the player through:
#   1. MORROWIND_PATH — configure (always shown, path verified)
#   2. TES3MP_DIR     — configure (always shown)
#   3. PROTON_PATH    — configure (manual entry)
#   4. Install client
#   5. Install fonts
#   6. Configure UI (ttf resolution, font size, scaling)
#   7. Localization + launch
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
PLAYER_CONFIG="$CONFIG_DIR/tes3mp-easy-player.ini"
CONFIG_FILE="$PLAYER_CONFIG"

# ────────────────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────────────────
step_header() {
    local num="$1" total="$2" title="$3"
    echo ""
    echo "  ${T_LABEL}━━━ [${num}/${total}] ${title} ━━━${NC}"
    echo ""
}

set_ini() {
    local key="$1" value="$2" file="$3"
    if grep -q "^${key}[[:space:]]*=" "$file" 2>/dev/null; then
        sed -i "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$file"
    else
        echo "${key} = ${value}" >> "$file"
    fi
    ok "${key} set to: ${value}"
}

# Prompt for MORROWIND_PATH (always shows current, verifies Morrowind.esm)
configure_morrowind_path() {
    local current="${MORROWIND_PATH:-}"

    while true; do
        if [[ -n "$current" ]]; then
            input "Enter path to Morrowind directory" "$current" MORROWIND_PATH
        else
            echo ""
            echo "  Enter the path to your Morrowind installation directory."
            echo "  The 'Data Files' folder must be inside this directory."
            echo "  Example: /home/user/.steam/steam/steamapps/common/Morrowind"
            echo ""
            input "Enter path to Morrowind directory" "" MORROWIND_PATH
        fi

        if [[ -z "$MORROWIND_PATH" ]]; then
            warn "MORROWIND_PATH not set — skipping."
            return 1
        fi

        set_ini "MORROWIND_PATH" "$MORROWIND_PATH" "$PLAYER_CONFIG"
        local resolved="${MORROWIND_PATH/#\~/$HOME}"

        if [[ -f "$resolved/Data Files/Morrowind.esm" ]]; then
            ok "Morrowind.esm found at: ${resolved}/Data Files"
            return 0
        else
            warn "Morrowind.esm not found at: ${resolved}/Data Files"
            if confirm "Try again?" "y"; then
                current="$MORROWIND_PATH"
                continue
            else
                warn "Skipping MORROWIND_PATH for now."
                return 1
            fi
        fi
    done
}

# Prompt for TES3MP_DIR (always shows current)
configure_tes3mp_dir() {
    local current="${TES3MP_DIR:-}"

    while true; do
        if [[ -n "$current" ]]; then
            input "Enter TES3MP directory" "$current" TES3MP_DIR
        else
            input "Enter TES3MP directory" "games/tes3mp" TES3MP_DIR
        fi

        if [[ -z "$TES3MP_DIR" ]]; then
            warn "TES3MP_DIR not set — skipping."
            return 1
        fi

        set_ini "TES3MP_DIR" "$TES3MP_DIR" "$PLAYER_CONFIG"
        return 0
    done
}

# Prompt for PROTON_PATH (manual entry only)
configure_proton_path() {
    local current="${PROTON_PATH:-}"
    local found=""

    if [[ -n "$current" ]] && [[ -f "$current/proton" ]]; then
        found="yes"
    fi

    while true; do
        if [[ -n "$current" ]]; then
            if [[ "$found" == "yes" ]]; then
                input "Enter path to Proton directory" "$current" PROTON_PATH
            else
                input "Enter path to Proton directory" "$current" PROTON_PATH
            fi
        else
            echo ""
            echo "  Enter the path to your Proton installation."
            echo "  This is where the 'proton' executable is located."
            echo "  Example: /home/user/.steam/steam/steamapps/common/Proton 9.0"
            echo ""
            input "Enter path to Proton directory" "" PROTON_PATH
        fi

        if [[ -z "$PROTON_PATH" ]]; then
            warn "PROTON_PATH not set — skipping."
            return 1
        fi

        local resolved="${PROTON_PATH/#\~/$HOME}"
        if [[ -f "$resolved/proton" ]]; then
            set_ini "PROTON_PATH" "$PROTON_PATH" "$PLAYER_CONFIG"
            ok "Proton found: ${resolved}"
            return 0
        else
            warn "proton executable not found at: ${resolved}"
            if confirm "Try again?" "y"; then
                current="$PROTON_PATH"
                continue
            else
                warn "Skipping PROTON_PATH for now."
                return 1
            fi
        fi
    done
}

# ────────────────────────────────────────────────────────────
# Main wizard
# ────────────────────────────────────────────────────────────
main() {
    local TOTAL=7

    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║      TES3MP Easy — Player Setup Wizard          ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    info "This wizard will guide you through setting up the client."
    info "Press Ctrl+C at any time to exit."
    echo ""

    # Load current config
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 1: DATA_FILES
    # ────────────────────────────────────────────────────────
    step_header 1 $TOTAL "Morrowind Directory"
    configure_morrowind_path
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 2: TES3MP_DIR
    # ────────────────────────────────────────────────────────
    step_header 2 $TOTAL "TES3MP Directory"
    configure_tes3mp_dir
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 3: PROTON_PATH
    # ────────────────────────────────────────────────────────
    step_header 3 $TOTAL "Proton Path"
    configure_proton_path
    load_config "$PLAYER_CONFIG" 2>/dev/null || true

    # ────────────────────────────────────────────────────────
    # Step 4: Install client
    # ────────────────────────────────────────────────────────
    step_header 4 $TOTAL "Client Installation"

    if [[ -z "${MORROWIND_PATH:-}" ]]; then
        err "MORROWIND_PATH is not set. Please configure it first."
    elif [[ -z "${TES3MP_DIR:-}" ]]; then
        err "TES3MP_DIR is not set. Please configure it first."
    else
        if confirm "Install / update client now?" "y"; then
            bash "$SCRIPT_DIR/bin/player/install-client" || {
                err "Client installation failed."
            }
        fi
    fi

    # ────────────────────────────────────────────────────────
    # Step 5: Install fonts
    # ────────────────────────────────────────────────────────
    step_header 5 $TOTAL "Fonts"

    if confirm "Install fonts?" "y"; then
        bash "$SCRIPT_DIR/bin/player/install-fonts" || {
            warn "Font installation cancelled or failed."
        }
    fi

    # ────────────────────────────────────────────────────────
    # Step 6: Configure UI
    # ────────────────────────────────────────────────────────
    step_header 6 $TOTAL "UI Configuration"

    local settings_cfg=""
    if [[ -n "${TES3MP_DIR:-}" ]]; then
        settings_cfg="${TES3MP_DIR/#\~/$HOME}/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/settings.cfg"
    fi

    if [[ -n "$settings_cfg" && -f "$settings_cfg" ]]; then
        bash "$SCRIPT_DIR/bin/player/configure-ui" || {
            warn "UI configuration cancelled or failed."
        }
    else
        warn "settings.cfg not found. Run the client at least once first."
        warn "Skipping UI configuration."
    fi

    # ────────────────────────────────────────────────────────
    # Step 7: Localization + Launch
    # ────────────────────────────────────────────────────────
    step_header 7 $TOTAL "Finish"

    bash "$SCRIPT_DIR/bin/player/install-localization" || {
        warn "Localization installation cancelled or failed."
    }

    if confirm "Launch client now?" "n"; then
        bash "$SCRIPT_DIR/bin/player/run-client" || {
            err "Failed to launch client."
        }
    fi

    # ────────────────────────────────────────────────────────
    # Summary
    # ────────────────────────────────────────────────────────
    echo ""
    echo "  ${T_LABEL}╔══════════════════════════════════════════════════╗${NC}"
    echo "  ${T_LABEL}║            Setup Wizard Complete!                ║${NC}"
    echo "  ${T_LABEL}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ${T_LABEL}Configuration:${NC}"
    echo "    MORROWIND_PATH  = ${MORROWIND_PATH:-${T_ERROR}(not set)${NC}}"
    echo "    TES3MP_DIR  = ${TES3MP_DIR:-${T_ERROR}(not set)${NC}}"
    echo "    PROTON_PATH = ${PROTON_PATH:-${T_ERROR}(not set)${NC}}"
    echo ""
    info "You can always re-run this wizard or use individual menu items."
}

main "$@"
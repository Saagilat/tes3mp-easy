#!/bin/bash
#
# player-install-localization — Install Morrowind localization
#
# Shows available localizations from client/lib/localization/*/
# and runs the install.sh for the selected one.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$SCRIPT_DIR/lib/common"
source "$SCRIPT_DIR/lib/config"

load_config "$HOME/.tes3mp-easy-player.ini" 2>/dev/null || {
    err "Config not found at ~/.tes3mp-easy-player.ini"; exit 1
}

[[ -z "${TES3MP_DIR:-}" ]] && { err "TES3MP_DIR is not set in config."; exit 1; }
[[ -z "${DATA_FILES:-}" ]] && { err "DATA_FILES is not set in config."; exit 1; }

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
DATA_FILES="${DATA_FILES/#\~/$HOME}"

# Morrowind root (one level above Data Files)
MORROWIND_DIR="${DATA_FILES%/Data Files}"

if [[ ! -d "$MORROWIND_DIR" ]]; then
    err "Morrowind directory not found: $MORROWIND_DIR"
    err "Check DATA_FILES in config."
    exit 1
fi

LOCALE_DIR="$TES3MP_DIR/localizations"
mkdir -p "$LOCALE_DIR"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Install Localization"
echo "═══════════════════════════════════════════════"
echo ""

# ────────────────────────────────────────────────────
# 1. List available localizations
# ────────────────────────────────────────────────────
LOCALES=()
LOCALE_NAMES=()

for dir in "$SCRIPT_DIR/lib/localization"/*/; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    install_script="$dir/install.sh"
    if [[ -f "$install_script" ]]; then
        LOCALES+=("$name")
        # Capitalize first letter
        LOCALE_NAMES+=("$(tr '[:lower:]' '[:upper:]' <<< "${name:0:1}")${name:1}")
    fi
done

if [[ ${#LOCALES[@]} -eq 0 ]]; then
    warn "No localizations found."
    exit 1
fi

echo "  Available localizations:"
for i in "${!LOCALES[@]}"; do
    printf "  %d) %s\n" $((i+1)) "${LOCALE_NAMES[$i]}"
done
echo "  $((${#LOCALES[@]}+1))) Skip localization"
echo ""
input "Select option [1-$((${#LOCALES[@]}+1))]" "" LOCALE_CHOICE

# If empty or skip — exit
if [[ -z "${LOCALE_CHOICE:-}" ]] || [[ "$LOCALE_CHOICE" -eq $((${#LOCALES[@]}+1)) ]]; then
    info "No localization selected. Skipping."
    exit 0
fi

LOCALE_IDX=$((LOCALE_CHOICE - 1))
if [[ "$LOCALE_IDX" -lt 0 || "$LOCALE_IDX" -ge "${#LOCALES[@]}" ]]; then
    warn "Invalid selection. Skipping."
    exit 1
fi

LOCALE="${LOCALES[$LOCALE_IDX]}"
LOCALE_NAME="${LOCALE_NAMES[$LOCALE_IDX]}"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Installing ${LOCALE_NAME} Localization"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Morrowind:    $MORROWIND_DIR"
echo "  Cache dir:    $LOCALE_DIR"
echo ""

# ────────────────────────────────────────────────────
# 2. Get install.sh — use local copy
# ────────────────────────────────────────────────────
INSTALL_SCRIPT="$SCRIPT_DIR/lib/localization/${LOCALE}/install.sh"
chmod +x "$INSTALL_SCRIPT"
info "Using install.sh for ${LOCALE_NAME}"

# ────────────────────────────────────────────────────
# 3. Download archive
# ────────────────────────────────────────────────────
RELEASE_URL="https://github.com/Saagilat/tes3mp-easy/releases/download/${LOCALE}-v1.0"
LOCALE_TAR="$LOCALE_DIR/${LOCALE}.tar"

if [[ -f "$LOCALE_TAR" ]]; then
    info "${LOCALE}.tar already cached, skipping."
else
    info "Downloading ${LOCALE}.tar (this may take a while)..."
    curl -# -L -o "$LOCALE_TAR" "$RELEASE_URL/${LOCALE}.tar" 2>&1 || {
        err "Failed to download ${LOCALE}.tar"
        exit 1
    }
    ok "${LOCALE}.tar downloaded."
fi

# ────────────────────────────────────────────────────
# 4. Optional: voices
# ────────────────────────────────────────────────────
VOICES_TAR="$LOCALE_DIR/voices_${LOCALE}.tar"
if [[ ! -f "$VOICES_TAR" ]]; then
    if confirm "Download voices_${LOCALE}.tar (~150 MB)?" "n"; then
        info "Downloading voices_${LOCALE}.tar (this may take a while)..."
        curl -# -L -o "$VOICES_TAR" "$RELEASE_URL/voices_${LOCALE}.tar" 2>&1 || {
            warn "Failed to download voices_${LOCALE}.tar (may be missing)."
            rm -f "$VOICES_TAR"
        }
        if [[ -f "$VOICES_TAR" ]]; then
            ok "voices_${LOCALE}.tar downloaded."
        fi
    fi
fi

# ────────────────────────────────────────────────────
# 5. Run install.sh
# ────────────────────────────────────────────────────
echo ""
info "Running localization installer..."
echo ""

bash "$INSTALL_SCRIPT" "$MORROWIND_DIR"

# ────────────────────────────────────────────────────
# 6. Set encoding=win1251 in openmw.cfg
# ────────────────────────────────────────────────────
OPENMW_CFG="$TES3MP_DIR/prefix/pfx/drive_c/users/steamuser/Documents/My Games/OpenMW/openmw.cfg"

if [[ -f "$OPENMW_CFG" ]]; then
    echo ""
    info "Setting encoding=win1251 in openmw.cfg for Cyrillic support..."
    if grep -q "^encoding[[:space:]]*=" "$OPENMW_CFG" 2>/dev/null; then
        sed -i "s|^encoding[[:space:]]*=.*|encoding=win1251|" "$OPENMW_CFG"
    else
        echo "" >> "$OPENMW_CFG"
        echo "encoding=win1251" >> "$OPENMW_CFG"
    fi
    ok "encoding=win1251 set in openmw.cfg"
else
    warn "openmw.cfg not found at: $OPENMW_CFG"
    warn "encoding=win1251 could not be set automatically."
    warn "Run the client once to generate config files, then re-run this script."
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Localization installation complete!"
echo "═══════════════════════════════════════════════"
echo ""
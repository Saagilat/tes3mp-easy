#!/bin/bash
#
# interactive-install-mods-and-play — install mods and launch client
# Layer 2: shows current server address, offers to change it, then proceeds
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true

LAYER1="$PROJECT_DIR/layer1/player"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Install Mods & Launch Client"
echo "═══════════════════════════════════════════════"
echo ""

# ────────────────────────────────────────────────────
# Get current server address from config
# ────────────────────────────────────────────────────
if [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set in config."
    err "Run setup-wizard first."
    exit 1
fi

TES3MP_DIR="${TES3MP_DIR/#\~/$HOME}"
CLIENT_CFG="$TES3MP_DIR/tes3mp-client-default.cfg"
if [[ ! -f "$CLIENT_CFG" ]]; then
    err "Client config not found: $CLIENT_CFG"
    err "Run install-client first."
    exit 1
fi

CURRENT_ADDR=$(grep -i "^destinationAddress[[:space:]]*=" "$CLIENT_CFG" 2>/dev/null | head -1 | sed 's/.*=[[:space:]]*//' | tr -d '\r')
[[ -z "$CURRENT_ADDR" ]] && CURRENT_ADDR="(not set)"

echo "  Current server: $CURRENT_ADDR"
echo ""

# ────────────────────────────────────────────────────
# Interactive countdown with option to change server
# ────────────────────────────────────────────────────
TIMEOUT=5
NEW_ADDR="$CURRENT_ADDR"

# Save terminal settings to restore later
tty_settings=$(stty -g 2>/dev/null || true)

# Read one character with timeout loop (1 second at a time)
for ((i=TIMEOUT; i>=1; i--)); do
    echo -ne "\r  Press 'e' to change server address, or press Enter to continue... [$i]   "
    
    if [[ -c /dev/tty ]]; then
        key=""
        read -r -t 1 -n 1 key </dev/tty || true
    elif [[ -t 0 ]]; then
        key=""
        read -r -t 1 -n 1 key || true
    else
        sleep 1
        key=""
    fi
    
    if [[ -n "$key" ]]; then
        case "$key" in
            e|E)
                echo -ne "\r  Enter new server address (IP or hostname): "
                if [[ -c /dev/tty ]]; then
                    read -r NEW_ADDR </dev/tty
                else
                    read -r NEW_ADDR
                fi
                # Strip whitespace
                NEW_ADDR="${NEW_ADDR#"${NEW_ADDR%%[![:space:]]*}"}"
                NEW_ADDR="${NEW_ADDR%"${NEW_ADDR##*[![:space:]]}"}"
                if [[ -n "$NEW_ADDR" ]]; then
                    # Write new address to client config
                    if grep -qi "^destinationAddress[[:space:]]*=" "$CLIENT_CFG" 2>/dev/null; then
                        sed -i "s/^destinationAddress[[:space:]]*=.*/destinationAddress = $NEW_ADDR/" "$CLIENT_CFG"
                    else
                        echo "" >> "$CLIENT_CFG"
                        echo "destinationAddress = $NEW_ADDR" >> "$CLIENT_CFG"
                    fi
                    ok "Server address set to: $NEW_ADDR"
                else
                    NEW_ADDR="$CURRENT_ADDR"
                    info "Keeping current server: $CURRENT_ADDR"
                fi
                break
                ;;
            *)
                # Any other key — continue with current server
                echo ""
                info "Continuing with current server: $CURRENT_ADDR"
                NEW_ADDR="$CURRENT_ADDR"
                break
                ;;
        esac
    fi
done

# If we fell through the loop without keypress, timer expired
if [[ $i -eq 0 ]]; then
    echo ""
    info "Continuing with current server: $CURRENT_ADDR"
    NEW_ADDR="$CURRENT_ADDR"
fi

# Restore terminal settings
stty "$tty_settings" 2>/dev/null || true

echo ""

# ────────────────────────────────────────────────────
# Step 1: install mods with server URL built from address
# ────────────────────────────────────────────────────
export SERVER_URL="http://${NEW_ADDR}:8085"

if bash "$LAYER1/install-mods" 2>/dev/null; then
    ok "Mods installed."
else
    warn "Mod installation skipped or failed — launching client without mod update."
    warn "This is normal if the server is offline or has no mods deployed."
fi

# ────────────────────────────────────────────────────
# Step 2: launch client
# ────────────────────────────────────────────────────
echo ""
bash "$LAYER1/run-client"
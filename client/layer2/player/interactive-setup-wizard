#!/bin/bash
#
# interactive-setup-wizard — Player guided setup wizard
# Layer 2: orchestrates the full setup process step by step
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
CONFIG="$CONFIG_DIR/tes3mp-easy.json"
LAYER1="$PROJECT_DIR/layer1/player"
LAYER1_SHARED="$PROJECT_DIR/layer1/shared"

step_header() {
    local num="$1" total="$2" title="$3"
    echo ""; echo "  ━━━ [${num}/${total}] ${title} ━━━"; echo ""
}

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║      TES3MP Easy — Player Setup Wizard          ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
info "This wizard will guide you through setting up the client."
info "Press Ctrl+C at any time to exit."
echo ""

load_config 2>/dev/null || true

# ────────────────────────────────────
# Section: Configuration
# ────────────────────────────────────
echo ""; echo "  ── Configuration ──"; echo ""

NUM=1; TOTAL=4

# 1. EDITOR
step_header $NUM $TOTAL "Preferred Editor"
input "Enter editor (leave empty for auto-detect)" "${EDITOR:-}" EDITOR_VAL
if [[ -n "$EDITOR_VAL" ]]; then
    bash "$LAYER1_SHARED/edit-config-record" "EDITOR" "$EDITOR_VAL"
fi
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 2. MORROWIND_PATH
step_header $NUM $TOTAL "Morrowind Directory"
while true; do
    input "Enter path to Morrowind directory" "${MORROWIND_PATH:-}" MW_PATH
    if [[ -z "$MW_PATH" ]]; then
        warn "Skipping."
        break
    fi
    bash "$LAYER1_SHARED/edit-config-record" "MORROWIND_PATH" "$MW_PATH"
    resolved="${MW_PATH/#\~/$HOME}"
    if [[ -d "$resolved" ]]; then
        ok "Morrowind directory found: ${resolved}"
        break
    else
        err "Directory not found: ${resolved}"
        confirm "Try again?" "y" || { warn "Skipping."; break; }
    fi
done
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 3. TES3MP_DIR
step_header $NUM $TOTAL "TESMP Directory"
input "Enter TES3MP directory" "${TES3MP_DIR:-games/tes3mp}" T_DIR
if [[ -n "$T_DIR" ]]; then
    bash "$LAYER1_SHARED/edit-config-record" "TES3MP_DIR" "$T_DIR"
fi
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 4. PROTON_PATH
step_header $NUM $TOTAL "Proton Path"
while true; do
    input "Enter path to Proton directory" "${PROTON_PATH:-}" P_PATH
    if [[ -z "$P_PATH" ]]; then
        warn "Skipping."
        break
    fi
    bash "$LAYER1_SHARED/edit-config-record" "PROTON_PATH" "$P_PATH"
    resolved="${P_PATH/#\~/$HOME}"
    if [[ -d "$resolved" ]]; then
        ok "Proton directory found: ${resolved}"
        break
    else
        err "Directory not found: ${resolved}"
        confirm "Try again?" "y" || { warn "Skipping."; break; }
    fi
done
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# ────────────────────────────────────
# Section: Client Setup
# ────────────────────────────────────
echo ""; echo "  ── Client Setup ──"; echo ""

NUM=1; TOTAL=4

# 5. Install client
step_header $NUM $TOTAL "Client Installation"
if [[ -z "${MORROWIND_PATH:-}" ]]; then
    err "MORROWIND_PATH is not set."
elif [[ -z "${TES3MP_DIR:-}" ]]; then
    err "TES3MP_DIR is not set."
else
    confirm "Install / update client now?" "y" && bash "$LAYER1/install-client" || true
fi
NUM=$((NUM + 1))

# 6. Install fonts
step_header $NUM $TOTAL "Fonts"
confirm "Install fonts?" "y" && bash "$PROJECT_DIR/layer2/player/interactive-install-fonts" || true
NUM=$((NUM + 1))

# 7. Configure UI
step_header $NUM $TOTAL "UI Configuration"
bash "$PROJECT_DIR/layer2/player/interactive-configure-ui"
NUM=$((NUM + 1))

# 8. Localization
step_header $NUM $TOTAL "Game Localization"
confirm "Install game localization?" "y" && bash "$PROJECT_DIR/layer2/player/interactive-install-localization" || true

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║            Setup Wizard Complete!                ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
echo "  To launch the game (with mods):"
echo ""
echo "    Player menu:  bash layer3/player.sh"
echo "                  Select \"Install mods & play\""
echo ""
echo "    CLI:          bash layer3/player.sh install-mods-and-play"
echo ""
echo "    Steam:        Add Non-Steam Game →"
echo "                  ~/.local/share/tes3mp-easy/layer3/player.sh"
echo "                  Arguments: install-mods-and-play"
echo ""
echo "    Lutris:       Add game → Launcher: Custom"
echo "                  Command: bash ~/.local/share/tes3mp-easy/layer3/player.sh install-mods-and-play"
echo ""

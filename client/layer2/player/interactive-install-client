#!/bin/bash
#
# interactive-install-client — Install TES3MP client via Proton
# Layer 2: prompts user, calls layer1/player/install-client
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

bash "$PROJECT_DIR/layer1/player/install-client"
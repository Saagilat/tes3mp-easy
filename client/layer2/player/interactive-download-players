#!/bin/bash
#
# interactive-download-players — Download player backup from server
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true

TYPE="players"
LABEL="Players"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Download $LABEL Backup"
echo "═══════════════════════════════════════════════"
echo ""

check_deps jq

json=$(bash "$PROJECT_DIR/layer1/player/show-backups-${TYPE}" 2>/dev/null)
if [[ -z "$json" ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

current_sha256=$(echo "$json" | jq -r '.current // empty' 2>/dev/null)

names=()
sha256s=()
while IFS=$'\t' read -r name sha256; do
    [[ -z "$name" ]] && continue
    names+=("$name")
    sha256s+=("$sha256")
done < <(echo "$json" | jq -r '.files[] | [.name, .sha256] | @tsv' 2>/dev/null)

if [[ ${#names[@]} -eq 0 ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

i=1
for name in "${names[@]}"; do
    idx=$((i - 1))
    if [[ -n "$current_sha256" && "${sha256s[$idx]}" == "$current_sha256" ]]; then
        echo "  $i) $name  (current)"
    else
        echo "  $i) $name"
    fi
    ((i++)) || true
done
echo ""

read -r -p "  Select number (empty = cancel): " choice
[[ -z "$choice" ]] && { info "Cancelled."; exit 0; }

selected="${names[$((choice - 1))]}"
[[ -z "$selected" ]] && { err "Invalid selection."; exit 1; }

echo ""
info "Downloading $selected..."
bash "$PROJECT_DIR/layer1/player/download-backup-${TYPE}" "$selected" || { err "Download failed."; exit 1; }
ok "Done."
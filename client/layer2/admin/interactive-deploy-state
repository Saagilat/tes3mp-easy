#!/bin/bash
#
# interactive-deploy-state — Deploy state backup to VPS
# Layer 2: checks SSH, parses JSON from show-backups, prompts, deploys
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set."
    exit 1
fi

TYPE="state"
LABEL="State"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Deploy $LABEL Backup"
echo "═══════════════════════════════════════════════"
echo ""

check_deps jq

json=$(bash "$PROJECT_DIR/layer1/admin/show-backups-${TYPE}")
rc=$?
if [[ $rc -ne 0 ]]; then
    err "Failed to connect to server. Check your connection and try again."
    exit 1
fi
if [[ -z "$json" ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

# Add --latest option
echo "  0) Use latest backup (--latest)"
echo ""

names=()
while IFS=$'\t' read -r name sha256; do
    [[ -z "$name" ]] && continue
    names+=("$name")
done < <(echo "$json" | jq -r '.files[] | [.name, .sha256] | @tsv' 2>/dev/null)

if [[ ${#names[@]} -eq 0 ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

i=1
for name in "${names[@]}"; do
    echo "  $i) $name"
    ((i++)) || true
done
echo ""

read -r -p "  Select number (empty = cancel): " choice
[[ -z "$choice" ]] && { info "Cancelled."; exit 0; }

if [[ "$choice" == "0" ]]; then
    archive_arg="--latest"
else
    selected="${names[$((choice - 1))]}"
    [[ -z "$selected" ]] && { err "Invalid selection."; exit 1; }
    archive_arg="$selected"
fi

if ! confirm "Deploy $LABEL backup? This will overwrite current data."; then
    info "Cancelled."
    exit 0
fi

echo ""
info "Deploying $archive_arg..."
retry ssh "$SSH_HOST" "cd /tes3mp-easy && bash scripts/deploy_state.sh $archive_arg" || { err "Deploy failed."; exit 1; }
ok "Done."
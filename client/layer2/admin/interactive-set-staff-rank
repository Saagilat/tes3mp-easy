#!/bin/bash
#
# interactive-set-staff-rank — Set staff rank for a player on the server
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set."
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Set Staff Rank"
echo "═══════════════════════════════════════════════"
echo ""

# Get list of player JSON files from server
echo "Fetching player list from $SSH_HOST..."
player_list=$(ssh "$SSH_HOST" "ls -1 /tes3mp-easy/players/*.json 2>/dev/null | xargs -n1 basename -s .json" 2>/dev/null) || {
    err "Failed to fetch player list from server."
    exit 1
}

if [[ -z "$player_list" ]]; then
    warn "No players found on server."
    exit 1
fi

mapfile -t players <<< "$player_list"

if [[ ${#players[@]} -eq 0 ]]; then
    warn "No players found on server."
    exit 1
fi

echo "  Select a player:"
echo ""
i=1
for player in "${players[@]}"; do
    echo "  $i) $player"
    ((i++)) || true
done
echo ""

read -r -p "  Number: " choice
if [[ -z "$choice" || "$choice" -lt 1 || "$choice" -gt "${#players[@]}" ]]; then
    err "Invalid selection."
    exit 1
fi

selected_player="${players[$((choice - 1))]}"
echo ""
info "Selected player: $selected_player"
echo ""
echo "  0) None (regular player)"
echo "  1) Moderator"
echo "  2) Admin"
echo "  3) Owner"
echo ""
read -r -p "  Rank [0-3]: " rank

if [[ "$rank" != "0" && "$rank" != "1" && "$rank" != "2" && "$rank" != "3" ]]; then
    err "Rank must be 0, 1, 2, or 3."
    exit 1
fi

rank_name=""
case "$rank" in
    0) rank_name="None (regular player)" ;;
    1) rank_name="Moderator" ;;
    2) rank_name="Admin" ;;
    3) rank_name="Owner" ;;
esac

echo ""
info "About to set $selected_player rank to $rank ($rank_name)"
echo ""
if ! confirm "  Proceed?" "n"; then
    info "Cancelled."
    exit 0
fi

echo ""
bash "$PROJECT_DIR/layer1/admin/set-staff-rank" "$selected_player" "$rank" || {
    err "Failed to set staff rank."
    exit 1
}
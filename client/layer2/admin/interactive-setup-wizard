#!/bin/bash
#
# interactive-setup-wizard — Admin guided setup wizard
# Layer 2: orchestrates the full server setup
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
CONFIG="$CONFIG_DIR/tes3mp-easy.ini"
LAYER1_ADMIN="$PROJECT_DIR/layer1/admin"
LAYER1_SHARED="$PROJECT_DIR/layer1/shared"
TOTAL=8

step_header() { local num="$1" total="$2" title="$3"; echo ""; echo "  ━━━ [${num}/${total}] ${title} ━━━"; echo ""; }

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║       TES3MP Easy — Admin Setup Wizard          ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
info "This wizard will guide you through setting up the server."
info "Press Ctrl+C at any time to exit."
echo ""

load_config 2>/dev/null || true

# Step 0: EDITOR
step_header 1 $TOTAL "Preferred Editor"
echo ""
echo "  Enter your preferred text editor (or leave empty for auto-detect)."
echo "  Auto-detection order: \$EDITOR → nano → vim → vi"
echo ""
input "Enter editor" "${EDITOR:-}" EDITOR_VAL
if [[ -n "$EDITOR_VAL" ]]; then
    bash "$LAYER1_SHARED/set-editor" "$EDITOR_VAL"
fi
load_config 2>/dev/null || true

# Step 1: SSH_HOST
step_header 2 $TOTAL "SSH Connection"
while true; do
    if [[ -n "${SSH_HOST:-}" ]]; then
        input "Enter SSH host (from ~/.ssh/config)" "$SSH_HOST" SSH_HOST_VAL
    else
        echo ""
        echo "  You need an SSH host configured in ~/.ssh/config."
        echo ""
        input "Enter SSH host" "" SSH_HOST_VAL
    fi
    if [[ -z "$SSH_HOST_VAL" ]]; then
        err "SSH_HOST cannot be empty."
        continue
    fi
    if bash "$LAYER1_ADMIN/set-ssh-host" "$SSH_HOST_VAL"; then
        break
    else
        confirm "Try again?" "y" || { warn "Skipping SSH."; break; }
    fi
done
load_config 2>/dev/null || true

# Step 2: EXPORT_DIR
step_header 3 $TOTAL "Export Directory"
input "Enter path to export directory" "${EXPORT_DIR:-./exports}" EXPORT_DIR_VAL
if [[ -n "$EXPORT_DIR_VAL" ]]; then
    bash "$LAYER1_ADMIN/set-export-dir" "$EXPORT_DIR_VAL"
fi
load_config 2>/dev/null || true

# Step 3: Install server
step_header 4 $TOTAL "Server Installation"
if [[ -z "${SSH_HOST:-}" ]]; then
    warn "SSH_HOST not set — skipping."
else
    if bash "$LAYER1_ADMIN/check-server-installed" 2>/dev/null; then
        server_installed=true
    else
        server_installed=false
    fi
    if $server_installed; then
        ok "Server is already installed."
        if confirm "Re-install / upgrade server?" "n"; then
            bash "$LAYER1_ADMIN/install-server" || err "Installation failed."
        fi
    else
        if confirm "Install server?" "y"; then
            bash "$LAYER1_ADMIN/install-server" || err "Installation failed."
        fi
    fi
fi

# Step 4: Server configuration
step_header 5 $TOTAL "Server Configuration"
bash "$PROJECT_DIR/layer2/admin/interactive-configure-server"

# Step 5: Mods setup
step_header 6 $TOTAL "Mods Setup"
load_config 2>/dev/null || true
if [[ -n "${EXPORT_DIR:-}" ]]; then
    resolved="${EXPORT_DIR/#\~/$HOME}"
    mod_plugins="$resolved/mods/plugins"
    mod_scripts="$resolved/mods/scripts"
    if [[ ! -d "$mod_plugins" ]] || [[ ! -d "$mod_scripts" ]]; then
        if confirm "Create mod directories (plugins + scripts)?" "y"; then
            mkdir -p "$mod_plugins" "$mod_scripts"
            ok "Created mod directories."
        fi
    else
        ok "Mod directories already exist."
    fi
else
    warn "EXPORT_DIR not set — skipping."
fi

# Step 6: Backup directory
step_header 7 $TOTAL "Backup Directory"
echo ""
echo "  Directory where downloaded backup archives will be stored."
echo ""
input "Enter backup directory" "${BACKUP_DIR:-}" BACKUP_VAL
if [[ -n "$BACKUP_VAL" ]]; then
    bash "$LAYER1_SHARED/set-backup-dir" "$BACKUP_VAL"
fi
load_config 2>/dev/null || true

# Step 7: Start server
step_header 8 $TOTAL "Start Server"
if [[ -n "${SSH_HOST:-}" ]]; then
    if confirm "Start server now?" "n"; then
        bash "$LAYER1_ADMIN/start-server" || err "Failed to start server."
    fi
fi

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║            Setup Wizard Complete!                ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
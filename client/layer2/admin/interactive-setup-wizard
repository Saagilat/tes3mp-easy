#!/bin/bash
#
# interactive-setup-wizard — Admin guided setup wizard
# Layer 2: orchestrates the full server setup
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
CONFIG="$CONFIG_DIR/tes3mp-easy.json"
LAYER1_ADMIN="$PROJECT_DIR/layer1/admin"
LAYER1_SHARED="$PROJECT_DIR/layer1/shared"

step_header() { local num="$1" total="$2" title="$3"; echo ""; echo "  ━━━ [${num}/${total}] ${title} ━━━"; echo ""; }

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║       TES3MP Easy — Admin Setup Wizard          ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
info "This wizard will guide you through setting up the server."
info "Press Ctrl+C at any time to exit."
echo ""

load_config 2>/dev/null || true

# ────────────────────────────────────
# Section: Configuration
# ────────────────────────────────────
echo ""; echo "  ── Configuration ──"; echo ""

NUM=1; TOTAL=5

# 1. EDITOR
step_header $NUM $TOTAL "Preferred Editor"
input "Enter editor (leave empty for auto-detect)" "${EDITOR:-}" EDITOR_VAL
if [[ -n "$EDITOR_VAL" ]]; then
    bash "$LAYER1_SHARED/edit-config-record" "EDITOR" "$EDITOR_VAL"
fi
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 2. SSH_HOST
step_header $NUM $TOTAL "SSH Host"
while true; do
    input "Enter SSH host (from ~/.ssh/config)" "${SSH_HOST:-}" SSH_HOST_VAL
    if [[ -z "$SSH_HOST_VAL" ]]; then
        err "SSH_HOST cannot be empty."
        continue
    fi
    bash "$LAYER1_SHARED/edit-config-record" "SSH_HOST" "$SSH_HOST_VAL"
    if ssh -o ConnectTimeout=5 -o BatchMode=yes "$SSH_HOST_VAL" "echo ok" 2>/dev/null; then
        ok "SSH connection successful."
        break
    else
        err "Connection failed."
        confirm "Try again?" "y" || { warn "Skipping SSH."; break; }
    fi
done
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 3. EXPORT_DIR
step_header $NUM $TOTAL "Export Directory"
input "Enter path to export directory" "${EXPORT_DIR:-./exports}" EXPORT_DIR_VAL
if [[ -n "$EXPORT_DIR_VAL" ]]; then
    bash "$LAYER1_SHARED/edit-config-record" "EXPORT_DIR" "$EXPORT_DIR_VAL"
    resolved="${EXPORT_DIR_VAL/#\~/$HOME}"
    if [[ ! -d "$resolved" ]]; then
        mkdir -p "$resolved" 2>/dev/null && ok "Created: ${resolved}" || warn "Could not create: ${resolved}"
    fi
fi
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 4. BACKUP_DIR
step_header $NUM $TOTAL "Backup Directory"
input "Enter backup directory (for downloaded archives)" "${BACKUP_DIR:-}" BACKUP_VAL
if [[ -n "$BACKUP_VAL" ]]; then
    bash "$LAYER1_SHARED/edit-config-record" "BACKUP_DIR" "$BACKUP_VAL"
    resolved="${BACKUP_VAL/#\~/$HOME}"
    if [[ ! -d "$resolved" ]]; then
        mkdir -p "$resolved" 2>/dev/null && ok "Created: ${resolved}" || warn "Could not create: ${resolved}"
    fi
fi
load_config 2>/dev/null || true; NUM=$((NUM + 1))

# 5. Mods directories
step_header $NUM $TOTAL "Mod Directories"
if [[ -n "${EXPORT_DIR:-}" ]]; then
    resolved="${EXPORT_DIR/#\~/$HOME}"
    mod_plugins="$resolved/mods/plugins"
    mod_scripts="$resolved/mods/scripts"
    if [[ ! -d "$mod_plugins" ]] || [[ ! -d "$mod_scripts" ]]; then
        if confirm "Create mod directories (plugins + scripts)?" "y"; then
            mkdir -p "$mod_plugins" "$mod_scripts"
            ok "Created mod directories."
        fi
    else
        ok "Mod directories already exist."
    fi
else
    warn "EXPORT_DIR not set — skipping."
fi
NUM=$((NUM + 1))

# ────────────────────────────────────
# Section: Server Setup
# ────────────────────────────────────
echo ""; echo "  ── Server Setup ──"; echo ""

NUM=1; TOTAL=3

# 6. Install server
step_header $NUM $TOTAL "Server Installation"
if [[ -z "${SSH_HOST:-}" ]]; then
    warn "SSH_HOST not set — skipping."
else
    if bash "$LAYER1_ADMIN/check-server-installed" 2>/dev/null; then
        ok "Server is already installed."
        confirm "Re-install / upgrade server?" "n" && bash "$LAYER1_ADMIN/install-server" || true
    else
        confirm "Install server?" "y" && bash "$LAYER1_ADMIN/install-server" || true
    fi
fi
NUM=$((NUM + 1))

# 7. Configure server
step_header $NUM $TOTAL "Server Configuration"
bash "$PROJECT_DIR/layer2/admin/interactive-configure-server"
NUM=$((NUM + 1))

# 8. Start server
step_header $NUM $TOTAL "Start Server"
if [[ -n "${SSH_HOST:-}" ]]; then
    confirm "Start server now?" "n" && bash "$LAYER1_ADMIN/start-server" || true
fi

echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║            Setup Wizard Complete!                ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""
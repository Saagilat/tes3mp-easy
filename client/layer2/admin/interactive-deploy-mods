#!/bin/bash
#
# interactive-deploy-mods — Deploy mods archive on VPS
# Layer 2: lists archives via layer1 show-backups, prompts, calls layer1 deploy
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set."
    exit 1
fi

TYPE="mods"
LABEL="Mods"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Deploy $LABEL"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Choose archive to deploy (or press Enter for latest):"
echo ""

check_deps jq

# Get archive list from layer1 show-backups JSON
json=$(bash "$PROJECT_DIR/layer1/admin/show-backups-${TYPE}" 2>/dev/null)
if [[ -z "$json" ]]; then
    warn "No archives found on server."
    exit 1
fi

# Extract names from JSON using jq
mapfile -t names < <(echo "$json" | jq -r '.files[].name' 2>/dev/null)

if [[ ${#names[@]} -eq 0 ]]; then
    warn "No archives found on server."
    exit 1
fi

i=1
for name in "${names[@]}"; do
    echo "  $i) $name"
    ((i++)) || true
done
echo ""

read -r -p "  Select number (empty = latest): " choice

if [[ -z "$choice" ]]; then
    archive="${names[0]}"
else
    archive="${names[$((choice - 1))]}"
fi

if [[ -z "$archive" ]]; then
    err "Invalid selection."
    exit 1
fi

info "Deploying: $archive"
bash "$PROJECT_DIR/layer1/admin/deploy-${TYPE}" "$archive" || { err "Deploy failed."; exit 1; }
ok "Deploy queued. Use RESTART to apply."
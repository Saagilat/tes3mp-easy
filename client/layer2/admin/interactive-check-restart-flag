#!/bin/bash
#
# interactive-check-restart-flag — Check if server restart is needed
# Outputs "1" if restart needed, empty string otherwise.
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -n "${SSH_HOST:-}" ]]; then
    running=$(ssh "$SSH_HOST" "cd /tes3mp-easy && docker compose ps --format '{{.State}}' 2>/dev/null | head -1" 2>/dev/null)
    if [[ "$running" == "running" ]]; then
        if ssh "$SSH_HOST" "test -f /tes3mp-easy/needs_restart.flag" 2>/dev/null; then
            echo "1"
        fi
    fi
fi
echo ""
#!/bin/bash
#
# interactive-download-state — Download state backup from VPS
# Layer 2: checks SSH, parses JSON from show-backups, prompts, calls download
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set."
    exit 1
fi

TYPE="state"
LABEL="State"

echo ""
echo "═══════════════════════════════════════════════"
echo "  Download $LABEL Backup"
echo "═══════════════════════════════════════════════"
echo ""

check_deps jq

json=$(bash "$PROJECT_DIR/layer1/admin/show-backups-${TYPE}")
rc=$?
if [[ $rc -ne 0 ]]; then
    err "Failed to connect to server. Check your connection and try again."
    exit 1
fi
if [[ -z "$json" ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

names=()
while IFS=$'\t' read -r name sha256; do
    [[ -z "$name" ]] && continue
    names+=("$name")
done < <(echo "$json" | jq -r '.files[] | [.name, .sha256] | @tsv' 2>/dev/null)

if [[ ${#names[@]} -eq 0 ]]; then
    warn "No $LABEL backups available on server."
    exit 1
fi

i=1
for name in "${names[@]}"; do
    echo "  $i) $name"
    ((i++)) || true
done
echo ""

read -r -p "  Select number (empty = cancel): " choice
[[ -z "$choice" ]] && { info "Cancelled."; exit 0; }

selected="${names[$((choice - 1))]}"
[[ -z "$selected" ]] && { err "Invalid selection."; exit 1; }

echo ""
info "Downloading $selected..."
bash "$PROJECT_DIR/layer1/admin/download-backup-${TYPE}" "$selected" || { err "Download failed."; exit 1; }
ok "Done."
#!/bin/bash
#
# interactive-set-backup-interval — Change backup interval
# Layer 2: prompts for seconds, calls Layer 1 set-backup-interval
#

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
source "$PROJECT_DIR/lib/common"
source "$PROJECT_DIR/lib/config"

load_config 2>/dev/null || true
if [[ -z "${SSH_HOST:-}" ]]; then
    err "SSH_HOST is not set."
    exit 1
fi

echo ""
echo "═══════════════════════════════════════════════"
echo "  Set Backup Interval"
echo "═══════════════════════════════════════════════"
echo ""

read -r -p "  Interval in seconds (empty = cancel): " choice
[[ -z "$choice" ]] && { info "Cancelled."; exit 0; }
[[ "$choice" =~ ^[0-9]+$ ]] || { err "Must be a positive number."; exit 1; }

echo ""
info "Setting backup interval to ${choice}s..."
bash "$PROJECT_DIR/layer1/admin/set-backup-interval" "$choice" || { err "Failed."; exit 1; }
ok "Done."
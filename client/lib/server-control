#!/bin/bash
#
# server-control.sh — start, stop, restart, logs for TES3MP server
#
# Provides:
#   - server_start()
#   - server_stop()
#   - server_restart()
#   - server_logs()
#   - server_status()
#   - needs_restart_set()
#   - needs_restart_clear()
#   - needs_restart_check()
#

if [[ -z "${LIB_DIR:-}" ]]; then
    echo "ERROR: common.sh must be sourced before server-control.sh" >&2
    exit 1
fi

# ────────────────────────────────────────────────────────────
# Helper: check SSH_HOST
# ────────────────────────────────────────────────────────────
require_ssh_host() {
    if [[ -z "${SSH_HOST:-}" ]]; then
        return 1
    fi
}

# ────────────────────────────────────────────────────────────
# Helper: run docker compose command
# ────────────────────────────────────────────────────────────
docker_compose() {
    local action="$1"
    local tty_flag="${2:-}"
    local cmd="cd /tes3mp-easy && docker compose $action"

    info "Running on $SSH_HOST: $cmd"
    echo ""

    if [[ -n "$tty_flag" ]]; then
        ssh -t "$SSH_HOST" "$cmd"
    else
        ssh "$SSH_HOST" "$cmd"
    fi
    return $?
}

# ────────────────────────────────────────────────────────────
# needs_restart_set — mark server as needing a restart
# ────────────────────────────────────────────────────────────
needs_restart_set() {
    require_ssh_host || return 1
    ssh "$SSH_HOST" "touch /tes3mp-easy/needs_restart.flag" 2>/dev/null || true
}

# ────────────────────────────────────────────────────────────
# needs_restart_clear — clear the restart flag
# ────────────────────────────────────────────────────────────
needs_restart_clear() {
    require_ssh_host || return 1
    ssh "$SSH_HOST" "rm -f /tes3mp-easy/needs_restart.flag" 2>/dev/null || true
}

# ────────────────────────────────────────────────────────────
# needs_restart_check — returns 0 if restart needed, 1 if not
# ────────────────────────────────────────────────────────────
needs_restart_check() {
    if [[ -z "${SSH_HOST:-}" ]]; then
        return 1
    fi
    ssh "$SSH_HOST" "test -f /tes3mp-easy/needs_restart.flag" 2>/dev/null
}

# ────────────────────────────────────────────────────────────
# server_start — start TES3MP containers
# ────────────────────────────────────────────────────────────
server_start() {
    require_ssh_host || return 1
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  Starting TES3MP Server"
    echo "═══════════════════════════════════════════════"
    echo ""
    docker_compose "up -d" || {
        err "Failed to start server on $SSH_HOST"
        return 1
    }
    needs_restart_clear
    ok "Server started on $SSH_HOST"
}

# ────────────────────────────────────────────────────────────
# server_stop — stop TES3MP containers
# ────────────────────────────────────────────────────────────
server_stop() {
    require_ssh_host || return 1
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  Stopping TES3MP Server"
    echo "═══════════════════════════════════════════════"
    echo ""
    docker_compose "down" || {
        err "Failed to stop server on $SSH_HOST"
        return 1
    }
    ok "Server stopped on $SSH_HOST"
}

# ────────────────────────────────────────────────────────────
# server_restart — restart TES3MP containers
# ────────────────────────────────────────────────────────────
server_restart() {
    require_ssh_host || return 1
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  Restarting TES3MP Server"
    echo "═══════════════════════════════════════════════"
    echo ""
    docker_compose "restart" || {
        err "Failed to restart server on $SSH_HOST"
        return 1
    }
    needs_restart_clear
    ok "Server restarted on $SSH_HOST"
}

# ────────────────────────────────────────────────────────────
# server_logs — follow TES3MP container logs
# ────────────────────────────────────────────────────────────
server_logs() {
    require_ssh_host || return 1
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  TES3MP Server Logs (press Ctrl+C to stop)"
    echo "═══════════════════════════════════════════════"
    echo ""
    info "Connecting to $SSH_HOST..."
    echo ""
    docker_compose "logs -f" "-t"
}

# ────────────────────────────────────────────────────────────
# server_status — show container status
# ────────────────────────────────────────────────────────────
server_status() {
    require_ssh_host || return 1
    echo ""
    echo "═══════════════════════════════════════════════"
    echo "  TES3MP Server Status"
    echo "═══════════════════════════════════════════════"
    echo ""
    docker_compose "ps"
}
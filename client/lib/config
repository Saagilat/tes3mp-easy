#!/bin/bash
#
# config.sh — tes3mp-easy configuration (JSON format)
#
# Single config file:
#   ~/.config/tes3mp-easy/tes3mp-easy.json
#
# All settings (shared, admin, player) are stored in one file.
# Format: {"KEY":"value","KEY2":"value2"}
#
# Loaded via parse_json (safe, no bash execution).
# Editing via write_config (atomic, uses jq).
#
# NOTE: This file must be sourced AFTER common.sh.
# NOTE: Requires jq.
#

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
SHARED_CONFIG="$CONFIG_DIR/tes3mp-easy.json"
CONFIG="$SHARED_CONFIG"
INI_LEGACY="${CONFIG_DIR}/tes3mp-easy.ini"

# ────────────────────────────────────────────────────────────
# migrate_from_ini — migrate old INI config to JSON
# If tes3mp-easy.ini exists and tes3mp-easy.json does not,
# read the INI, write JSON, remove INI.
# ────────────────────────────────────────────────────────────
migrate_from_ini() {
    [[ -f "$SHARED_CONFIG" ]] && return 0
    [[ -f "$INI_LEGACY" ]] || return 0

    info "Migrating config from INI to JSON format..."

    local entries=()
    local key value
    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" == \#* || "$line" == \;* ]] && continue
        [[ "$line" == \[* ]] && continue

        if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*=[[:space:]]*(.*) ]]; then
            key="${BASH_REMATCH[1]}"
            value="${BASH_REMATCH[2]}"
            # strip surrounding quotes if present
            if [[ "$value" == \"*\" ]]; then
                value="${value#\"}"; value="${value%\"}"
            elif [[ "$value" == \'*\' ]]; then
                value="${value#\'}"; value="${value%\'}"
            fi
            entries+=("--arg" "$key" "$value")
        fi
    done < "$INI_LEGACY"

    if [[ ${#entries[@]} -gt 0 ]]; then
        jq -n "${entries[@]}" '{} + $ARGS.named' > "$SHARED_CONFIG" 2>/dev/null && {
            rm "$INI_LEGACY"
            ok "Migrated to JSON config: $SHARED_CONFIG"
        } || {
            warn "Migration failed — keeping old INI config."
            return 1
        }
    else
        echo '{}' > "$SHARED_CONFIG"
        rm "$INI_LEGACY"
        ok "Created empty JSON config (migrated empty INI)."
    fi
}

# ────────────────────────────────────────────────────────────
# parse_json — parse key=value from JSON file (safe, uses jq)
# Usage: parse_json <file>
# Sets variables in current shell.
# ────────────────────────────────────────────────────────────
parse_json() {
    local file="$1"
    local key value

    [[ -f "$file" ]] || return 1
    command -v jq &>/dev/null || { err "jq is required but not found."; return 1; }

    while IFS=$'\t' read -r key value; do
        printf -v "$key" "%s" "$value"
    done < <(jq -r 'to_entries | .[] | [.key, .value] | @tsv' "$file" 2>/dev/null) || return 1
}

# ────────────────────────────────────────────────────────────
# write_config — atomically set a key=value in JSON config
# Usage: write_config <key> <value>
# ────────────────────────────────────────────────────────────
write_config() {
    local key="$1" value="$2"
    command -v jq &>/dev/null || { err "jq is required but not found."; return 1; }

    [[ -f "$SHARED_CONFIG" ]] || echo '{}' > "$SHARED_CONFIG"

    local tmp
    tmp=$(mktemp) || { err "Failed to create temp file."; return 1; }

    if jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$SHARED_CONFIG" > "$tmp" 2>/dev/null; then
        mv "$tmp" "$SHARED_CONFIG"
        return 0
    else
        err "Failed to write config key: $key"
        rm -f "$tmp"
        return 1
    fi
}

# ────────────────────────────────────────────────────────────
# load_config — load config file
# Usage: load_config
# Loads the tes3mp-easy.json (if exists). Handles INI→JSON migration.
# ────────────────────────────────────────────────────────────
load_config() {
    if [[ $# -gt 0 ]]; then
        err "load_config: does not accept arguments (got: $*)"
        return 1
    fi

    migrate_from_ini

    if [[ -f "$SHARED_CONFIG" ]]; then
        parse_json "$SHARED_CONFIG" && return 0
    fi
    return 1
}

# ────────────────────────────────────────────────────────────
# find_editor — detect available text editor
# Order: EDITOR env → VISUAL → EDITOR var → nano → vim → vi
# ────────────────────────────────────────────────────────────
find_editor() {
    local cfg_editor="${EDITOR:-}"
    if [[ -n "$cfg_editor" ]] && command -v "$cfg_editor" &>/dev/null; then
        echo "$cfg_editor"
        return 0
    fi
    for e in "$VISUAL" "$EDITOR" nano vim vi; do
        if [[ -n "$e" ]] && command -v "$e" &>/dev/null; then
            echo "$e"
            return 0
        fi
    done
    echo "vi"
}

# ────────────────────────────────────────────────────────────
# edit_config — open config in detected editor
# Usage: edit_config
# ────────────────────────────────────────────────────────────
edit_config() {
    if [[ ! -f "$SHARED_CONFIG" ]]; then
        err "Config file not found. Re-run the install script."
        return 1
    fi

    # Load config so EDITOR from JSON is available to find_editor
    load_config 2>/dev/null || true

    local editor
    editor=$(find_editor)
    info "Opening with: $editor"
    "$editor" "$SHARED_CONFIG"
    ok "Config file saved."
}

# ────────────────────────────────────────────────────────────
# Entry point for direct execution (admin-settings / player-settings)
# ────────────────────────────────────────────────────────────
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    source "$SCRIPT_DIR/common"

    edit_config
fi
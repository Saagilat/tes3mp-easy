#!/bin/bash
#
# config.sh — tes3mp-easy configuration (INI format)
#
# Single config file:
#   ~/.config/tes3mp-easy/tes3mp-easy.ini
#
# All settings (shared, admin, player) are stored in one file.
# Format:
#   ; comment
#   KEY = value
#
# Loaded via parse_ini (safe, no bash execution).
#
# NOTE: This file must be sourced AFTER common.sh.

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy"
SHARED_CONFIG="$CONFIG_DIR/tes3mp-easy.ini"
CONFIG="$SHARED_CONFIG"

# ────────────────────────────────────────────────────────────
# parse_ini — parse key=value from a file (safe, no source)
# Usage: parse_ini <file> [prefix]
# ────────────────────────────────────────────────────────────
parse_ini() {
    local file="$1"
    local prefix="${2:-}"
    local key value

    [[ -f "$file" ]] || return 1

    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" == \#* || "$line" == \;* ]] && continue
        [[ "$line" == \[* ]] && continue

        if [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)[[:space:]]*=[[:space:]]*(.*) ]]; then
            key="${BASH_REMATCH[1]}"
            value="${BASH_REMATCH[2]}"
            case "$value" in
                \"*\") value="${value#\"}"; value="${value%\"}" ;;
                \'*\') value="${value#\'}"; value="${value%\'}" ;;
            esac
            printf -v "${prefix}${key}" "%s" "$value"
        fi
    done < "$file"
}

# ────────────────────────────────────────────────────────────
# load_config — load config file
# Usage: load_config
# Loads the single tes3mp-easy.ini (if exists).
# ────────────────────────────────────────────────────────────
load_config() {
    [[ -f "$SHARED_CONFIG" ]] && parse_ini "$SHARED_CONFIG" && return 0
    return 1
}

# ────────────────────────────────────────────────────────────
# find_editor — detect available text editor
# Order: EDITOR env → VISUAL → EDITOR var → nano → vim → vi
# ────────────────────────────────────────────────────────────
find_editor() {
    local cfg_editor="${EDITOR:-}"
    if [[ -n "$cfg_editor" ]] && command -v "$cfg_editor" &>/dev/null; then
        echo "$cfg_editor"
        return 0
    fi
    for e in "$VISUAL" "$EDITOR" nano vim vi; do
        if [[ -n "$e" ]] && command -v "$e" &>/dev/null; then
            echo "$e"
            return 0
        fi
    done
    echo "vi"
}

# ────────────────────────────────────────────────────────────
# edit_config — open config in detected editor
# Usage: edit_config
# ────────────────────────────────────────────────────────────
edit_config() {
    if [[ ! -f "$SHARED_CONFIG" ]]; then
        err "Config file not found. Re-run the install script."
        return 1
    fi

    # Load config so EDITOR from INI is available to find_editor
    load_config 2>/dev/null || true

    local editor
    editor=$(find_editor)
    info "Opening with: $editor"
    "$editor" "$SHARED_CONFIG"
    ok "Config file saved."
}

# ────────────────────────────────────────────────────────────
# Entry point for direct execution (admin-settings / player-settings)
# ────────────────────────────────────────────────────────────
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    source "$SCRIPT_DIR/common"

    edit_config
fi

#!/bin/bash
#
# log — Logging subsystem for tes3mp-easy
#
# Usage:
#   source "$SCRIPT_DIR/lib/log"
#
# Provides:
#   _LOG_FILE          — path to current log file
#   log_file           — prints current log file path
#   run_logged CMD     — runs CMD, captures stdout+stderr to console and log
#
# When sourced, automatically creates:
#   ~/.config/tes3mp-easy/logs/YYYY-MM-DD/HH-MM-SS_<script-name>.log
#
# All subsequent err/ok/warn/info calls (from lib/common) write to this file.
#

# ────────────────────────────────────────────────────────────
# Configuration
# ────────────────────────────────────────────────────────────
_LOG_BASE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/logs"

# ────────────────────────────────────────────────────────────
# _log_date_dir — returns YYYY-MM-DD for folder structure
# ────────────────────────────────────────────────────────────
_log_date_dir() {
    date '+%Y-%m-%d'
}

# ────────────────────────────────────────────────────────────
# _log_time_stamp — returns HH-MM-SS for file name prefix
# ────────────────────────────────────────────────────────────
_log_time_stamp() {
    date '+%H-%M-%S'
}

# Avoid re-initialisation if already sourced
if [[ -z "${_LOG_INITIALISED:-}" ]]; then

    # ──────────── Determine script name (from top-level script) ──
    # $0 is the script that was executed, not sourced
    _LOG_SCRIPT_NAME="$(basename "$0" 2>/dev/null || echo "unknown")"
    _LOG_SCRIPT_NAME="${_LOG_SCRIPT_NAME%.*}"  # strip .sh

    # ──────────── Date/time folders and file ──────────────
    _LOG_DATE_DIR="$(_log_date_dir)"
    _LOG_TIME_STAMP="$(_log_time_stamp)"

    _LOG_DAY_DIR="$_LOG_BASE_DIR/$_LOG_DATE_DIR"
    _LOG_FILE="$_LOG_DAY_DIR/${_LOG_TIME_STAMP}_${_LOG_SCRIPT_NAME}.log"

    # Ensure directory exists
    mkdir -p "$_LOG_DAY_DIR"

    # Write opening header
    {
        echo "═══════════════════════════════════════════════════════════════════"
        echo "  Script:  ${_LOG_SCRIPT_NAME}"
        echo "  Started: ${_LOG_TIME_STAMP//_/ }"
        echo "  PID:     $$"
        echo "═══════════════════════════════════════════════════════════════════"
        echo ""
    } >> "$_LOG_FILE"

    _LOG_INITIALISED=1
fi

# ────────────────────────────────────────────────────────────
# _log_write — internal: append one line to log file
# Arguments:
#   $1  level   (ERROR, OK, WARN, INFO, DEBUG)
#   $2+ message
# ────────────────────────────────────────────────────────────
_log_write() {
    local level="$1"
    shift
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[${ts}] [${level}] $*" >> "$_LOG_FILE"
}

# ────────────────────────────────────────────────────────────
# log_file — prints absolute path to the current log file
# ────────────────────────────────────────────────────────────
log_file() {
    echo "$_LOG_FILE"
}

# ────────────────────────────────────────────────────────────
# run_logged — run a command, tee stdout+stderr to log file
# Usage:
#   run_logged command [args...]
# Returns: exit code of the command
# ────────────────────────────────────────────────────────────
run_logged() {
    local rc
    # Header in log
    _log_write "CMD" "→ $*"
    # Run with tee (both streams to console and log)
    "$@" 2>&1 | tee -a "$_LOG_FILE"
    rc="${PIPESTATUS[0]}"
    _log_write "CMD" "← exit code ${rc}"
    return "$rc"
}
#!/bin/bash
#
# menu-nav.sh — TUI menu navigation engine (pure bash, no whiptail)
#

[ -z "${LIB_DIR:-}" ] && LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)" 2>/dev/null || true

# Load theme
if [[ -f "$LIB_DIR/theme.ini" ]]; then
    while IFS='=' read -r key val; do
        key="${key// /}"
        val="${val# }"
        [[ -z "$key" || "$key" == \;* || "$key" == \#* ]] && continue
        case "$key" in THEME_*) eval "$key=\"\$val\"" ;; esac
    done < "$LIB_DIR/theme.ini"
fi

THEME_MENU_WIDTH="${THEME_MENU_WIDTH:-64}"
THEME_BORDER_TL="${THEME_BORDER_TL:-╭}"
THEME_BORDER_TR="${THEME_BORDER_TR:-╮}"
THEME_BORDER_BL="${THEME_BORDER_BL:-╰}"
THEME_BORDER_BR="${THEME_BORDER_BR:-╯}"
THEME_BORDER_H="${THEME_BORDER_H:-─}"
THEME_BORDER_V="${THEME_BORDER_V:-│}"

T_RESET=$'\033[0m'
T_LABEL=$'\033['"${THEME_LABEL:-36}"'m'
T_ACCENT=$'\033['"${THEME_ACCENT:-33}"'m'

W="$THEME_MENU_WIDTH"
H="$THEME_BORDER_H"
V="$THEME_BORDER_V"
TL="$THEME_BORDER_TL"
TR="$THEME_BORDER_TR"
BL="$THEME_BORDER_BL"
BR="$THEME_BORDER_BR"

# Compute inner widths dynamically based on border characters (wc -m for multi-byte)
_V_LEN=$(printf "%s" "$V" | wc -m)
CONTENT_SIDE_W=$(( _V_LEN * 2 ))
CONTENT_W=$(( W - CONTENT_SIDE_W ))

# ────────────────────────────────────────────────────────────
# press_enter — wait for user to press Enter, then clear prompt
# (Layer 2 only — not in common.sh)
# ────────────────────────────────────────────────────────────
press_enter() {
    echo ""
    read -r -p "  Press Enter to continue..."
    printf "\033[1A\033[K"
    printf "\033[1A\033[K"
}

print_boxed_header() {
    local title="$1"
    local line
    printf -v line "%*s" $((CONTENT_W - 2)) ""
    line="${line// /─}"
    echo ""
    printf "  ${T_LABEL}${title}${T_RESET}\n"
    printf "  ${T_LABEL}${line}${T_RESET}\n"
}

# ─── Global terminal state ───
_M_SAVED_STTY=""

_m_restore_tty() {
    if [[ -n "$_M_SAVED_STTY" ]]; then
        stty "$_M_SAVED_STTY" 2>/dev/null || true
        _M_SAVED_STTY=""
    fi
}

_m_read_key() {
    _M_SAVED_STTY=$(stty -g 2>/dev/null || echo "")
    trap _m_restore_tty EXIT INT TERM
    stty raw -echo -icanon 2>/dev/null

    # Read 1 byte (blocks). Enter = empty string (0 bytes).
    local key
    key=$(dd bs=1 count=1 2>/dev/null; echo x)
    key="${key%x}"

    # If ESC, read up to 2 more bytes (arrow sequence)
    if [[ -z "$key" ]]; then
        # Enter — leave empty
        :
    elif [[ "$key" == $'\e' ]]; then
        local seq
        seq=$(dd bs=1 count=2 2>/dev/null; echo x)
        seq="${seq%x}"
        key="$key$seq"
    fi

    _m_restore_tty
    printf "%s" "$key"
}

run_menu() {
    local menu_title="$1"
    shift
    local ssh_host="${1:-}"
    shift
    local modpack="${1:-}"
    shift
    local config_file="${1:-}"
    shift
    local needs_restart="${1:-}"
    shift
    local server_status="${1:-}"
    shift
    local items=("$@")

    # Force terminal back to sane
    stty sane 2>/dev/null || true

    local -a v_labels=()
    local -a v_types=()
    local -a v_actions=()

    local i
    for ((i=0; i<${#items[@]}; i++)); do
        local item="${items[$i]}"
        local label="${item%%|*}"
        local rest="${item#*|}"
        local type="${rest%%|*}"
        local action="${rest#*|}"
        v_labels+=("$label")
        v_types+=("$type")
        v_actions+=("$action")
    done

    local count=${#v_labels[@]}
    local cursor=0

    local -a fn_map=()
    for ((i=0; i<count; i++)); do
        [[ "${v_types[$i]}" == "fn" ]] && fn_map+=($i)
    done
    local fn_total=${#fn_map[@]}

    # Start cursor on first selectable item
    [[ $fn_total -gt 0 ]] && cursor=${fn_map[0]}

    # Functions that should NOT show "Press Enter" pause
    # Must match the exact function names (from layer2 or layer3)
    _NO_PAUSE_ACTIONS=(
        "switch_to_player"
        "interactive_edit_server_cfg"
        "interactive_edit_lua"
        "interactive_edit_banlist"
        "interactive_edit_config"
    )

    _should_pause() {
        local fn="$1"
        local name="${fn%% *}"
        for na in "${_NO_PAUSE_ACTIONS[@]}"; do
            [[ "$na" == "$name" ]] && return 1
        done
        return 0
    }

    while true; do
        printf "\033[H\033[J"

        print_boxed_header "$menu_title"

        echo ""
        if [[ -n "$ssh_host" ]]; then
            printf "  ${T_LABEL}Host:${T_RESET} ${ssh_host}\n"
            if [[ -n "$server_status" ]]; then
                printf "  ${T_LABEL}Server:${T_RESET} ${server_status}"
                if [[ "$needs_restart" == "1" ]]; then
                    printf " [!] Restart required"
                fi
                printf "\n"
            fi
        fi
        if [[ -n "$modpack" ]]; then
            printf "  ${T_LABEL}Mods:${T_RESET} ${modpack}\n"
        fi
        echo ""

        local fn_counter=0
        for ((i=0; i<count; i++)); do
            local typ="${v_types[$i]}"
            local lbl="${v_labels[$i]}"

            if [[ "$typ" == "sep" ]]; then
                local sep_line
                local sep_len
                sep_len=$(printf "%s" "$lbl" | wc -m)
                printf -v sep_line "%*s" $((CONTENT_W - 7 - sep_len)) ""
                sep_line="${sep_line// /$H}"
                printf "  ${T_LABEL}${H}${H}${H} ${lbl} ${sep_line}${T_RESET}\n"
            elif [[ "$typ" == "fn" ]]; then
                fn_counter=$((fn_counter + 1))
                if [[ $i -eq $cursor ]]; then
                    printf "  ${T_ACCENT}%2d) %s${T_RESET}\n" "$fn_counter" "$lbl"
                else
                    printf "  %2d) %s\n" "$fn_counter" "$lbl"
                fi
            fi
        done

        printf "\n  ↑↓ navigate · Enter select · Ctrl+C exit\n"

        # ─── Read key via raw terminal ───
        local key
        key=$(_m_read_key)

        # Ctrl+C (0x03) — exit
        if [[ "$key" == $'\x03' ]]; then
            exit 0
        fi

        # Empty = Enter — select
        if [[ -z "$key" ]]; then
            local typ="${v_types[$cursor]}"
            local action="${v_actions[$cursor]}"

            if [[ "$typ" == "fn" ]]; then
                "$action"

                _should_pause "$action" && press_enter

                if [[ -n "$config_file" && -f "$config_file" ]]; then
                    source "$config_file" 2>/dev/null || true
                    ssh_host="${SSH_HOST:-}"
                    modpack="${EXPORT_DIR:-}"
                    load_lang "${LANG_CODE:-en}" 2>/dev/null || true
                fi
                if [[ -n "$ssh_host" ]]; then
                    needs_restart=$(interactive_check_restart_flag)
                    server_status=$(interactive_check_server_status)
                fi
            fi
            continue
        fi

        # Up arrow
        if [[ "$key" == $'\e[A' ]]; then
            if [[ $fn_total -gt 0 ]]; then
                local cur_fn_idx=0
                for ((i=0; i<fn_total; i++)); do
                    [[ ${fn_map[$i]} -eq $cursor ]] && { cur_fn_idx=$i; break; }
                done
                cur_fn_idx=$((cur_fn_idx - 1))
                [[ $cur_fn_idx -lt 0 ]] && cur_fn_idx=$((fn_total - 1))
                cursor=${fn_map[$cur_fn_idx]}
            fi
            continue
        fi

        # Down arrow
        if [[ "$key" == $'\e[B' ]]; then
            if [[ $fn_total -gt 0 ]]; then
                local cur_fn_idx=0
                for ((i=0; i<fn_total; i++)); do
                    [[ ${fn_map[$i]} -eq $cursor ]] && { cur_fn_idx=$i; break; }
                done
                cur_fn_idx=$((cur_fn_idx + 1))
                [[ $cur_fn_idx -ge $fn_total ]] && cur_fn_idx=0
                cursor=${fn_map[$cur_fn_idx]}
            fi
            continue
        fi

        # Any other key — also select (Space, letters, etc.)
        local typ="${v_types[$cursor]}"
        local action="${v_actions[$cursor]}"

        if [[ "$typ" == "fn" ]]; then
            "$action"

            _should_pause "$action" && press_enter

            if [[ -n "$config_file" && -f "$config_file" ]]; then
                source "$config_file" 2>/dev/null || true
                ssh_host="${SSH_HOST:-}"
                modpack="${EXPORT_DIR:-}"
                load_lang "${LANG_CODE:-en}" 2>/dev/null || true
            fi
            if [[ -n "$ssh_host" ]]; then
                needs_restart=$(interactive_check_restart_flag)
                server_status=$(interactive_check_server_status)
            fi
        fi
    done
}

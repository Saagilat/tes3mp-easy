#!/bin/bash
#
# common.sh — shared utilities for tes3mp-easy scripts
#

_LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$_LIB_DIR/log"
unset _LIB_DIR

# ────────────────────────────────────────────────────────────
# err — print error message to stderr + log
# Usage: err "message"
# ────────────────────────────────────────────────────────────
err() {
    echo -e "\033[0;31m[ERROR]\033[0m $*" >&2
    _log_write "ERROR" "$*"
}

# ────────────────────────────────────────────────────────────
# ok — print success message + log
# Usage: ok "message"
# ────────────────────────────────────────────────────────────
ok() {
    echo -e "\033[0;32m[OK]\033[0m   $*"
    _log_write "OK" "$*"
}

# ────────────────────────────────────────────────────────────
# warn — print warning message + log
# Usage: warn "message"
# ────────────────────────────────────────────────────────────
warn() {
    echo -e "\033[1;33m[WARN]\033[0m $*"
    _log_write "WARN" "$*"
}

# ────────────────────────────────────────────────────────────
# info — print info message + log
# Usage: info "message"
# ────────────────────────────────────────────────────────────
info() {
    echo -e "\033[0;34m[INFO]\033[0m $*"
    _log_write "INFO" "$*"
}

# ────────────────────────────────────────────────────────────
# check_deps — ensure required commands exist
# Usage: check_deps curl ssh scp ...
# ────────────────────────────────────────────────────────────
check_deps() {
    local missing=0
    for cmd in "$@"; do
        if ! command -v "$cmd" &>/dev/null; then
            err "'$cmd' not found. Install it and try again."
            missing=1
        fi
    done
    if [[ "$missing" -ne 0 ]]; then
        exit 1
    fi
}

# ────────────────────────────────────────────────────────────
# _resolve_ssh_host_ip — resolve SSH host alias to IP address
# Reads ~/.ssh/config and extracts HostName for the given host.
# Usage: ip=$(_resolve_ssh_host_ip "myhost") || echo "not found"
# Returns: IP address on stdout, exits 1 if not found
# ────────────────────────────────────────────────────────────
_resolve_ssh_host_ip() {
    local host="${1:-}"
    [[ -z "$host" ]] && { err "Usage: _resolve_ssh_host_ip <host>"; return 1; }

    local ssh_config
    for f in "$HOME/.ssh/config" "$HOME/.ssh/config.d/config" /etc/ssh/ssh_config; do
        [[ -f "$f" ]] && { ssh_config="$f"; break; }
    done

    [[ -z "$ssh_config" ]] && { err "No SSH config found"; return 1; }

    local in_host=0
    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"  # trim leading spaces
        line="${line%"${line##*[![:space:]]}"}"  # trim trailing spaces
        [[ -z "$line" ]] && continue
        [[ "$line" == \#* ]] && continue

        if [[ "$line" =~ ^[Hh][Oo][Ss][Tt][[:space:]]+(.+)$ ]]; then
            # Extract all host globs
            local hosts="${BASH_REMATCH[1]}"
            in_host=0
            local h
            for h in $hosts; do
                if [[ "$h" == "$host" ]]; then
                    in_host=1
                    break
                fi
            done
            continue
        fi

        if [[ "$in_host" -eq 1 && "$line" =~ ^[Hh][Oo][Ss][Tt][Nn][Aa][Mm][Ee][[:space:]]+(.+)$ ]]; then
            echo "${BASH_REMATCH[1]}"
            return 0
        fi
    done < "$ssh_config"

    # If not found in SSH config, treat as direct hostname/IP
    echo "$host"
    return 0
}

# ────────────────────────────────────────────────────────────
# _get_server_url — build mod server URL from TES3MP config
# Parses destinationAddress from tes3mp-client-default.cfg
# or tes3mp-server-default.cfg and builds http://addr:8085
# Usage: _get_server_url
# Returns: URL string or empty string on failure
# ────────────────────────────────────────────────────────────
_get_server_url() {
    local cfg addr port tes3mp_dir

    # Try already-loaded variable first (from load_config in config.sh)
    if [[ -z "${TES3MP_DIR:-}" ]]; then
        # Read TES3MP_DIR from JSON config using jq
        local config="${XDG_CONFIG_HOME:-$HOME/.config}/tes3mp-easy/tes3mp-easy.json"
        if command -v jq &>/dev/null && [[ -f "$config" ]]; then
            tes3mp_dir=$(jq -r '.TES3MP_DIR // empty' "$config" 2>/dev/null)
            tes3mp_dir="${tes3mp_dir/#\~/$HOME}"
        fi
    else
        tes3mp_dir="$TES3MP_DIR"
    fi

    if [[ -n "$tes3mp_dir" ]] && [[ -f "$tes3mp_dir/tes3mp-client-default.cfg" ]]; then
        cfg="$tes3mp_dir/tes3mp-client-default.cfg"
    fi

    if [[ -z "$cfg" ]] && [[ -f "/tes3mp-easy/configs/tes3mp-server-default.cfg" ]]; then
        cfg="/tes3mp-easy/configs/tes3mp-server-default.cfg"
    fi
    if [[ -z "$cfg" ]]; then
        return 1
    fi

    addr=$(grep -i "^destinationAddress[[:space:]]*=" "$cfg" 2>/dev/null | head -1 | sed 's/.*=[[:space:]]*//' | tr -d '\r')
    if [[ -z "$addr" ]]; then
        return 1
    fi

    echo "http://${addr}:8085"
    return 0
}

# ────────────────────────────────────────────────────────────
# _get_server_id — extract server ID from a URL or hostname
# Strips protocol, port, and special chars to get a clean folder name.
# Usage: id=$(_get_server_id "$URL")   # from http://host:8085 → host
#        id=$(_get_server_id "$HOST")  # from user@host → host
# Returns: clean server id string (e.g. "myserver.com")
# ────────────────────────────────────────────────────────────
_get_server_id() {
    local input="${1:-}"
    [[ -z "$input" ]] && { echo ""; return 1; }
    # Strip protocol, user@, port, trailing slashes, and leading slashes
    echo "$input" | sed -E 's|^https?://||; s|^[^@]+@||; s|:?[0-9]*/?$||; s|^[/]+||; s|[/:]+|_|g'
}

# ────────────────────────────────────────────────────────────
# Utility: is_os — check operating system
# Usage:  is_os "linux"  && echo "Linux detected"
#         is_os "windows" && echo "Git Bash / MSYS2 / Cygwin"
# ────────────────────────────────────────────────────────────
is_os() {
    local os="${1,,}"
    local uname_s
    uname_s="$(uname -s)"
    case "$os" in
        linux)
            [[ "$uname_s" == "Linux" ]] && return 0 || return 1
            ;;
        macos|darwin)
            [[ "$uname_s" == "Darwin" ]] && return 0 || return 1
            ;;
        windows)
            [[ "$uname_s" =~ ^(MINGW|MSYS|CYGWIN) ]] && return 0 || return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# ────────────────────────────────────────────────────────────
# verify_archive — check if a tar archive is valid
# Usage: verify_archive <file.tar>
# Returns: 0 if valid, 1 if corrupted/missing
# ────────────────────────────────────────────────────────────
verify_archive() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "File not found: $file" >&2
        return 1
    fi
    tar -tf "$file" >/dev/null 2>&1
}

# ────────────────────────────────────────────────────────────
# retry — execute a command with retries on failure
# Output: stdout passthrough; stderr for retry messages (no ANSI — Layer 1 compliant)
# Returns: exit code of the command
# Usage: retry [-n N] [-d SEC] command [args...]
#   -n N  — max attempts (default: 3)
#   -d SEC — delay between attempts (default: 2)
# ────────────────────────────────────────────────────────────
retry() {
    local max_attempts=3 delay=2

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) max_attempts="$2"; shift 2 ;;
            -d) delay="$2"; shift 2 ;;
            --) shift; break ;;
            *) break ;;
        esac
    done

    local attempt=1 rc
    while [[ $attempt -le $max_attempts ]]; do
        if [[ $attempt -gt 1 ]]; then
            echo "Retry $attempt/$max_attempts after ${delay}s..." >&2
        fi
        "$@" && return 0 || rc=$?
        sleep "$delay"
        ((attempt++)) || true
    done
    echo "Command failed after $max_attempts attempts." >&2
    return "$rc"
}

# ────────────────────────────────────────────────────────────
# input — interactive text input prompt
# Reads from /dev/tty if available, otherwise falls back to stdin.
# Usage: input "Prompt: " "default_value" VARNAME
# Sets VARNAME to user input, or to default if user pressed Enter.
# ────────────────────────────────────────────────────────────
input() {
    local prompt="$1" default="$2" var_name="$3"
    local input_val=""

    if [[ -c /dev/tty ]]; then
        read -r -p "$prompt [$default]: " input_val </dev/tty || true
    elif [[ -t 0 ]]; then
        read -r -p "$prompt [$default]: " input_val || true
    else
        err "Interactive input required but no TTY available."
        return 1
    fi

    printf -v "$var_name" "%s" "${input_val:-$default}"
}

# ────────────────────────────────────────────────────────────
# confirm — yes/no prompt
# Usage: confirm "Continue?" "y"  && do_something
#        confirm "Continue?" "n"  || echo "Skipped"
# Returns: 0 for yes, 1 for no
# Displays [Y/n] or [y/N] hint based on default.
# ────────────────────────────────────────────────────────────
confirm() {
    local prompt="$1" default="${2:-n}"
    local hint
    case "$default" in
        y|Y|yes|YES) hint="Y/n" ;;
        *)           hint="y/N" ;;
    esac
    local response=""
    if [[ -c /dev/tty ]]; then
        read -r -p "$prompt [$hint]: " response </dev/tty || true
    elif [[ -t 0 ]]; then
        read -r -p "$prompt [$hint]: " response || true
    else
        err "Interactive input required but no TTY available."
        return 1
    fi
    response="${response:-$default}"
    case "${response,,}" in
        y|yes) return 0 ;;
        *)     return 1 ;;
    esac
}
